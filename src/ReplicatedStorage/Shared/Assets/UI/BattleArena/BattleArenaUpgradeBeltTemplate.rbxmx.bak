<roblox xmlns:xmime="http://www.w3.org/2005/05/xmlmime" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://www.roblox.com/roblox.xsd" version="4">
	<External>null</External>
	<External>nil</External>
	<!-- Root: full-screen transparent container. Parented at runtime to the ScreenGui. -->
	<Item class="Frame" referent="RBX_ROOT">
		<Properties>
			<string name="Name">BattleArenaUpgradeBeltTemplate</string>
			<bool name="Active">false</bool>
			<Color3 name="BackgroundColor3"><R>1</R><G>1</G><B>1</B></Color3>
			<float name="BackgroundTransparency">1</float>
			<int name="BorderSizePixel">0</float>
			<Vector2 name="AnchorPoint"><X>0</X><Y>0</Y></Vector2>
			<UDim2 name="Position"><XS>0</XS><XO>0</XO><YS>0</YS><YO>0</YO></UDim2>
			<UDim2 name="Size"><XS>1</XS><XO>0</XO><YS>1</YS><YO>0</YO></UDim2>
			<int name="ZIndex">30</float>
			<bool name="Visible">false</bool>
		</Properties>

		<!-- UpgradeChoiceBelt: the offer panel. Hidden until an upgrade offer arrives.
		     Position/Size are overridden at runtime by _applyDesktopLayout / _applyMobileLayout.
		     UICorner and UIStroke are added by code if not already present here. -->
		<Item class="Frame" referent="RBX_BELT">
			<Properties>
				<string name="Name">UpgradeChoiceBelt</string>
				<bool name="Active">false</bool>
				<Color3 name="BackgroundColor3"><R>0.051</R><G>0.067</G><B>0.09</B></Color3>
				<float name="BackgroundTransparency">0.08</float>
				<int name="BorderSizePixel">0</float>
				<Vector2 name="AnchorPoint"><X>0.5</X><Y>0</Y></Vector2>
				<UDim2 name="Position"><XS>0.5</XS><XO>0</XO><YS>0</YS><YO>106</YO></UDim2>
				<UDim2 name="Size"><XS>0</XS><XO>380</XO><YS>0</YS><YO>260</YO></UDim2>
				<int name="ZIndex">30</float>
				<bool name="Visible">false</bool>
			</Properties>

			<!-- TitleLabel: displays "LEVEL UP" or "SUPPLY". Text/position set by code. -->
			<Item class="TextLabel" referent="RBX_TITLELABEL">
				<Properties>
					<string name="Name">TitleLabel</string>
					<bool name="Active">false</bool>
					<Color3 name="BackgroundColor3"><R>1</R><G>1</G><B>1</B></Color3>
