					<UDim2 name="Position"><XS>0</XS><XO>14</XO><YS>0</YS><YO>10</YO></UDim2>
					<UDim2 name="Size"><XS>1</XS><XO>-28</XO><YS>0</YS><YO>26</YO></UDim2>
					<int name="ZIndex">31</float>
					<token name="Font">4</token>
					<string name="Text">LEVEL UP</string>
					<Color3 name="TextColor3"><R>0.98</R><G>0.8</G><B>0.082</B></Color3>
					<float name="TextSize">16</float>
					<bool name="TextWrapped">false</bool>
					<token name="TextTruncate">1</token>
					<token name="TextXAlignment">2</token>
					<token name="TextYAlignment">1</token>
				</Properties>
			</Item>

