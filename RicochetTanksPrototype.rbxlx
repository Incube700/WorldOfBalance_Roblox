							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">TankFactory</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">26a304254af295c10a1efee200003b41</UniqueId>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBXbd049ba3c9af4d12a846823a3f9a4647">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local TankRole = {
	Player = "Player",
	DuelOpponent = "DuelOpponent",
	Dummy = "Dummy",
	Bot = "Bot",
	ArenaPlayer = "ArenaPlayer",
	ArenaBot = "ArenaBot",
}

local validRoles = {}

for _, role in pairs(TankRole) do
	validRoles[role] = true
end

function TankRole.IsValid(role)
	return validRoles[role] == true
end

return table.freeze(TankRole)
]]></ProtectedString>
