						</Properties>
					</Item>
				</Item>
				<Item class="Folder" referent="RBXa8bcaa083ffa40ae8574965a80d8b461">
					<Properties>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">Arena</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">37d18a1f00558cc30a17099c0000d6f8</UniqueId>
					</Properties>
					<Item class="ModuleScript" referent="RBXe958b38553004dbdbaa1b821129ccd5c">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local ArenaCombatService = {}

local HttpService = game:GetService("HttpService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local shared = ReplicatedStorage:WaitForChild("Shared")
local configs = shared:WaitForChild("Configs")
local BattleArenaConfig = require(configs:WaitForChild("BattleArenaConfig"))
local BattleArenaLoopConfig = require(configs:WaitForChild("BattleArenaLoopConfig"))

local TankParticipantRegistry = require(script.Parent.Parent:WaitForChild("TankParticipantRegistry"))

ArenaCombatService.MODE_IN_BATTLE_ARENA = "InBattleArena"
ArenaCombatService.MODE_ARENA_RESPAWNING = "ArenaRespawning"

local root = nil
local tankSpawnResetService = nil
local playerWalletService = nil
local upgradeChoiceEvent = nil
local upgradeChoiceConnection = nil

local callbacks = {
	setPlayerMode = nil,
	clearPlayerInput = nil,
	restoreTankColors = nil,
}

local sessionsByPlayer = {}
local sessionsByParticipant = {}
local nextSpawnIndex = 1
local poiStateByInstance = {}
local pickupAccumulator = 0
local controlZoneAccumulator = 0
local survivalAccumulator = 0
local random = Random.new()

local UPGRADE_ORDER = {
	"DamageUp",
	"FireRateUp",
	"MoveSpeedUp",
	"DoubleShot",
	"TripleSpread",
	"RicochetUp",
	"ReflectShield",
	"Repair",
}

local function getServerTimeNow()
	local success, serverTime = pcall(function()
		return Workspace:GetServerTimeNow()
	end)

	if success and typeof(serverTime) == "number" then
		return serverTime
	end

	return os.clock()
end

local function isLoopV02Enabled()
	return BattleArenaLoopConfig.Enabled == true
end

local function getLoopSection(sectionName)
	if not isLoopV02Enabled() then
		return {}
	end

	return BattleArenaLoopConfig[sectionName] or {}
end

local function getLoopNumber(sectionName, valueName, fallback)
	local section = getLoopSection(sectionName)

	return tonumber(section[valueName]) or fallback
end

local function hasProjectileRicochet(sourceProjectile)
	return sourceProjectile ~= nil and (tonumber(sourceProjectile.BounceCount) or 0) > 0
end

local function getSessionSoftEndAt(startedAt)
	local sessionConfig = getLoopSection("Session")

	if sessionConfig.ShowSessionTimer ~= true then
		return 0
	end

	local duration = math.max(0, tonumber(sessionConfig.SoftSessionLengthSeconds) or 0)

	if duration <= 0 then
		return 0
	end

	return startedAt + duration
end

local function getArenaFolder()
	return root ~= nil and root:FindFirstChild("BattleArena") or nil
end

local function getArenaChild(name)
	local arena = getArenaFolder()

	return arena ~= nil and arena:FindFirstChild(name) or nil
end

local function getSpawnFolder()
	local arena = getArenaFolder()

	return arena ~= nil and arena:FindFirstChild("SpawnPoints") or nil
end

local function getYawFromLookVector(lookVector)
	local flatLook = Vector3.new(lookVector.X, 0, lookVector.Z)

	if flatLook.Magnitude < 0.001 then
		return 0
	end

	local unit = flatLook.Unit
	return math.atan2(-unit.X, -unit.Z)
end

local function makeSpawnTransform(position, yaw, source)
	return {
		Position = position,
		BodyYaw = yaw,
		TurretYaw = yaw,
		Source = source,
	}
end

local function getArenaSpawnParts()
	local spawnFolder = getSpawnFolder()
	local spawnParts = {}

	if spawnFolder ~= nil then
		for _, child in ipairs(spawnFolder:GetChildren()) do
			if child:IsA("BasePart") and string.match(child.Name, "^ArenaSpawn%d+$") ~= nil then
				table.insert(spawnParts, child)
			end
		end
	end

	table.sort(spawnParts, function(a, b)
		return a.Name < b.Name
	end)

	return spawnParts
end

local function getFallbackArenaSpawnTransform(player)
	local arena = getArenaFolder()
	local arenaCenter = arena ~= nil and arena:GetAttribute("ArenaCenter") or nil
	local halfSize = arena ~= nil and arena:GetAttribute("ArenaHalfSize") or nil

	if typeof(arenaCenter) ~= "Vector3" then
		arenaCenter = Vector3.new(0, 0, -360)
	end

	if typeof(halfSize) ~= "number" then
		halfSize = 130
	end

	local spawnCount = math.max(1, tonumber(BattleArenaConfig.SpawnPointCount) or 8)
	local userOffset = player ~= nil and math.abs(player.UserId % spawnCount) or 0
	local angle = (math.pi * 2) * (userOffset / spawnCount)
	local radius = math.max(36, halfSize * 0.7)
	local position = arenaCenter + Vector3.new(math.cos(angle) * radius, 0, math.sin(angle) * radius)
	local yaw = getYawFromLookVector((arenaCenter - position).Unit)

	return makeSpawnTransform(position, yaw, "ArenaFallback")
end

local function getArenaSpawnTransform(player)
	local spawnParts = getArenaSpawnParts()

	if #spawnParts == 0 then
		return getFallbackArenaSpawnTransform(player)
	end

	local spawnPart = spawnParts[((nextSpawnIndex - 1) % #spawnParts) + 1]
	nextSpawnIndex += 1

	return makeSpawnTransform(
		spawnPart.Position,
		getYawFromLookVector(spawnPart.CFrame.LookVector),
		spawnPart.Name
	)
end

local function setAttributeOnParticipantModels(participant, attributeName, value)
	if participant == nil then
		return
	end

	local physicalModel = TankParticipantRegistry.getParticipantPhysicalModel(participant)

	if participant.Model ~= nil then
		participant.Model:SetAttribute(attributeName, value)
	end

	if physicalModel ~= nil and physicalModel ~= participant.Model then
		physicalModel:SetAttribute(attributeName, value)
	end
end

local function setPlayerMode(player, participant, mode)
	if callbacks.setPlayerMode ~= nil then
		callbacks.setPlayerMode(player, participant, mode, nil, nil)
		return
	end

	if player ~= nil then
		player:SetAttribute("PlayerMode", mode)
		player:SetAttribute("MatchId", nil)
		player:SetAttribute("OpponentTankId", nil)
	end

	TankParticipantRegistry.setParticipantMatchState(participant, mode, nil, nil)
end

local function clearPlayerInput(player)
	if callbacks.clearPlayerInput ~= nil then
		callbacks.clearPlayerInput(player)
	end
end

local function setArenaModifier(participant, attributeName, value)
	if participant == nil then
		return
	end

	participant[attributeName] = value
	setAttributeOnParticipantModels(participant, attributeName, value)
end

local function getReflectShieldConfig()
	return BattleArenaConfig.ReflectShield or {}
end

local function getReflectShieldMaxCharges()
	return math.max(0, math.floor(tonumber(getReflectShieldConfig().MaxCharges) or 3))
end

local function getReflectShieldSpawnDuration()
	return math.max(0, tonumber(getReflectShieldConfig().SpawnDurationSeconds) or 3)
end

local function isSpawnShieldActive(session, now)
	if session == nil then
		return false
	end

	local serverTime = typeof(now) == "number" and now or getServerTimeNow()
	local spawnShieldUntil = tonumber(session.SpawnShieldUntil)

	return spawnShieldUntil ~= nil and serverTime < spawnShieldUntil
end

local function hasReflectShieldCharge(session)
	return session ~= nil and (tonumber(session.ReflectShieldCharges) or 0) > 0
end

local function isAnyReflectShieldActive(session, now)
	return isSpawnShieldActive(session, now) or hasReflectShieldCharge(session)
end

local function publishShieldAttributes(session, now)
	if session == nil then
		return
	end

	local serverTime = typeof(now) == "number" and now or getServerTimeNow()
	local charges = math.clamp(
		math.floor(tonumber(session.ReflectShieldCharges) or 0),
		0,
		getReflectShieldMaxCharges()
	)
	local spawnShieldUntil = math.max(0, tonumber(session.SpawnShieldUntil) or 0)
	local player = session.Player
	local participant = session.Participant

	session.ReflectShieldCharges = charges
	session.SpawnShieldUntil = spawnShieldUntil
	local shieldActive = isAnyReflectShieldActive(session, serverTime)

	if player ~= nil then
		player:SetAttribute("ArenaReflectShieldCharges", charges)
		player:SetAttribute("ArenaSpawnShieldUntil", spawnShieldUntil)
		player:SetAttribute("ArenaShieldActive", shieldActive)
	end

	if participant ~= nil then
		participant.ArenaReflectShieldCharges = charges
		participant.ArenaSpawnShieldUntil = spawnShieldUntil
		participant.ArenaShieldActive = shieldActive
		setAttributeOnParticipantModels(participant, "ArenaReflectShieldCharges", charges)
		setAttributeOnParticipantModels(participant, "ArenaSpawnShieldUntil", spawnShieldUntil)
		setAttributeOnParticipantModels(participant, "ArenaShieldActive", shieldActive)
	end
end

local function republishShieldAttributesSoon(session)
	task.defer(function()
		local currentSession = session ~= nil
			and (
				(session.Player ~= nil and sessionsByPlayer[session.Player])
				or sessionsByParticipant[session.Participant]
			)
			or nil

		if currentSession == session then
			publishShieldAttributes(session)
		end
	end)
end

local function scheduleSpawnShieldExpiry(session)
	if session == nil then
		return
	end

	local duration = getReflectShieldSpawnDuration()

	if duration <= 0 then
		return
	end

	session.ShieldToken = (session.ShieldToken or 0) + 1
	local shieldToken = session.ShieldToken

	task.delay(duration, function()
		if session.ShieldToken ~= shieldToken then
			return
		end

		local currentSession = session.Player ~= nil
			and sessionsByPlayer[session.Player]
			or sessionsByParticipant[session.Participant]

		if currentSession ~= session then
			return
		end

		local now = getServerTimeNow()

		if (tonumber(session.SpawnShieldUntil) or 0) <= now then
			session.SpawnShieldUntil = 0
			publishShieldAttributes(session, now)
		end
	end)
end

local function grantSpawnReflectShield(session, _reason)
	if session == nil then
		return
	end

	local duration = getReflectShieldSpawnDuration()

	if duration <= 0 then
		session.SpawnShieldUntil = 0
		publishShieldAttributes(session)
		return
	end

	local now = getServerTimeNow()
	session.SpawnShieldUntil = now + duration
	publishShieldAttributes(session, now)
	scheduleSpawnShieldExpiry(session)
	republishShieldAttributesSoon(session)
end

local function resetParticipantArenaModifiers(participant)
	if participant == nil then
		return
	end

	setArenaModifier(participant, "ArenaDamageMultiplier", 1)
	setArenaModifier(participant, "ArenaFireRateMultiplier", 1)
	setArenaModifier(participant, "ArenaMoveSpeedMultiplier", 1)
	setArenaModifier(participant, "ArenaProjectileCount", 1)
	setArenaModifier(participant, "ArenaSpreadDegrees", 0)
	setArenaModifier(participant, "ArenaDoubleShotLateralOffset", 0)
	setArenaModifier(participant, "ArenaRicochetBonus", 0)
	setArenaModifier(participant, "ArenaUpgradeIds", "")
	setArenaModifier(participant, "ArenaReflectShieldCharges", 0)
	setArenaModifier(participant, "ArenaSpawnShieldUntil", 0)
	setArenaModifier(participant, "ArenaShieldActive", false)
end

local function setPlayerArenaDefaults(player)
	if player == nil then
		return
	end

	player:SetAttribute("ArenaScore", 0)
	player:SetAttribute("ArenaXP", 0)
	player:SetAttribute("ArenaLevel", 1)
	player:SetAttribute("ArenaNextLevelXP", BattleArenaConfig.LevelThresholds[2])
	player:SetAttribute("ArenaKills", 0)
	player:SetAttribute("ArenaDeaths", 0)
	player:SetAttribute("ArenaStreak", 0)
	player:SetAttribute("ArenaRespawnAt", 0)
	player:SetAttribute("ArenaRespawnDelay", BattleArenaConfig.RespawnDelay)
	player:SetAttribute("ArenaStatus", "")
	player:SetAttribute("ArenaUpgradeIds", "")
	player:SetAttribute("ArenaPendingUpgradeOfferId", "")
	player:SetAttribute("ArenaPendingUpgradeOfferSource", "")
	player:SetAttribute("ArenaSessionStartedAt", 0)
	player:SetAttribute("ArenaSessionSoftEndsAt", 0)
	player:SetAttribute("ArenaSessionBolts", 0)
	player:SetAttribute("ArenaLastSummary", "")
	player:SetAttribute("ArenaDamageMultiplier", 1)
	player:SetAttribute("ArenaFireRateMultiplier", 1)
	player:SetAttribute("ArenaMoveSpeedMultiplier", 1)
	player:SetAttribute("ArenaProjectileCount", 1)
	player:SetAttribute("ArenaRicochetBonus", 0)
	player:SetAttribute("ArenaReflectShieldCharges", 0)
	player:SetAttribute("ArenaSpawnShieldUntil", 0)
	player:SetAttribute("ArenaShieldActive", false)
end

local function publishSessionAttributes(session)
	local player = session.Player

	if player == nil then
		return
	end

	player:SetAttribute("ArenaScore", session.Score)
	player:SetAttribute("ArenaXP", session.ArenaXP)
	player:SetAttribute("ArenaLevel", session.ArenaLevel)
	player:SetAttribute("ArenaNextLevelXP", session.NextLevelXP)
	player:SetAttribute("ArenaKills", session.Kills)
	player:SetAttribute("ArenaDeaths", session.Deaths)
	player:SetAttribute("ArenaStreak", session.Streak)
	player:SetAttribute("ArenaUpgradeIds", table.concat(session.UpgradeIds, ","))
	player:SetAttribute("ArenaPendingUpgradeOfferId", session.PendingUpgradeOfferId or "")
	player:SetAttribute("ArenaPendingUpgradeOfferSource", session.PendingUpgradeOfferSource or "")
	player:SetAttribute("ArenaSessionStartedAt", session.StartedAt or 0)
	player:SetAttribute("ArenaSessionSoftEndsAt", session.SoftEndsAt or 0)
	player:SetAttribute("ArenaSessionBolts", session.EarnedBolts or 0)
	player:SetAttribute("ArenaLastSummary", session.LastSummary or "")
	player:SetAttribute("ArenaDamageMultiplier", session.DamageMultiplier)
	player:SetAttribute("ArenaFireRateMultiplier", session.FireRateMultiplier)
	player:SetAttribute("ArenaMoveSpeedMultiplier", session.MoveSpeedMultiplier)
	player:SetAttribute("ArenaProjectileCount", session.ProjectileCount)
	player:SetAttribute("ArenaRicochetBonus", session.RicochetBonus)
	publishShieldAttributes(session)
end

local function hasUpgrade(session, upgradeId)
	for _, existingUpgradeId in ipairs(session.UpgradeIds) do
		if existingUpgradeId == upgradeId then
			return true
		end
	end

	return false
end

local function countUpgradeStacks(session, upgradeId)
	local count = 0

	for _, existingUpgradeId in ipairs(session.UpgradeIds) do
		if existingUpgradeId == upgradeId then
			count += 1
		end
	end

	return count
end

local function getUpgradeDefinition(upgradeId)
	local pool = BattleArenaConfig.UpgradePool or {}

	return pool[upgradeId]
end

local function getUpgradeMaxStacks(upgradeId)
	local definition = getUpgradeDefinition(upgradeId)

	if definition == nil then
		return 0
	end

	if definition.Immediate == true then
		return math.huge
	end

	return math.max(1, math.floor(tonumber(definition.MaxStacks) or 1))
end

local function isUpgradeChoiceValid(session, upgradeId)
	if session == nil or typeof(upgradeId) ~= "string" then
		return false
	end

	local definition = getUpgradeDefinition(upgradeId)

	if definition == nil then
		return false
	end

	if definition.Immediate == true then
		return true
	end

	if upgradeId == "DoubleShot" and hasUpgrade(session, "TripleSpread") then
		return false
	end

	if upgradeId == "TripleSpread" and not hasUpgrade(session, "DoubleShot") then
		return false
	end

	local requiredUpgrade = definition.RequiresUpgrade

	if typeof(requiredUpgrade) == "string" and not hasUpgrade(session, requiredUpgrade) then
		return false
	end

	return countUpgradeStacks(session, upgradeId) < getUpgradeMaxStacks(upgradeId)
end

local function getValidUpgradeIds(session)
	local upgradeIds = {}

	for _, upgradeId in ipairs(UPGRADE_ORDER) do
		if isUpgradeChoiceValid(session, upgradeId) then
			table.insert(upgradeIds, upgradeId)
		end
	end

	return upgradeIds
end

local function makeUpgradeChoicePayload(session, upgradeId)
	local definition = getUpgradeDefinition(upgradeId) or {}
	local currentStacks = countUpgradeStacks(session, upgradeId)
	local maxStacks = getUpgradeMaxStacks(upgradeId)

	return {
		Id = upgradeId,
		Title = definition.Title or upgradeId,
		Description = definition.Description or "",
		Stack = definition.Immediate == true and 0 or currentStacks + 1,
		MaxStacks = maxStacks == math.huge and 0 or maxStacks,
		Immediate = definition.Immediate == true,
	}
end

local function applySessionUpgrades(session)
	local participant = session.Participant
	local damageStacks = countUpgradeStacks(session, "DamageUp")
	local moveSpeedStacks = countUpgradeStacks(session, "MoveSpeedUp")
	local damageStep = (tonumber(BattleArenaConfig.DamageUpMultiplier) or 1.2) - 1
	local moveSpeedStep = (tonumber(BattleArenaConfig.MoveSpeedMultiplier) or 1.1) - 1

	session.DamageMultiplier = 1 + damageStep * damageStacks
	session.FireRateMultiplier = hasUpgrade(session, "FireRateUp") and BattleArenaConfig.FireRateMultiplier or 1
	session.MoveSpeedMultiplier = 1 + moveSpeedStep * moveSpeedStacks
	session.RicochetBonus = hasUpgrade(session, "RicochetUp") and (tonumber(BattleArenaConfig.RicochetUpBonus) or 1) or 0

	if hasUpgrade(session, "TripleSpread") then
		session.ProjectileCount = 3
		session.SpreadDegrees = BattleArenaConfig.MultiShotSpreadDegrees
		session.DoubleShotLateralOffset = 0
	elseif hasUpgrade(session, "DoubleShot") then
		session.ProjectileCount = 2
		session.SpreadDegrees = 0
		session.DoubleShotLateralOffset = BattleArenaConfig.DoubleShotLateralOffset
	else
		session.ProjectileCount = 1
		session.SpreadDegrees = 0
		session.DoubleShotLateralOffset = 0
	end

	setArenaModifier(participant, "ArenaDamageMultiplier", session.DamageMultiplier)
	setArenaModifier(participant, "ArenaFireRateMultiplier", session.FireRateMultiplier)
	setArenaModifier(participant, "ArenaMoveSpeedMultiplier", session.MoveSpeedMultiplier)
	setArenaModifier(participant, "ArenaProjectileCount", session.ProjectileCount)
	setArenaModifier(participant, "ArenaSpreadDegrees", session.SpreadDegrees)
	setArenaModifier(participant, "ArenaDoubleShotLateralOffset", session.DoubleShotLateralOffset)
	setArenaModifier(participant, "ArenaRicochetBonus", session.RicochetBonus)
	setArenaModifier(participant, "ArenaUpgradeIds", table.concat(session.UpgradeIds, ","))
	publishSessionAttributes(session)

	if BattleArenaConfig.Debug == true then
		local ownerName = session.Player ~= nil and session.Player.Name or tostring(participant ~= nil and participant.TankId or "Bot")
		print("[ARENA] upgrades " .. ownerName .. " -> " .. table.concat(session.UpgradeIds, ","))
	end
end

local function getLevelThreshold(level)
	local thresholds = BattleArenaConfig.LevelThresholds or {}

	return tonumber(thresholds[level])
end

local function getNextLevelThreshold(level)
	return getLevelThreshold((tonumber(level) or 1) + 1)
end

local function updateNextLevelXP(session)
	session.NextLevelXP = getNextLevelThreshold(session.ArenaLevel)
end

local function clearPendingUpgradeOffer(session)
	session.PendingUpgradeOffer = nil
	session.PendingUpgradeOfferId = ""
	session.PendingUpgradeOfferSource = ""
	publishSessionAttributes(session)
end

local function fireUpgradeOffer(session)
	if upgradeChoiceEvent == nil or session.Player == nil or session.PendingUpgradeOffer == nil then
		return
	end

	upgradeChoiceEvent:FireClient(session.Player, session.PendingUpgradeOffer)
end

local function createUpgradeOffer(session, source)
	if session == nil or session.Player == nil or session.PendingUpgradeOffer ~= nil then
		return false
	end

	local validUpgradeIds = getValidUpgradeIds(session)

	if #validUpgradeIds == 0 then
		return false
	end

	for index = #validUpgradeIds, 2, -1 do
		local swapIndex = random:NextInteger(1, index)
		validUpgradeIds[index], validUpgradeIds[swapIndex] = validUpgradeIds[swapIndex], validUpgradeIds[index]
	end

	local choiceCount = math.min(
		math.max(1, math.floor(tonumber(BattleArenaConfig.UpgradeChoicesPerOffer) or 3)),
		#validUpgradeIds
	)
	local choices = {}

	for index = 1, choiceCount do
		table.insert(choices, makeUpgradeChoicePayload(session, validUpgradeIds[index]))
	end

	local offerId = "ArenaOffer_" .. HttpService:GenerateGUID(false)
	session.PendingUpgradeOffer = {
		OfferId = offerId,
		Source = source or "LevelUp",
		ArenaLevel = session.ArenaLevel,
		Choices = choices,
	}
	session.PendingUpgradeOfferId = offerId
	session.PendingUpgradeOfferSource = source or "LevelUp"
	publishSessionAttributes(session)
	fireUpgradeOffer(session)

	return true
end

local function ensurePendingLevelOffer(session)
	if session == nil or session.PendingUpgradeOffer ~= nil then
		return
	end

	if (session.UnclaimedLevelUpOffers or 0) <= 0 then
		return
	end

	if not createUpgradeOffer(session, "LevelUp") then
		session.UnclaimedLevelUpOffers = 0
		publishSessionAttributes(session)
	end
end

local function addArenaXP(session, amount, reason)
	if session == nil or session.IsBotSession == true then
		return false
	end

	local xpAmount = math.max(0, math.floor(tonumber(amount) or 0))

	if xpAmount <= 0 then
		return false
	end

	session.ArenaXP += xpAmount

	local maxLevel = math.max(1, math.floor(tonumber(BattleArenaConfig.MaxArenaLevel) or 5))

	while session.ArenaLevel < maxLevel do
		local nextThreshold = getNextLevelThreshold(session.ArenaLevel)

		if nextThreshold == nil or session.ArenaXP < nextThreshold then
			break
		end

		session.ArenaLevel += 1
		session.UnclaimedLevelUpOffers += 1
	end

	updateNextLevelXP(session)
	publishSessionAttributes(session)
	ensurePendingLevelOffer(session)

	if BattleArenaConfig.Debug == true then
		local playerName = session.Player ~= nil and session.Player.Name or "Unknown"
		print(
			("[ARENA XP] player=%s amount=%d reason=%s xp=%d level=%d"):format(
				playerName,
				xpAmount,
				tostring(reason or "Unknown"),
				session.ArenaXP,
				session.ArenaLevel
			)
		)
	end

	return true
end

local function applyRepairUpgrade(session)
	local participant = session.Participant

	if participant == nil then
		return
	end

	local currentHealth = TankParticipantRegistry.getParticipantHealth(participant)
	local maxHealth = TankParticipantRegistry.getParticipantMaxHealth(participant)
	local healAmount = math.max(0, tonumber(BattleArenaConfig.RepairHealAmount) or 30)

	TankParticipantRegistry.setParticipantHealth(participant, math.min(maxHealth, currentHealth + healAmount))
end

local function grantReflectShieldUpgradeCharge(session)
	if session == nil then
		return
	end

	local grantCharges = math.max(0, math.floor(tonumber(getReflectShieldConfig().UpgradeGrantCharges) or 1))

	session.ReflectShieldCharges = math.clamp(
		(tonumber(session.ReflectShieldCharges) or 0) + grantCharges,
		0,
		getReflectShieldMaxCharges()
	)
end

local function applyChosenUpgrade(session, upgradeId)
	if upgradeId == "Repair" then
		applyRepairUpgrade(session)
		publishSessionAttributes(session)
		return true
	end

	table.insert(session.UpgradeIds, upgradeId)

	if upgradeId == "ReflectShield" then
		grantReflectShieldUpgradeCharge(session)
	end

	applySessionUpgrades(session)

	return true
end

local function resetArenaRun(session)
	if session == nil then
		return
	end

	session.ArenaXP = 0
	session.ArenaLevel = 1
	updateNextLevelXP(session)
	session.Streak = 0
	session.UpgradeIds = {}
	session.ForcedUpgrades = {}
	session.UnclaimedLevelUpOffers = 0
	session.ReflectShieldCharges = 0
	session.SpawnShieldUntil = 0
	session.ShieldToken = (session.ShieldToken or 0) + 1
	clearPendingUpgradeOffer(session)
	resetParticipantArenaModifiers(session.Participant)
	applySessionUpgrades(session)
end

local function makeSession(player, participant)
	local startedAt = getServerTimeNow()

	return {
		Player = player,
		Participant = participant,
		SessionId = "Arena_" .. tostring(player.UserId) .. "_" .. tostring(math.floor(os.clock() * 1000)),
		RespawnToken = 0,
		ShieldToken = 0,
		StartedAt = startedAt,
		SoftEndsAt = getSessionSoftEndAt(startedAt),
		Score = 0,
		ArenaXP = 0,
		ArenaLevel = 1,
		NextLevelXP = getNextLevelThreshold(1),
		Kills = 0,
		Deaths = 0,
		Streak = 0,
		EarnedBolts = 0,
		LastSummary = "",
		UpgradeIds = {},
		ForcedUpgrades = {},
		UnclaimedLevelUpOffers = 0,
		PendingUpgradeOffer = nil,
		PendingUpgradeOfferId = "",
		PendingUpgradeOfferSource = "",
		DamageMultiplier = 1,
		FireRateMultiplier = 1,
		MoveSpeedMultiplier = 1,
		ProjectileCount = 1,
		SpreadDegrees = 0,
		DoubleShotLateralOffset = 0,
		RicochetBonus = 0,
		ReflectShieldCharges = 0,
		SpawnShieldUntil = 0,
	}
end

local function makeBotSession(participant)
	return {
		Player = nil,
		Participant = participant,
		SessionId = "ArenaBot_" .. tostring(participant ~= nil and participant.TankId or "Unknown"),
		RespawnToken = 0,
		ShieldToken = 0,
		StartedAt = 0,
		SoftEndsAt = 0,
		Score = 0,
		ArenaXP = 0,
		ArenaLevel = 1,
		NextLevelXP = getNextLevelThreshold(1),
		Kills = 0,
		Deaths = 0,
		Streak = 0,
		EarnedBolts = 0,
		LastSummary = "",
		UpgradeIds = {},
		ForcedUpgrades = {},
		UnclaimedLevelUpOffers = 0,
		PendingUpgradeOffer = nil,
		PendingUpgradeOfferId = "",
		PendingUpgradeOfferSource = "",
		DamageMultiplier = 1,
		FireRateMultiplier = 1,
		MoveSpeedMultiplier = 1,
		ProjectileCount = 1,
		SpreadDegrees = 0,
		DoubleShotLateralOffset = 0,
		RicochetBonus = 0,
		ReflectShieldCharges = 0,
		SpawnShieldUntil = 0,
		IsBotSession = true,
	}
end

function ArenaCombatService.init(options)
	options = options or {}
	root = options.root
	tankSpawnResetService = options.tankSpawnResetService
	playerWalletService = options.playerWalletService
	upgradeChoiceEvent = options.upgradeChoiceEvent
	callbacks.setPlayerMode = options.setPlayerMode
	callbacks.clearPlayerInput = options.clearPlayerInput
	callbacks.restoreTankColors = options.restoreTankColors

	if upgradeChoiceConnection ~= nil then
		upgradeChoiceConnection:Disconnect()
		upgradeChoiceConnection = nil
	end

	if upgradeChoiceEvent ~= nil then
		upgradeChoiceConnection = upgradeChoiceEvent.OnServerEvent:Connect(function(player, payload)
			ArenaCombatService.HandleUpgradeChoice(player, payload)
		end)
	end
end

function ArenaCombatService.IsEnabled()
	return BattleArenaConfig.Enabled == true
end

function ArenaCombatService.IsPlayerInArena(player)
	return player ~= nil and sessionsByPlayer[player] ~= nil
end

function ArenaCombatService.IsParticipantInArena(participant)
	return participant ~= nil and sessionsByParticipant[participant] ~= nil
end

function ArenaCombatService.GetSession(player)
	return sessionsByPlayer[player]
end

function ArenaCombatService.GetActivePlayerCount()
	local count = 0

	for player, _ in pairs(sessionsByPlayer) do
		if player ~= nil and player.Parent == Players then
			count += 1
		end
	end

	return count
end

function ArenaCombatService.GetActiveParticipants()
	local participants = {}

	for participant, _ in pairs(sessionsByParticipant) do
		if participant ~= nil then
			table.insert(participants, participant)
		end
	end

	return participants
end

function ArenaCombatService.RegisterBotParticipant(participant)
	if participant == nil then
		return nil
	end

	local existingSession = sessionsByParticipant[participant]

	if existingSession ~= nil then
		return existingSession
	end

	local session = makeBotSession(participant)
	sessionsByParticipant[participant] = session
	resetParticipantArenaModifiers(participant)
	TankParticipantRegistry.setParticipantMatchState(participant, ArenaCombatService.MODE_IN_BATTLE_ARENA, nil, nil)

	return session
end

function ArenaCombatService.UnregisterBotParticipant(participant)
	local session = sessionsByParticipant[participant]

	if session == nil or session.IsBotSession ~= true then
		return nil
	end

	sessionsByParticipant[participant] = nil
	resetParticipantArenaModifiers(participant)
	TankParticipantRegistry.setParticipantMatchState(participant, nil, nil, nil)

	return session
end

function ArenaCombatService.EnterArena(player)
	if not ArenaCombatService.IsEnabled() then
		return false
	end

	local participant = TankParticipantRegistry.getPlayerParticipant(player)

	if player == nil or participant == nil then
		return false
	end

	local existingSession = sessionsByPlayer[player]

	if existingSession ~= nil then
		ArenaCombatService.RespawnPlayer(player)
		return true
	end

	local session = makeSession(player, participant)
	sessionsByPlayer[player] = session
	sessionsByParticipant[participant] = session

	setPlayerArenaDefaults(player)
	resetParticipantArenaModifiers(participant)
	player:SetAttribute("ArenaStatus", "Active")
	player:SetAttribute("ArenaSessionId", session.SessionId)
	setPlayerMode(player, participant, ArenaCombatService.MODE_IN_BATTLE_ARENA)

	TankParticipantRegistry.setParticipantModelVisible(participant, true)
	TankParticipantRegistry.resetParticipantHealth(participant)

	if callbacks.restoreTankColors ~= nil then
		callbacks.restoreTankColors(participant)
	end

	tankSpawnResetService.applySpawnToParticipant(participant, getArenaSpawnTransform(player))
	clearPlayerInput(player)
	applySessionUpgrades(session)
	grantSpawnReflectShield(session, "EnterArena")
	print("[ARENA] player entered battle arena " .. player.Name .. " -> " .. participant.TankId)

	return true
end

function ArenaCombatService.ResetArenaSession(player)
	local session = sessionsByPlayer[player]

	if session ~= nil then
		local startedAt = getServerTimeNow()
		session.Score = 0
		session.Kills = 0
		session.Deaths = 0
		session.EarnedBolts = 0
		session.StartedAt = startedAt
		session.SoftEndsAt = getSessionSoftEndAt(startedAt)
		session.LastSummary = ""
		session.RespawnToken += 1
		resetArenaRun(session)
	end

	setPlayerArenaDefaults(player)
end

function ArenaCombatService.LeaveArena(player)
	local session = sessionsByPlayer[player]

	if session == nil then
		setPlayerArenaDefaults(player)
		return nil
	end

	session.RespawnToken += 1
	sessionsByPlayer[player] = nil
	sessionsByParticipant[session.Participant] = nil
	resetParticipantArenaModifiers(session.Participant)
	setPlayerArenaDefaults(player)
	player:SetAttribute("ArenaSessionId", nil)
	clearPlayerInput(player)
	print("[ARENA] left " .. player.Name)

	return session.Participant
end

function ArenaCombatService.GetArenaScore(player)
	local session = sessionsByPlayer[player]

	return session ~= nil and session.Score or 0
end

local function getParticipantModel(participant)
	if participant == nil then
		return nil
	end

	return TankParticipantRegistry.getParticipantPhysicalModel(participant) or participant.Model
end

local function getParticipantPosition(participant)
	local model = getParticipantModel(participant)

	if model == nil then
		return nil
	end

	local body = model:FindFirstChild("Body", true)
		or model:FindFirstChild("Hull", true)
		or model.PrimaryPart

	if body ~= nil and body:IsA("BasePart") then
		return body.Position
	end

	local ok, pivot = pcall(function()
		return model:GetPivot()
	end)

	if ok then
		return pivot.Position
	end

	return nil
end

local function isParticipantAlive(participant)
	return participant ~= nil
		and participant.IsActive == true
		and TankParticipantRegistry.getParticipantIsDead(participant) ~= true
end

local function getPoiBounds(instance)
	if instance == nil then
		return nil, nil
	end

	if instance:IsA("BasePart") then
		return instance.CFrame, instance.Size
	elseif instance:IsA("Model") then
		local ok, cframe, size = pcall(function()
			return instance:GetBoundingBox()
		end)

		if ok then
			return cframe, size
		end
	end

	return nil, nil
end

local function isPositionInsidePoi(instance, position)
	local cframe, size = getPoiBounds(instance)

	if cframe == nil or size == nil or typeof(position) ~= "Vector3" then
		return false
	end

	local localPosition = cframe:PointToObjectSpace(position)
	local verticalHalfSize = math.max(size.Y * 0.5 + 6, 8)

	return math.abs(localPosition.X) <= size.X * 0.5
		and math.abs(localPosition.Z) <= size.Z * 0.5
		and math.abs(localPosition.Y) <= verticalHalfSize
end

local function collectPoiParts(instance)
	local parts = {}

	if instance:IsA("BasePart") then
		table.insert(parts, instance)
	else
		for _, descendant in ipairs(instance:GetDescendants()) do
			if descendant:IsA("BasePart") then
				table.insert(parts, descendant)
			end
		end
	end

	return parts
end

local function getPoiState(instance)
	local state = poiStateByInstance[instance]

	if state ~= nil then
		return state
	end

	state = {
		InactiveUntil = 0,
		LastUserId = nil,
		OriginalParts = {},
	}

	for _, part in ipairs(collectPoiParts(instance)) do
		state.OriginalParts[part] = {
			Transparency = part.Transparency,
			CanQuery = part.CanQuery,
			CanTouch = part.CanTouch,
		}
	end

	poiStateByInstance[instance] = state
	return state
end

local function setPoiActive(instance, isActive)
	local state = getPoiState(instance)

	for part, original in pairs(state.OriginalParts) do
		if part.Parent ~= nil then
			if isActive then
				part.Transparency = original.Transparency
				part.CanQuery = original.CanQuery
				part.CanTouch = original.CanTouch
			else
				part.Transparency = 1
				part.CanQuery = false
				part.CanTouch = false
			end
		end
	end
end

local function getPoiChildren(folderName)
	local folder = getArenaChild(folderName)
	local children = {}

	if folder == nil then
		return children
	end

	for _, child in ipairs(folder:GetChildren()) do
		if child:IsA("BasePart") or child:IsA("Model") then
			table.insert(children, child)
		end
	end

	return children
end

local function getParticipantInsidePoi(instance, playersOnly)
	for participant, session in pairs(sessionsByParticipant) do
		if isParticipantAlive(participant)
			and (playersOnly ~= true or session.Player ~= nil)
			and isPositionInsidePoi(instance, getParticipantPosition(participant))
		then
			return participant, session
		end
	end

	return nil, nil
end

local function reactivatePoiIfReady(instance, state, now)
	if (state.InactiveUntil or 0) <= 0 or now < state.InactiveUntil then
		return false
	end

	state.InactiveUntil = 0
	state.LastUserId = nil
	setPoiActive(instance, true)

	return true
end

local function processMedkits(now)
	for _, medkit in ipairs(getPoiChildren(BattleArenaConfig.MedkitFolderName or "Medkits")) do
		local state = getPoiState(medkit)
		reactivatePoiIfReady(medkit, state, now)

		if (state.InactiveUntil or 0) > 0 then
			continue
		end

		local participant = getParticipantInsidePoi(medkit, false)

		if participant == nil then
			continue
		end

		local currentHealth = TankParticipantRegistry.getParticipantHealth(participant)
		local maxHealth = TankParticipantRegistry.getParticipantMaxHealth(participant)

		if currentHealth >= maxHealth then
			continue
		end

		local healAmount = math.max(0, tonumber(BattleArenaConfig.MedkitHealAmount) or 40)
		TankParticipantRegistry.setParticipantHealth(participant, math.min(maxHealth, currentHealth + healAmount))
		state.InactiveUntil = now + math.max(0, tonumber(BattleArenaConfig.MedkitRespawnTime) or 30)
		setPoiActive(medkit, false)
	end
end

local function processSupplyCrates(now)
	for _, crate in ipairs(getPoiChildren(BattleArenaConfig.SupplyCrateFolderName or "SupplyCrates")) do
		local state = getPoiState(crate)
		reactivatePoiIfReady(crate, state, now)

		if (state.InactiveUntil or 0) > 0 then
			continue
		end

		local _, session = getParticipantInsidePoi(crate, true)
		local player = session ~= nil and session.Player or nil

		if player == nil
			or session.PendingUpgradeOffer ~= nil
			or state.LastUserId == player.UserId
		then
			continue
		end

		if createUpgradeOffer(session, "SupplyCrate") then
			addArenaXP(session, BattleArenaConfig.XPPerSupplyCrateUse, "SupplyCrate")
			state.LastUserId = player.UserId
			state.InactiveUntil = now + math.max(0, tonumber(BattleArenaConfig.CrateRespawnTime) or 60)
			setPoiActive(crate, false)
		end
	end
end

local function processControlZone()
	local controlZone = getArenaChild(BattleArenaConfig.ControlZoneName or "ControlZone")

	if controlZone == nil or not (controlZone:IsA("BasePart") or controlZone:IsA("Model")) then
		return
	end

	for participant, session in pairs(sessionsByParticipant) do
		if session.Player ~= nil
			and isParticipantAlive(participant)
			and isPositionInsidePoi(controlZone, getParticipantPosition(participant))
		then
			addArenaXP(session, BattleArenaConfig.XPPerControlZoneTick, "ControlZone")
		end
	end
end

local function processSurvivalXP()
	local xpPerTick = math.max(0, tonumber(BattleArenaConfig.XPPerSurvivalTick) or 0)

	if xpPerTick <= 0 then
		return
	end

	for participant, session in pairs(sessionsByParticipant) do
		if session.Player ~= nil and isParticipantAlive(participant) then
			addArenaXP(session, xpPerTick, "Survival")
		end
	end
end

function ArenaCombatService.ApplyUpgrade(player, upgradeId)
	local session = sessionsByPlayer[player]

	if session == nil or typeof(upgradeId) ~= "string" then
		return false
	end

	if isUpgradeChoiceValid(session, upgradeId) then
		return applyChosenUpgrade(session, upgradeId)
	end

	return false
end

function ArenaCombatService.HandleUpgradeChoice(player, payload)
	local session = sessionsByPlayer[player]

	if session == nil or session.PendingUpgradeOffer == nil or typeof(payload) ~= "table" then
		return false
	end

	local offerId = payload.OfferId
	local upgradeId = payload.UpgradeId

	if typeof(offerId) ~= "string"
		or typeof(upgradeId) ~= "string"
		or offerId ~= session.PendingUpgradeOfferId
	then
		return false
	end

	local selectedWasOffered = false

	for _, choice in ipairs(session.PendingUpgradeOffer.Choices or {}) do
		if choice.Id == upgradeId then
			selectedWasOffered = true
			break
		end
	end

	if not selectedWasOffered or not isUpgradeChoiceValid(session, upgradeId) then
		return false
	end

	local source = session.PendingUpgradeOfferSource
	clearPendingUpgradeOffer(session)

	if source == "LevelUp" then
		session.UnclaimedLevelUpOffers = math.max(0, (session.UnclaimedLevelUpOffers or 0) - 1)
	end

	applyChosenUpgrade(session, upgradeId)
	ensurePendingLevelOffer(session)

	return true
end

function ArenaCombatService.RespawnPlayer(player)
	local session = sessionsByPlayer[player]

	if session == nil or player == nil or player.Parent ~= Players then
		return false
	end

	local participant = session.Participant

	if participant == nil then
		return false
	end

	TankParticipantRegistry.setParticipantModelVisible(participant, true)
	TankParticipantRegistry.resetParticipantHealth(participant)

	if callbacks.restoreTankColors ~= nil then
		callbacks.restoreTankColors(participant)
	end

	tankSpawnResetService.applySpawnToParticipant(participant, getArenaSpawnTransform(player))
	setPlayerMode(player, participant, ArenaCombatService.MODE_IN_BATTLE_ARENA)
	player:SetAttribute("ArenaRespawnAt", 0)
	player:SetAttribute("ArenaStatus", "Active")
	clearPlayerInput(player)
	applySessionUpgrades(session)
	grantSpawnReflectShield(session, "Respawn")
	print("[ARENA] respawned " .. player.Name)

	return true
end

local function updateArenaSummary(session)
	if session == nil or session.IsBotSession == true then
		return
	end

	session.LastSummary = ("Run: %d kills / %d deaths / +%d Bolts"):format(
		math.floor(session.Kills or 0),
		math.floor(session.Deaths or 0),
		math.floor(session.EarnedBolts or 0)
	)
end

local function getPlayerKillScore(killerSession, victimSession, sourceProjectile)
	local defaultKillScore = math.max(0, math.floor(tonumber(BattleArenaConfig.KillScore) or 0))

	if killerSession == nil or killerSession.IsBotSession == true then
		return 0
	end

	if victimSession == nil or victimSession.IsBotSession ~= true or not isLoopV02Enabled() then
		return defaultKillScore
	end

	local score = math.max(0, math.floor(getLoopNumber("Score", "PlayerKillBot", defaultKillScore)))

	if hasProjectileRicochet(sourceProjectile) then
		score += math.max(0, math.floor(getLoopNumber("Score", "RicochetKillBonus", 0)))
	end

	return score
end

local function awardArenaKillCurrency(killerSession, victimSession, sourceProjectile)
	if killerSession == nil
		or killerSession.IsBotSession == true
		or killerSession.Player == nil
		or victimSession == nil
		or victimSession.IsBotSession ~= true
		or playerWalletService == nil
		or playerWalletService.addBolts == nil
		or not isLoopV02Enabled()
	then
		return
	end

	local rewardAmount = math.max(0, math.floor(getLoopNumber("Rewards", "BoltsPerBotKill", 0)))
	local reason = "BattleArenaBotKill"

	if hasProjectileRicochet(sourceProjectile) then
		rewardAmount += math.max(0, math.floor(getLoopNumber("Rewards", "BoltsPerRicochetKillBonus", 0)))
		reason = "BattleArenaRicochetKill"
	end

	if rewardAmount <= 0 then
		return
	end

	local awarded = playerWalletService.addBolts(killerSession.Player, rewardAmount, reason)

	if awarded then
		killerSession.EarnedBolts += rewardAmount
	end
end

function ArenaCombatService.OnParticipantKilled(killerParticipant, victimParticipant, sourceProjectile)
	local victimSession = sessionsByParticipant[victimParticipant]

	if victimSession == nil then
		return
	end

	local victimPlayer = victimSession.Player
	victimSession.Deaths += 1
	resetArenaRun(victimSession)

	local killerSession = nil

	if killerParticipant ~= nil and killerParticipant ~= victimParticipant then
		killerSession = sessionsByParticipant[killerParticipant]
	end

	if killerSession ~= nil and killerSession.IsBotSession ~= true then
		killerSession.Score += getPlayerKillScore(killerSession, victimSession, sourceProjectile)
		awardArenaKillCurrency(killerSession, victimSession, sourceProjectile)
		addArenaXP(killerSession, BattleArenaConfig.XPPerKill, "Kill")
		killerSession.Kills += 1
		killerSession.Streak += 1
		updateArenaSummary(killerSession)
		applySessionUpgrades(killerSession)
	end

	updateArenaSummary(victimSession)
	publishSessionAttributes(victimSession)

	if victimPlayer == nil or victimPlayer.Parent ~= Players then
		return
	end

	victimSession.RespawnToken += 1
	local token = victimSession.RespawnToken
	local respawnDelay = math.max(0, tonumber(BattleArenaConfig.RespawnDelay) or 0)
	local respawnAt = getServerTimeNow() + respawnDelay

	setPlayerMode(victimPlayer, victimParticipant, ArenaCombatService.MODE_ARENA_RESPAWNING)
	victimPlayer:SetAttribute("ArenaStatus", "Destroyed")
	victimPlayer:SetAttribute("ArenaRespawnDelay", respawnDelay)
	victimPlayer:SetAttribute("ArenaRespawnAt", respawnAt)
	clearPlayerInput(victimPlayer)

	task.delay(respawnDelay, function()
		local currentSession = sessionsByPlayer[victimPlayer]

		if currentSession ~= victimSession or currentSession.RespawnToken ~= token then
			return
		end

		ArenaCombatService.RespawnPlayer(victimPlayer)
	end)
end

function ArenaCombatService.CanDamageParticipant(projectile, targetParticipant)
	if projectile == nil or targetParticipant == nil or projectile.NoDamage == true then
		return false
	end

	local ownerSession = sessionsByParticipant[projectile.OwnerParticipant]
	local targetSession = sessionsByParticipant[targetParticipant]

	return ownerSession ~= nil and targetSession ~= nil
end

function ArenaCombatService.TryConsumeReflectShield(projectile, targetParticipant)
	if projectile == nil or targetParticipant == nil or projectile.NoDamage == true then
		return false, nil
	end

	local ownerSession = sessionsByParticipant[projectile.OwnerParticipant]
	local targetSession = sessionsByParticipant[targetParticipant]

	if ownerSession == nil or targetSession == nil then
		return false, nil
	end

	local reflectConfig = getReflectShieldConfig()
	local maxReflectsPerProjectile = math.max(
		0,
		math.floor(tonumber(reflectConfig.MaxReflectsPerProjectile) or 1)
	)

	if (tonumber(projectile.ShieldReflectCount) or 0) >= maxReflectsPerProjectile then
		return false, nil
	end

	local now = getServerTimeNow()

	if (tonumber(targetSession.SpawnShieldUntil) or 0) > 0
		and (tonumber(targetSession.SpawnShieldUntil) or 0) <= now
	then
		targetSession.SpawnShieldUntil = 0
	end

	local spawnShieldActive = isSpawnShieldActive(targetSession, now)
	local shieldCharges = math.clamp(
		math.floor(tonumber(targetSession.ReflectShieldCharges) or 0),
		0,
		getReflectShieldMaxCharges()
	)

	if not spawnShieldActive and not hasReflectShieldCharge(targetSession) then
		publishShieldAttributes(targetSession, now)
		return false, nil
	end

	if spawnShieldActive then
		targetSession.SpawnShieldUntil = 0
	else
		targetSession.ReflectShieldCharges = math.max(0, shieldCharges - 1)
	end

	publishShieldAttributes(targetSession, now)

	return true, {
		Text = tostring(reflectConfig.ReflectText or "REFLECT"),
		Color = Color3.fromRGB(116, 210, 255),
		Lifetime = 0.6,
		RiseDistance = 2.2,
	}
end

function ArenaCombatService.IsArenaProjectile(projectile)
	return projectile ~= nil and sessionsByParticipant[projectile.OwnerParticipant] ~= nil
end

function ArenaCombatService.GetControlZonePosition()
	local controlZone = getArenaChild(BattleArenaConfig.ControlZoneName or "ControlZone")

	if controlZone == nil or not (controlZone:IsA("BasePart") or controlZone:IsA("Model")) then
		return nil
	end

	local cframe = getPoiBounds(controlZone)

	return cframe ~= nil and cframe.Position or nil
end

function ArenaCombatService.update(deltaTime)
	local dt = math.max(0, tonumber(deltaTime) or 0)
	local now = getServerTimeNow()

	pickupAccumulator += dt
	if pickupAccumulator >= math.max(0.05, tonumber(BattleArenaConfig.PickupCheckInterval) or 0.25) then
		pickupAccumulator = 0
		processMedkits(now)
		processSupplyCrates(now)
	end

	controlZoneAccumulator += dt
	if controlZoneAccumulator >= math.max(1, tonumber(BattleArenaConfig.ControlZoneTickInterval) or 5) then
		controlZoneAccumulator = 0
		processControlZone()
	end

	survivalAccumulator += dt
	if survivalAccumulator >= math.max(1, tonumber(BattleArenaConfig.SurvivalTickInterval) or 10) then
		survivalAccumulator = 0
		processSurvivalXP()
	end
end

function ArenaCombatService.PlayerRemoving(player)
	ArenaCombatService.LeaveArena(player)
end

return ArenaCombatService
]]></ProtectedString>
							<string name="ScriptGuid">{860d0929-3ac5-4ea6-a57d-96bfed92e8fc}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">ArenaCombatService</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">37d18a1f00558cc30a17099c0000d6fb</UniqueId>
						</Properties>
					</Item>
				</Item>
				<Item class="Folder" referent="RBX3505d577433641029dd595dfe23118d5">
					<Properties>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">Bots</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">327caba24f9a1d5d0a1a37b3000009cc</UniqueId>
					</Properties>
					<Item class="ModuleScript" referent="RBXc191f53e6ff54119bf4e69cabc842e99">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local shared = ReplicatedStorage:WaitForChild("Shared")
local configs = shared:WaitForChild("Configs")
local BotConfig = require(configs:WaitForChild("BotConfig"))
local TankConfig = require(configs:WaitForChild("TankConfig"))

local TrainingBotService = {}

local MATCH_MODE_TRAINING = "Training"
local PARTICIPANT_STATE_IN_MATCH = "InMatch"

local MOVE_SPEED = TankConfig.Movement.MoveSpeed
local REVERSE_MOVE_SPEED_MULTIPLIER = TankConfig.Movement.ReverseMoveSpeedMultiplier or 1
local BODY_TURN_SPEED = BotConfig.BodyTurnSpeedRadians or TankConfig.Movement.BodyTurnSpeedRadians
local turretConfig = TankConfig.Turret or {}
local TURRET_TURN_SPEED = BotConfig.TurretTurnSpeedRadians
	or turretConfig.TurnSpeedRadiansPerSecond
	or math.rad(turretConfig.TurnSpeedDegreesPerSecond or TankConfig.Movement.TurretTurnSpeedDegrees or 240)

local roundMatchService = nil
local tankParticipantRegistry = nil
local tankSpawnResetService = nil
local tankMovementService = nil
local projectileService = nil
local dummyParticipant = nil

local rng = Random.new()
local initialized = false
local elapsedSinceThink = 0
local elapsedSinceFireCheck = 0
local strafeDirection = 1
local nextStrafeSwitchAt = 0
local aimErrorRadians = 0
local nextAimErrorSwitchAt = 0
local nextAllowedShotAt = 0
local lastWarnTimeByKey = {}
local botDecision = {
	DesiredMoveYaw = nil,
	DesiredAimYaw = nil,
	DesiredThrottle = 0,
	DirectionToTarget = nil,
	TargetDistance = nil,
	TargetParticipant = nil,
}

local lineOfSightRaycastParams = RaycastParams.new()
lineOfSightRaycastParams.FilterType = Enum.RaycastFilterType.Include
lineOfSightRaycastParams.IgnoreWater = true

local function randomRange(minValue, maxValue)
	return minValue + rng:NextNumber() * (maxValue - minValue)
end

local function warnThrottled(key, message)
	local now = os.clock()

	if now - (lastWarnTimeByKey[key] or 0) < 3 then
		return
	end

	lastWarnTimeByKey[key] = now
	warn(message)
end

local function normalizeAngle(angle)
	local fullTurn = math.pi * 2
	return ((angle + math.pi) % fullTurn) - math.pi
end

local function shortestAngleDelta(fromAngle, toAngle)
	return normalizeAngle(toAngle - fromAngle)
end

local function moveAngleTowards(currentAngle, targetAngle, maxDelta)
	local delta = shortestAngleDelta(currentAngle, targetAngle)

	if math.abs(delta) <= maxDelta then
		return targetAngle
	end

	local direction = delta >= 0 and 1 or -1
	return currentAngle + direction * maxDelta
end

local function getYawFromFlatDirection(direction, fallbackYaw)
	local flat = Vector3.new(direction.X, 0, direction.Z)

	if flat.Magnitude < 0.001 then
		return fallbackYaw or 0
	end

	local unit = flat.Unit
	return math.atan2(-unit.X, -unit.Z)
end

local function getFlatDirection(fromPosition, toPosition)
	local delta = Vector3.new(toPosition.X - fromPosition.X, 0, toPosition.Z - fromPosition.Z)

	if delta.Magnitude < 0.001 then
		return nil, 0
	end

	return delta.Unit, delta.Magnitude
end

local function getDirectionFromYaw(yaw)
	local look = CFrame.Angles(0, yaw, 0).LookVector
	local flat = Vector3.new(look.X, 0, look.Z)

	if flat.Magnitude < 0.001 then
		return Vector3.new(0, 0, -1)
	end

	return flat.Unit
end

local function getArenaBounds()
	if BotConfig.ArenaBoundsEnabled ~= true then
		return nil
	end

	local minX = tonumber(BotConfig.ArenaMinX) or -96
	local maxX = tonumber(BotConfig.ArenaMaxX) or 96
	local minZ = tonumber(BotConfig.ArenaMinZ) or -96
	local maxZ = tonumber(BotConfig.ArenaMaxZ) or 96

	if minX > maxX then
		minX, maxX = maxX, minX
	end

	if minZ > maxZ then
		minZ, maxZ = maxZ, minZ
	end

	return {
		MinX = minX,
		MaxX = maxX,
		MinZ = minZ,
		MaxZ = maxZ,
	}
end

local function getArenaCenter(bounds)
	return Vector3.new(
		(bounds.MinX + bounds.MaxX) * 0.5,
		0,
		(bounds.MinZ + bounds.MaxZ) * 0.5
	)
end

local function clampPositionToArenaBounds(position, bounds)
	if bounds == nil then
		return position
	end

	return Vector3.new(
		math.clamp(position.X, bounds.MinX, bounds.MaxX),
		position.Y,
		math.clamp(position.Z, bounds.MinZ, bounds.MaxZ)
	)
end

local function isOutsideArenaBounds(position, bounds)
	return position.X < bounds.MinX
		or position.X > bounds.MaxX
		or position.Z < bounds.MinZ
		or position.Z > bounds.MaxZ
end

local function isNearArenaEdge(position, bounds)
	local returnToCenterDistance = math.max(0, tonumber(BotConfig.ReturnToCenterDistance) or 0)

	if isOutsideArenaBounds(position, bounds) then
		return true
	end

	if returnToCenterDistance <= 0 then
		return false
	end

	return position.X <= bounds.MinX + returnToCenterDistance
		or position.X >= bounds.MaxX - returnToCenterDistance
		or position.Z <= bounds.MinZ + returnToCenterDistance
		or position.Z >= bounds.MaxZ - returnToCenterDistance
end

local function getDirectionToArenaCenter(position, bounds, fallbackDirection)
	local center = getArenaCenter(bounds)
	local direction = getFlatDirection(position, center)

	if direction ~= nil then
		return direction
	end

	return fallbackDirection or Vector3.new(0, 0, -1)
end

local function findBasePart(model, partName)
	if model == nil then
		return nil
	end

	local directChild = model:FindFirstChild(partName)

	if directChild ~= nil and directChild:IsA("BasePart") then
		return directChild
	end

	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant.Name == partName and descendant:IsA("BasePart") then
			return descendant
		end
	end

	return nil
end

local function getParticipantModel(participant)
	if participant == nil then
		return nil
	end

	if tankParticipantRegistry ~= nil and tankParticipantRegistry.getParticipantPhysicalModel ~= nil then
		return tankParticipantRegistry.getParticipantPhysicalModel(participant)
	end

	return participant.PhysicalModel or participant.Model
end

local function getParticipantBody(participant)
	if participant == nil then
		return nil
	end

	if participant.Body ~= nil and participant.Body.Parent ~= nil then
		return participant.Body
	end

	local model = getParticipantModel(participant)
	local body = findBasePart(model, "Body")

	if body ~= nil then
		participant.Body = body
	end

	return body
end

local function getParticipantShootPoint(participant)
	if participant == nil then
		return nil
	end

	if participant.ShootPoint ~= nil and participant.ShootPoint.Parent ~= nil then
		return participant.ShootPoint
	end

	local model = getParticipantModel(participant)
	local shootPoint = findBasePart(model, "ShootPoint")

	if shootPoint ~= nil then
		participant.ShootPoint = shootPoint
	end

	return shootPoint
end

local function getParticipantPosition(participant)
	if participant == nil then
		return nil
	end

	local controlState = participant.ControlState

	if controlState ~= nil and typeof(controlState.Position) == "Vector3" then
		return controlState.Position
	end

	local body = getParticipantBody(participant)

	if body ~= nil then
		return Vector3.new(body.Position.X, 0, body.Position.Z)
	end

	local model = getParticipantModel(participant)

	if model ~= nil and model.PrimaryPart ~= nil then
		local position = model.PrimaryPart.Position
		return Vector3.new(position.X, 0, position.Z)
	end

	return nil
end

local function isParticipantDead(participant)
	if participant == nil then
		return true
	end

	if tankParticipantRegistry ~= nil and tankParticipantRegistry.getParticipantIsDead ~= nil then
		return tankParticipantRegistry.getParticipantIsDead(participant)
	end

	return participant.IsDead == true
end

local function isParticipantInList(participant, participants)
	for _, activeParticipant in ipairs(participants or {}) do
		if activeParticipant == participant then
			return true
		end
	end

	return false
end

local function getActiveTrainingTarget()
	if not initialized or BotConfig.Enabled ~= true then
		return nil
	end

	if roundMatchService == nil
		or tankParticipantRegistry == nil
		or tankSpawnResetService == nil
		or tankMovementService == nil
		or projectileService == nil
		or dummyParticipant == nil
	then
		return nil
	end

	local activeMatch = roundMatchService.getActiveMatch ~= nil and roundMatchService.getActiveMatch() or nil

	if activeMatch == nil or activeMatch.MatchMode ~= MATCH_MODE_TRAINING then
		return nil
	end

	if not isParticipantInList(dummyParticipant, activeMatch.Participants) then
		return nil
	end

	if dummyParticipant.ParticipantState ~= PARTICIPANT_STATE_IN_MATCH then
		return nil
	end

	local roundState = roundMatchService.getRoundState ~= nil and roundMatchService.getRoundState() or nil

	if roundState ~= nil and roundState.Ended == true then
		return nil
	end

	if isParticipantDead(dummyParticipant) then
		return nil
	end

	local target = roundMatchService.getOpponentForParticipant ~= nil
		and roundMatchService.getOpponentForParticipant(dummyParticipant)
		or nil

	if target == nil
		or target == dummyParticipant
		or not isParticipantInList(target, activeMatch.Participants)
		or target.ParticipantState ~= PARTICIPANT_STATE_IN_MATCH
		or isParticipantDead(target)
	then
		return nil
	end

	return target
end

local function refreshStrafeDirection(now)
	if now < nextStrafeSwitchAt then
		return
	end

	strafeDirection = rng:NextInteger(0, 1) == 0 and -1 or 1
	nextStrafeSwitchAt = now + randomRange(
		BotConfig.StrafeSwitchMinTime,
		BotConfig.StrafeSwitchMaxTime
	)
end

local function refreshAimError(now)
	if now < nextAimErrorSwitchAt then
		return
	end

	aimErrorRadians = math.rad(randomRange(-BotConfig.AimErrorDegrees, BotConfig.AimErrorDegrees))
	nextAimErrorSwitchAt = now + randomRange(0.55, 1.35)
end

local function getBotMoveDecision(distance, directionToTarget)
	local preferredDistance = BotConfig.PreferredDistance
	local minDistance = BotConfig.MinDistance
	local maxDistance = BotConfig.MaxDistance
	local moveThrottle = BotConfig.MoveThrottle
	local reverseThrottle = BotConfig.ReverseThrottle

	if distance > maxDistance or distance > preferredDistance + 8 then
		return directionToTarget, moveThrottle
	end

	if distance < minDistance or distance < preferredDistance - 10 then
		return directionToTarget, reverseThrottle
	end

	local lateral = Vector3.new(-directionToTarget.Z, 0, directionToTarget.X) * strafeDirection

	if lateral.Magnitude < 0.001 then
		lateral = Vector3.new(1, 0, 0)
	end

	return lateral.Unit, moveThrottle * 0.55
end

local function hasLineOfSight(origin, targetPosition)
	if BotConfig.LineOfSightEnabled ~= true then
		return true
	end

	if tankMovementService == nil or tankMovementService.getTankMovementObstacleParts == nil then
		return true
	end

	local obstacleParts = tankMovementService.getTankMovementObstacleParts()

	if #obstacleParts == 0 then
		return true
	end

	lineOfSightRaycastParams.FilterDescendantsInstances = obstacleParts
	local result = Workspace:Raycast(origin, targetPosition - origin, lineOfSightRaycastParams)

	return result == nil
end

local function updateBotDecision(target)
	local state = dummyParticipant.ControlState

	if state == nil or typeof(state.Position) ~= "Vector3" then
		warnThrottled("missingControlState", "[BOT] Training dummy has no ControlState; bot decision skipped.")
		return false
	end

	local targetPosition = getParticipantPosition(target)

	if targetPosition == nil then
		warnThrottled("missingTargetPosition", "[BOT] Training target has no Body/ControlState position.")
		return false
	end

	local directionToTarget, distance = getFlatDirection(state.Position, targetPosition)

	if directionToTarget == nil then
		return false
	end

	local now = os.clock()
	refreshStrafeDirection(now)
	refreshAimError(now)

	local desiredMoveDirection, throttle = getBotMoveDecision(distance, directionToTarget)
	local currentBodyYaw = state.BodyYaw or 0
	local arenaBounds = getArenaBounds()

	if arenaBounds ~= nil and isNearArenaEdge(state.Position, arenaBounds) then
		desiredMoveDirection = getDirectionToArenaCenter(state.Position, arenaBounds, desiredMoveDirection)
		throttle = math.max(0.1, math.abs(BotConfig.MoveThrottle or 0.75))
	end

	botDecision.DesiredMoveYaw = getYawFromFlatDirection(desiredMoveDirection, currentBodyYaw)
	botDecision.DesiredAimYaw = getYawFromFlatDirection(directionToTarget, state.TurretYaw or currentBodyYaw) + aimErrorRadians
	botDecision.DesiredThrottle = throttle
	botDecision.DirectionToTarget = directionToTarget
	botDecision.TargetDistance = distance
	botDecision.TargetParticipant = target

	return true
end

local function applyBotMovement(deltaTime)
	local state = dummyParticipant.ControlState

	if state == nil or typeof(state.Position) ~= "Vector3" then
		warnThrottled("missingControlState", "[BOT] Training dummy has no ControlState; bot movement skipped.")
		return false
	end

	local desiredBodyYaw = botDecision.DesiredMoveYaw
	local desiredTurretYaw = botDecision.DesiredAimYaw

	if desiredBodyYaw == nil or desiredTurretYaw == nil then
		return false
	end

	local currentBodyYaw = state.BodyYaw or desiredBodyYaw
	local resolvedBodyYaw = moveAngleTowards(currentBodyYaw, desiredBodyYaw, BODY_TURN_SPEED * deltaTime)
	local throttle = botDecision.DesiredThrottle or 0

	local moveSpeed = MOVE_SPEED * (throttle < 0 and REVERSE_MOVE_SPEED_MULTIPLIER or 1)
	local desiredMove = getDirectionFromYaw(resolvedBodyYaw) * throttle * moveSpeed * deltaTime
	local resolvedPosition = state.Position
	local arenaBounds = getArenaBounds()

	if arenaBounds ~= nil and isOutsideArenaBounds(state.Position + desiredMove, arenaBounds) then
		local returnDirection = getDirectionToArenaCenter(state.Position, arenaBounds, getDirectionFromYaw(resolvedBodyYaw))
		local returnYaw = getYawFromFlatDirection(returnDirection, resolvedBodyYaw)

		resolvedBodyYaw = moveAngleTowards(currentBodyYaw, returnYaw, BODY_TURN_SPEED * deltaTime)
		throttle = math.max(0.1, math.abs(BotConfig.MoveThrottle or 0.75))
		moveSpeed = MOVE_SPEED
		desiredMove = getDirectionFromYaw(resolvedBodyYaw) * throttle * moveSpeed * deltaTime
		botDecision.DesiredMoveYaw = returnYaw
		botDecision.DesiredThrottle = throttle
	end

	if tankMovementService.resolveTankMovement ~= nil then
		resolvedPosition = tankMovementService.resolveTankMovement(state.Position, resolvedBodyYaw, desiredMove)
	elseif tankMovementService.resolveTankPose ~= nil then
		resolvedPosition, resolvedBodyYaw = tankMovementService.resolveTankPose(
			state.Position,
			currentBodyYaw,
			desiredMove,
			resolvedBodyYaw,
			{ TankId = dummyParticipant.TankId .. ":Bot" }
		)
	end

	resolvedPosition = clampPositionToArenaBounds(resolvedPosition, arenaBounds)

	local currentTurretYaw = state.TurretYaw or resolvedBodyYaw

	state.Position = resolvedPosition
	state.BodyYaw = resolvedBodyYaw
	state.TurretYaw = moveAngleTowards(currentTurretYaw, desiredTurretYaw, TURRET_TURN_SPEED * deltaTime)

	local model = getParticipantModel(dummyParticipant)

	if model == nil then
		warnThrottled("missingDummyModel", "[BOT] Training dummy has no model; bot layout skipped.")
		return false
	end

	tankSpawnResetService.layoutTank(model, state.Position, state.BodyYaw, state.TurretYaw)

	return true
end

local function maybeShoot(deltaTime, target, directionToTarget, distance)
	elapsedSinceFireCheck += deltaTime

	if elapsedSinceFireCheck < BotConfig.FireCheckInterval then
		return
	end

	elapsedSinceFireCheck = 0

	if directionToTarget == nil or distance == nil or distance > BotConfig.MaxDistance * 1.2 then
		return
	end

	local now = os.clock()

	if now < nextAllowedShotAt then
		return
	end

	local shootPoint = getParticipantShootPoint(dummyParticipant)

	if shootPoint == nil then
		warnThrottled("missingShootPoint", "[BOT] Training dummy has no ShootPoint; bot cannot shoot.")
		return
	end

	local targetBody = getParticipantBody(target)
	local targetPosition = targetBody ~= nil and targetBody.Position or getParticipantPosition(target)

	if targetPosition == nil then
		return
	end

	local origin = shootPoint.Position
	local targetDirection = Vector3.new(targetPosition.X - origin.X, 0, targetPosition.Z - origin.Z)

	if targetDirection.Magnitude < 0.001 then
		return
	end

	if not hasLineOfSight(origin, targetPosition) then
		nextAllowedShotAt = now + randomRange(0.2, 0.55)
		return
	end

	if rng:NextNumber() > BotConfig.FireChance then
		nextAllowedShotAt = now + randomRange(0.15, 0.45)
		return
	end

	local turretDirection = getDirectionFromYaw(dummyParticipant.ControlState.TurretYaw or 0)
	local targetUnit = targetDirection.Unit
	local minDot = math.cos(math.rad(18 + BotConfig.AimErrorDegrees))

	if turretDirection:Dot(targetUnit) < minDot then
		return
	end

	local fired = projectileService.tryShoot(dummyParticipant, turretDirection)

	if fired then
		nextAllowedShotAt = now + randomRange(0.35, 1.1)
	else
		nextAllowedShotAt = now + randomRange(0.1, 0.35)
	end
end

local function resetBotDecision()
	botDecision.DesiredMoveYaw = nil
	botDecision.DesiredAimYaw = nil
	botDecision.DesiredThrottle = 0
	botDecision.DirectionToTarget = nil
	botDecision.TargetDistance = nil
	botDecision.TargetParticipant = nil
end

function TrainingBotService.init(options)
	options = options or {}

	roundMatchService = options.roundMatchService
	tankParticipantRegistry = options.tankParticipantRegistry
	tankSpawnResetService = options.tankSpawnResetService
	tankMovementService = options.tankMovementService
	projectileService = options.projectileService
	dummyParticipant = options.dummyParticipant

	initialized = true
	elapsedSinceThink = 0
	elapsedSinceFireCheck = 0
	nextStrafeSwitchAt = 0
	nextAimErrorSwitchAt = 0
	nextAllowedShotAt = 0
	resetBotDecision()
end

function TrainingBotService.update(deltaTime)
	if BotConfig.Enabled ~= true then
		resetBotDecision()
		return
	end

	local target = getActiveTrainingTarget()

	if target == nil then
		resetBotDecision()
		return
	end

	elapsedSinceThink += deltaTime

	if elapsedSinceThink >= BotConfig.ThinkInterval or botDecision.TargetParticipant ~= target then
		elapsedSinceThink = 0
		updateBotDecision(target)
	end

	applyBotMovement(deltaTime)
	maybeShoot(deltaTime, target, botDecision.DirectionToTarget, botDecision.TargetDistance)
end

return TrainingBotService
]]></ProtectedString>
							<string name="ScriptGuid">{799d3dd9-5a59-4851-99c7-494a96810d29}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">TrainingBotService</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">327caba24f9a1d5d0a1a37b3000009cd</UniqueId>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBX9e58bf785705409ababaac5ad4e140ae">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local BotTargeting = {}

local function findBasePart(model, partName)
	if model == nil then
		return nil
	end

	local directChild = model:FindFirstChild(partName)

	if directChild ~= nil and directChild:IsA("BasePart") then
		return directChild
	end

	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant.Name == partName and descendant:IsA("BasePart") then
			return descendant
		end
	end

	return nil
end

local function getParticipantModel(tankParticipantRegistry, participant)
	if participant == nil then
		return nil
	end

	if tankParticipantRegistry ~= nil and tankParticipantRegistry.getParticipantPhysicalModel ~= nil then
		return tankParticipantRegistry.getParticipantPhysicalModel(participant)
	end

	return participant.PhysicalModel or participant.Model
end

function BotTargeting.GetParticipantBody(tankParticipantRegistry, participant)
	if participant == nil then
		return nil
	end

	if participant.Body ~= nil and participant.Body.Parent ~= nil then
		return participant.Body
	end

	local model = getParticipantModel(tankParticipantRegistry, participant)
	local body = findBasePart(model, "Body") or findBasePart(model, "Hull")

	if body ~= nil then
		participant.Body = body
	end

	return body
end

function BotTargeting.GetParticipantPosition(tankParticipantRegistry, participant)
	if participant == nil then
		return nil
	end

	local controlState = participant.ControlState

	if controlState ~= nil and typeof(controlState.Position) == "Vector3" then
		return controlState.Position
	end

	local body = BotTargeting.GetParticipantBody(tankParticipantRegistry, participant)

	if body ~= nil then
		local position = body.Position
		return Vector3.new(position.X, 0, position.Z)
	end

	local model = getParticipantModel(tankParticipantRegistry, participant)

	if model ~= nil and model.PrimaryPart ~= nil then
		local position = model.PrimaryPart.Position
		return Vector3.new(position.X, 0, position.Z)
	end

	return nil
end

local function isAliveArenaTarget(tankParticipantRegistry, participant)
	if participant == nil or participant.IsActive == false then
		return false
	end

	if tankParticipantRegistry ~= nil and tankParticipantRegistry.getParticipantIsDead ~= nil then
		return tankParticipantRegistry.getParticipantIsDead(participant) ~= true
	end

	return participant.IsDead ~= true
end

local function isPlayerTarget(participant)
	return participant ~= nil and participant.OwnerPlayer ~= nil and participant.IsBot ~= true
end

local function canTarget(botParticipant, candidate, allowBotTargets)
	if candidate == nil or candidate == botParticipant then
		return false
	end

	if candidate.TeamId ~= nil and botParticipant.TeamId ~= nil and candidate.TeamId == botParticipant.TeamId then
		return false
	end

	if isPlayerTarget(candidate) then
		return true
	end

	return allowBotTargets == true and candidate.IsBot == true
end

function BotTargeting.FindClosestTarget(botParticipant, candidates, tankParticipantRegistry, options)
	options = options or {}
	local botPosition = BotTargeting.GetParticipantPosition(tankParticipantRegistry, botParticipant)

	if botPosition == nil then
		return nil, nil
	end

	local maxDistance = math.max(0, tonumber(options.SearchRadius) or 0)
	local maxDistanceSquared = maxDistance > 0 and maxDistance * maxDistance or math.huge
	local allowBotTargets = options.AllowBotTargets == true
	local bestTarget = nil
	local bestDistanceSquared = math.huge

	local function scan(allowNonPlayerBots)
		for _, candidate in ipairs(candidates or {}) do
			if canTarget(botParticipant, candidate, allowNonPlayerBots)
				and isAliveArenaTarget(tankParticipantRegistry, candidate)
			then
				local targetPosition = BotTargeting.GetParticipantPosition(tankParticipantRegistry, candidate)

				if targetPosition ~= nil then
					local delta = targetPosition - botPosition
					local distanceSquared = delta.X * delta.X + delta.Z * delta.Z

					if distanceSquared <= maxDistanceSquared and distanceSquared < bestDistanceSquared then
						bestTarget = candidate
						bestDistanceSquared = distanceSquared
					end
				end
			end
		end
	end

	scan(false)

	if bestTarget == nil and allowBotTargets then
		scan(true)
	end

	if bestTarget == nil then
		return nil, nil
	end

	return bestTarget, math.sqrt(bestDistanceSquared)
end

return BotTargeting
]]></ProtectedString>
							<string name="ScriptGuid">{09aeca39-7ad3-420b-a5d6-e6121957dc7f}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">BotTargeting</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">26a304254af295c10a1efee20000803c</UniqueId>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBX121d7f384ad54d01bb15076cbe600c34">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local BotBrain = {}

local DEFAULT_FORWARD = Vector3.new(0, 0, -1)

local function randomRange(rng, minValue, maxValue)
	return minValue + rng:NextNumber() * (maxValue - minValue)
end

local function getFlatDirection(fromPosition, toPosition)
	local delta = Vector3.new(toPosition.X - fromPosition.X, 0, toPosition.Z - fromPosition.Z)

	if delta.Magnitude < 0.001 then
		return nil, 0
	end

	return delta.Unit, delta.Magnitude
end

local function getDirectionFromYaw(yaw)
	local look = CFrame.Angles(0, yaw, 0).LookVector
	local flat = Vector3.new(look.X, 0, look.Z)

	if flat.Magnitude < 0.001 then
		return DEFAULT_FORWARD
	end

	return flat.Unit
end

local function refreshJitter(brainState, brainConfig, rng, now)
	if brainState.NextMoveJitterAt ~= nil and now < brainState.NextMoveJitterAt then
		return
	end

	brainState.StrafeDirection = rng:NextInteger(0, 1) == 0 and -1 or 1
	brainState.WanderYaw = (brainState.WanderYaw or 0) + randomRange(rng, -0.9, 0.9)
	brainState.NextMoveJitterAt = now + math.max(0.2, tonumber(brainConfig.MoveJitterInterval) or 1.25)
end

local function refreshAimJitter(brainState, brainConfig, rng, now, distance)
	if brainState.NextAimJitterAt ~= nil and now < brainState.NextAimJitterAt then
		return
	end

	local jitterDegrees = math.max(0, tonumber(brainConfig.AimJitterDegrees) or 0)
	local jitterRadius = math.tan(math.rad(jitterDegrees)) * math.max(8, tonumber(distance) or 30)
	local angle = rng:NextNumber() * math.pi * 2
	local radius = jitterRadius * math.sqrt(rng:NextNumber())

	brainState.AimJitter = Vector3.new(math.cos(angle) * radius, 0, math.sin(angle) * radius)
	brainState.NextAimJitterAt = now + math.max(0.15, tonumber(brainConfig.ReactionDelay) or 0.25)
end

local function getTargetKey(targetParticipant)
	if targetParticipant == nil then
		return ""
	end

	return tostring(targetParticipant.TankId or targetParticipant)
end

local function updateTargetReaction(brainState, brainConfig, targetParticipant, now)
	local targetKey = getTargetKey(targetParticipant)

	if brainState.TargetKey ~= targetKey then
		brainState.TargetKey = targetKey
		brainState.TargetSeenAt = now
		brainState.NextFireCheckAt = now + math.max(0, tonumber(brainConfig.ReactionDelay) or 0)
	end
end

local function shouldShootNow(brainState, brainConfig, rng, now)
	local reactionDelay = math.max(0, tonumber(brainConfig.ReactionDelay) or 0)

	if now - (brainState.TargetSeenAt or now) < reactionDelay then
		return false
	end

	if brainState.NextFireCheckAt ~= nil and now < brainState.NextFireCheckAt then
		return false
	end

	local minCooldown = math.max(0.05, tonumber(brainConfig.FireCooldownMin) or tonumber(brainConfig.FireCheckInterval) or 0.3)
	local maxCooldown = math.max(minCooldown, tonumber(brainConfig.FireCooldownMax) or minCooldown)
	brainState.NextFireCheckAt = now + randomRange(rng, minCooldown, maxCooldown)

	return rng:NextNumber() <= (tonumber(brainConfig.FireChance) or 0.55)
end

local function makeIdleDecision(botPosition, bodyYaw, brainState, brainConfig, rng, now)
	refreshJitter(brainState, brainConfig, rng, now)

	return {
		TargetParticipant = nil,
		MoveDirection = getDirectionFromYaw(brainState.WanderYaw or bodyYaw or 0),
		AimWorldPoint = botPosition + getDirectionFromYaw(bodyYaw or 0) * 40,
		Throttle = 0.18,
		WantsShoot = false,
		TargetDistance = nil,
	}
end

function BotBrain.Decide(params)
	params = params or {}
	local brainConfig = params.BrainConfig or {}
	local botPosition = params.BotPosition
	local targetPosition = params.TargetPosition
	local targetParticipant = params.TargetParticipant
	local bodyYaw = params.BodyYaw or 0
	local brainState = params.BrainState or {}
	local rng = params.Random or Random.new()
	local now = params.Now or os.clock()

	if typeof(botPosition) ~= "Vector3" then
		return nil
	end

	if typeof(targetPosition) ~= "Vector3" then
		return makeIdleDecision(botPosition, bodyYaw, brainState, brainConfig, rng, now)
	end

	refreshJitter(brainState, brainConfig, rng, now)
	updateTargetReaction(brainState, brainConfig, targetParticipant, now)

	local directionToTarget, distance = getFlatDirection(botPosition, targetPosition)

	if directionToTarget == nil then
		return makeIdleDecision(botPosition, bodyYaw, brainState, brainConfig, rng, now)
	end

	local preferredDistance = math.max(1, tonumber(brainConfig.PreferredDistance) or 45)
	local tooCloseDistance = math.max(0, tonumber(brainConfig.TooCloseDistance) or 18)
	local moveThrottle = math.clamp(tonumber(brainConfig.MoveThrottle) or 0.75, -1, 1)
	local reverseThrottle = math.clamp(tonumber(brainConfig.ReverseThrottle) or -0.55, -1, 1)
	local moveDirection = directionToTarget
	local throttle = moveThrottle

	if distance <= tooCloseDistance then
		if rng:NextNumber() <= (tonumber(brainConfig.ReverseChanceWhenTooClose) or 0.35) then
			throttle = reverseThrottle
			moveDirection = directionToTarget
		else
			local lateral = Vector3.new(-directionToTarget.Z, 0, directionToTarget.X)
				* (brainState.StrafeDirection or 1)

			moveDirection = lateral.Magnitude > 0.001 and lateral.Unit or directionToTarget
			throttle = moveThrottle * 0.45
		end
	elseif distance < preferredDistance then
		local lateral = Vector3.new(-directionToTarget.Z, 0, directionToTarget.X)
			* (brainState.StrafeDirection or 1)

		moveDirection = lateral.Magnitude > 0.001 and lateral.Unit or directionToTarget
		throttle = moveThrottle * 0.35
	elseif distance < preferredDistance + 12 then
		throttle = moveThrottle * 0.5
	end

	refreshAimJitter(brainState, brainConfig, rng, now, distance)

	local aimJitter = brainState.AimJitter
	if typeof(aimJitter) ~= "Vector3" then
		aimJitter = Vector3.zero
	end

	local wantsShoot = targetParticipant ~= nil and shouldShootNow(brainState, brainConfig, rng, now)

	return {
		TargetParticipant = targetParticipant,
		MoveDirection = moveDirection,
		AimWorldPoint = targetPosition + aimJitter,
		Throttle = throttle,
		WantsShoot = wantsShoot,
		TargetDistance = distance,
	}
end

return BotBrain
]]></ProtectedString>
							<string name="ScriptGuid">{c938e665-8143-473b-a59f-25e259d2f51a}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">BotBrain</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">26a304254af295c10a1efee20000803e</UniqueId>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBX03bd76f7ea32497ead84686968939986">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local configs = ReplicatedStorage:WaitForChild("Shared"):WaitForChild("Configs")
local BattleArenaConfig = require(configs:WaitForChild("BattleArenaConfig"))

local BotSpawnPlanner = {}
BotSpawnPlanner.__index = BotSpawnPlanner

local function getYawFromLookVector(lookVector)
	local flatLook = Vector3.new(lookVector.X, 0, lookVector.Z)

	if flatLook.Magnitude < 0.001 then
		return 0
	end

	local unit = flatLook.Unit
	return math.atan2(-unit.X, -unit.Z)
end

local function makeSpawnTransform(position, yaw, source)
	return {
		Position = position,
		BodyYaw = yaw,
		TurretYaw = yaw,
		Source = source,
	}
end

function BotSpawnPlanner.new(root)
	return setmetatable({
		Root = root,
		NextSpawnIndex = 1,
	}, BotSpawnPlanner)
end

function BotSpawnPlanner:_getArenaFolder()
	return self.Root ~= nil and self.Root:FindFirstChild("BattleArena") or nil
end

function BotSpawnPlanner:_getArenaSpawnParts()
	local arena = self:_getArenaFolder()
	local spawnFolder = arena ~= nil and arena:FindFirstChild("SpawnPoints") or nil
	local spawnParts = {}

	if spawnFolder ~= nil then
		for _, child in ipairs(spawnFolder:GetChildren()) do
			if child:IsA("BasePart") and string.match(child.Name, "^ArenaSpawn%d+$") ~= nil then
				table.insert(spawnParts, child)
			end
		end
	end

	table.sort(spawnParts, function(a, b)
		return a.Name < b.Name
	end)

	return spawnParts
end

function BotSpawnPlanner:_getFallbackTransform()
	local arena = self:_getArenaFolder()
	local arenaCenter = arena ~= nil and arena:GetAttribute("ArenaCenter") or nil
	local halfSize = arena ~= nil and arena:GetAttribute("ArenaHalfSize") or nil

	if typeof(arenaCenter) ~= "Vector3" then
		arenaCenter = BattleArenaConfig.SafeArenaCenter or Vector3.new(-340, 0, 320)
	end

	if typeof(halfSize) ~= "number" then
		halfSize = 80
	end

	local spawnCount = math.max(1, tonumber(BattleArenaConfig.SpawnPointCount) or 8)
	local index = self.NextSpawnIndex
	self.NextSpawnIndex += 1

	local angle = (math.pi * 2) * (((index - 1) % spawnCount) / spawnCount)
	local radius = math.max(30, halfSize * 0.6)
	local position = arenaCenter + Vector3.new(math.cos(angle) * radius, 0, math.sin(angle) * radius)
	local yaw = getYawFromLookVector((arenaCenter - position).Unit)

	return makeSpawnTransform(position, yaw, "ArenaBotFallback")
end

function BotSpawnPlanner:GetNextSpawnTransform()
	local spawnParts = self:_getArenaSpawnParts()

	if #spawnParts == 0 then
		return self:_getFallbackTransform()
	end

	local spawnPart = spawnParts[((self.NextSpawnIndex - 1) % #spawnParts) + 1]
	self.NextSpawnIndex += 1

	return makeSpawnTransform(
		spawnPart.Position,
		getYawFromLookVector(spawnPart.CFrame.LookVector),
		"ArenaBot:" .. spawnPart.Name
	)
end

return BotSpawnPlanner
]]></ProtectedString>
							<string name="ScriptGuid">{75aaa95c-eb62-4bec-bf88-1188f7be2da8}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">BotSpawnPlanner</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">26a304254af295c10a1efee200008040</UniqueId>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBXd3a84b6b6fbc47649aecd5cfb22ed4de">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local shared = ReplicatedStorage:WaitForChild("Shared")
local configs = shared:WaitForChild("Configs")
local BotConfig = require(configs:WaitForChild("BotConfig"))
local TankConfig = require(configs:WaitForChild("TankConfig"))

local BotBrain = require(script.Parent:WaitForChild("BotBrain"))
local BotTargeting = require(script.Parent:WaitForChild("BotTargeting"))

local BotController = {}
BotController.__index = BotController

local MOVE_SPEED = TankConfig.Movement.MoveSpeed
local REVERSE_MOVE_SPEED_MULTIPLIER = TankConfig.Movement.ReverseMoveSpeedMultiplier or 1
local BODY_TURN_SPEED = TankConfig.Movement.BodyTurnSpeedRadians
local turretConfig = TankConfig.Turret or {}
local TURRET_TURN_SPEED = turretConfig.TurnSpeedRadiansPerSecond
	or math.rad(turretConfig.TurnSpeedDegreesPerSecond or TankConfig.Movement.TurretTurnSpeedDegrees or 240)

local function normalizeAngle(angle)
	local fullTurn = math.pi * 2
	return ((angle + math.pi) % fullTurn) - math.pi
end

local function moveAngleTowards(currentAngle, targetAngle, maxDelta)
	local delta = normalizeAngle(targetAngle - currentAngle)

	if math.abs(delta) <= maxDelta then
		return targetAngle
	end

	local direction = delta >= 0 and 1 or -1
	return currentAngle + direction * maxDelta
end

local function getYawFromFlatDirection(direction, fallbackYaw)
	if typeof(direction) ~= "Vector3" then
		return fallbackYaw or 0
	end

	local flat = Vector3.new(direction.X, 0, direction.Z)

	if flat.Magnitude < 0.001 then
		return fallbackYaw or 0
	end

	local unit = flat.Unit
	return math.atan2(-unit.X, -unit.Z)
end

local function getDirectionFromYaw(yaw)
	local look = CFrame.Angles(0, yaw, 0).LookVector
	local flat = Vector3.new(look.X, 0, look.Z)

	if flat.Magnitude < 0.001 then
		return Vector3.new(0, 0, -1)
	end

	return flat.Unit
end

local function getEffectiveBrainConfig()
	local baseConfig = BotConfig.Brain or {}
	local profiles = BotConfig.DifficultyProfiles or {}
	local difficulty = BotConfig.Difficulty or "Easy"
	local profile = profiles[difficulty] or profiles.Easy or {}
	local merged = {}

	for key, value in pairs(baseConfig) do
		merged[key] = value
	end

	for key, value in pairs(profile) do
		merged[key] = value
	end

	return merged
end

local function getYawFromAimPosition(position, aimPosition, fallbackYaw)
	if typeof(position) ~= "Vector3" or typeof(aimPosition) ~= "Vector3" then
		return fallbackYaw or 0
	end

	local delta = Vector3.new(aimPosition.X - position.X, 0, aimPosition.Z - position.Z)

	if delta.Magnitude < 0.001 then
		return fallbackYaw or 0
	end

	return getYawFromFlatDirection(delta, fallbackYaw)
end

local function isDead(tankParticipantRegistry, participant)
	if participant == nil then
		return true
	end

	if tankParticipantRegistry ~= nil and tankParticipantRegistry.getParticipantIsDead ~= nil then
		return tankParticipantRegistry.getParticipantIsDead(participant)
	end

	return participant.IsDead == true
end

local function getParticipantModel(tankParticipantRegistry, participant)
	if participant == nil then
		return nil
	end

	if tankParticipantRegistry ~= nil and tankParticipantRegistry.getParticipantPhysicalModel ~= nil then
		return tankParticipantRegistry.getParticipantPhysicalModel(participant)
	end

	return participant.PhysicalModel or participant.Model
end

function BotController.new(options)
	options = options or {}

	return setmetatable({
		Participant = options.Participant,
		TankParticipantRegistry = options.TankParticipantRegistry,
		TankMovementService = options.TankMovementService,
		TankSpawnResetService = options.TankSpawnResetService,
		ProjectileService = options.ProjectileService,
		GetArenaParticipants = options.GetArenaParticipants,
		GetControlZonePosition = options.GetControlZonePosition,
		Random = Random.new(options.Seed or math.floor(os.clock() * 1000000)),
		BrainState = {},
		ThinkElapsed = 0,
		Decision = nil,
		StuckElapsed = 0,
		LastResolvedPosition = nil,
		LastDebugTargetLogAt = 0,
	}, BotController)
end

function BotController:IsAlive()
	return self.Participant ~= nil
		and self.Participant.IsActive ~= false
		and not isDead(self.TankParticipantRegistry, self.Participant)
end

function BotController:_getTarget()
	local battleArenaConfig = BotConfig.BattleArena or {}
	local brainConfig = getEffectiveBrainConfig()
	local participants = self.GetArenaParticipants ~= nil and self.GetArenaParticipants() or {}

	return BotTargeting.FindClosestTarget(self.Participant, participants, self.TankParticipantRegistry, {
		SearchRadius = brainConfig.SearchRadius,
		AllowBotTargets = battleArenaConfig.TargetBotsWhenNoPlayers == true,
	})
end

function BotController:_refreshDecision(deltaTime)
	local brainConfig = getEffectiveBrainConfig()
	self.ThinkElapsed += deltaTime

	if self.ThinkElapsed < math.max(0.05, tonumber(brainConfig.TickRate) or 0.15) and self.Decision ~= nil then
		return self.Decision
	end

	self.ThinkElapsed = 0

	local participant = self.Participant
	local state = participant.ControlState
	local botPosition = state ~= nil and state.Position or BotTargeting.GetParticipantPosition(self.TankParticipantRegistry, participant)
	local target = self:_getTarget()
	local targetPosition = BotTargeting.GetParticipantPosition(self.TankParticipantRegistry, target)

	if target == nil and self.GetControlZonePosition ~= nil then
		targetPosition = self.GetControlZonePosition()
	end

	self.Decision = BotBrain.Decide({
		BrainConfig = brainConfig,
		BotPosition = botPosition,
		TargetPosition = targetPosition,
		TargetParticipant = target,
		BodyYaw = state ~= nil and state.BodyYaw or 0,
		BrainState = self.BrainState,
		Random = self.Random,
		Now = os.clock(),
	})

	if BotConfig.Debug == true and target ~= nil then
		local now = os.clock()

		if now - self.LastDebugTargetLogAt >= 1.5 then
			self.LastDebugTargetLogAt = now
			print("[BOT] target=" .. tostring(target.TankId) .. " bot=" .. tostring(participant.TankId))
		end
	end

	return self.Decision
end

function BotController:_applyMovement(deltaTime, decision)
	local participant = self.Participant
	local state = participant.ControlState

	if state == nil or typeof(state.Position) ~= "Vector3" then
		return false
	end

	local currentBodyYaw = state.BodyYaw or 0
	local desiredBodyYaw = getYawFromFlatDirection(decision.MoveDirection, currentBodyYaw)
	local resolvedBodyYaw = moveAngleTowards(currentBodyYaw, desiredBodyYaw, BODY_TURN_SPEED * deltaTime)
	local throttle = math.clamp(tonumber(decision.Throttle) or 0, -1, 1)
	local moveSpeed = MOVE_SPEED * (throttle < 0 and REVERSE_MOVE_SPEED_MULTIPLIER or 1)
	local desiredMove = getDirectionFromYaw(resolvedBodyYaw) * throttle * moveSpeed * deltaTime
	local resolvedPosition = state.Position

	if self.TankMovementService ~= nil and self.TankMovementService.resolveTankPose ~= nil then
		resolvedPosition, resolvedBodyYaw = self.TankMovementService.resolveTankPose(
			state.Position,
			currentBodyYaw,
			desiredMove,
			resolvedBodyYaw,
			{ TankId = tostring(participant.TankId) .. ":Bot" }
		)
	end

	local movedDistance = self.LastResolvedPosition ~= nil and (resolvedPosition - self.LastResolvedPosition).Magnitude or math.huge
	local antiStuckSeconds = math.max(0, tonumber((BotConfig.Brain or {}).AntiStuckSeconds) or 0)
	local antiStuckDistance = math.max(0.01, tonumber((BotConfig.Brain or {}).AntiStuckDistance) or 0.35)

	if math.abs(throttle) > 0.1 and movedDistance < antiStuckDistance * deltaTime then
		self.StuckElapsed += deltaTime
	else
		self.StuckElapsed = 0
	end

	if antiStuckSeconds > 0 and self.StuckElapsed >= antiStuckSeconds then
		self.BrainState.NextMoveJitterAt = 0
		self.BrainState.WanderYaw = (self.BrainState.WanderYaw or resolvedBodyYaw) + self.Random:NextNumber(-1.7, 1.7)
		self.Decision = nil
		self.StuckElapsed = 0
	end

	self.LastResolvedPosition = resolvedPosition

	local currentTurretYaw = state.TurretYaw or resolvedBodyYaw
	local targetTurretYaw = getYawFromAimPosition(resolvedPosition, decision.AimWorldPoint, currentTurretYaw)

	state.Position = resolvedPosition
	state.BodyYaw = resolvedBodyYaw
	state.TurretYaw = moveAngleTowards(currentTurretYaw, targetTurretYaw, TURRET_TURN_SPEED * deltaTime)

	local model = getParticipantModel(self.TankParticipantRegistry, participant)

	if model ~= nil and self.TankSpawnResetService ~= nil then
		self.TankSpawnResetService.layoutTank(model, state.Position, state.BodyYaw, state.TurretYaw)
	end

	return true
end

function BotController:_maybeShoot(decision)
	if decision.WantsShoot ~= true or self.ProjectileService == nil then
		return false
	end

	local participant = self.Participant
	local state = participant.ControlState

	if state == nil or typeof(state.Position) ~= "Vector3" or typeof(decision.AimWorldPoint) ~= "Vector3" then
		return false
	end

	local shootPoint = participant.ShootPoint

	if shootPoint == nil or shootPoint.Parent == nil then
		return false
	end

	local toTarget = Vector3.new(
		decision.AimWorldPoint.X - shootPoint.Position.X,
		0,
		decision.AimWorldPoint.Z - shootPoint.Position.Z
	)

	if toTarget.Magnitude < 0.001 then
		return false
	end

	local turretDirection = getDirectionFromYaw(state.TurretYaw or state.BodyYaw or 0)
	local brainConfig = getEffectiveBrainConfig()
	local minDot = math.cos(math.rad(brainConfig.AimToleranceDegrees or 10))

	if turretDirection:Dot(toTarget.Unit) < minDot then
		return false
	end

	local fired = self.ProjectileService.tryShoot(participant, turretDirection)

	if BotConfig.Debug == true and fired then
		print("[BOT] shoot bot=" .. tostring(participant.TankId))
	end

	return fired
end

function BotController:Update(deltaTime)
	if not self:IsAlive() then
		return false
	end

	local decision = self:_refreshDecision(deltaTime)

	if decision == nil then
		return false
	end

	self:_applyMovement(deltaTime, decision)
	self:_maybeShoot(decision)

	return true
end

function BotController:Destroy()
	self.Participant = nil
	self.Decision = nil
	self.GetArenaParticipants = nil
end

return BotController
]]></ProtectedString>
							<string name="ScriptGuid">{1b309e9c-f31b-4288-b185-69bbbdc6b577}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">BotController</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">26a304254af295c10a1efee200008042</UniqueId>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBX8e8e370d53a54a11903278fc185bd774">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local shared = ReplicatedStorage:WaitForChild("Shared")
local configs = shared:WaitForChild("Configs")
local BotConfig = require(configs:WaitForChild("BotConfig"))
local BattleArenaLoopConfig = require(configs:WaitForChild("BattleArenaLoopConfig"))

local BotController = require(script.Parent:WaitForChild("BotController"))
local BotSpawnPlanner = require(script.Parent:WaitForChild("BotSpawnPlanner"))
local TankRole = require(script.Parent.Parent:WaitForChild("Tanks"):WaitForChild("TankRole"))
local TankStatsProfile = require(script.Parent.Parent:WaitForChild("Tanks"):WaitForChild("TankStatsProfile"))

local BotService = {}

local MODE_IN_BATTLE_ARENA = "InBattleArena"
local BOT_ID_PREFIX = "ArenaBot_"
local BOT_TEAM_ID = "Bots"

local tankFactory = nil
local tankParticipantRegistry = nil
local tankSpawnResetService = nil
local tankMovementService = nil
local projectileService = nil
local arenaCombatService = nil
local spawnPlanner = nil
local addMovementIgnoredParticipant = nil

local initialized = false
local botRecords = {}
local botRecordsById = {}
local nextBotIndex = 1
local lastDebugLogAtByKey = {}

local function debugLog(key, message)
	if BotConfig.Debug ~= true then
		return
	end

	local now = os.clock()

	if now - (lastDebugLogAtByKey[key] or 0) < 1 then
		return
	end

	lastDebugLogAtByKey[key] = now
	print(message)
end

local function isBattleArenaBotsEnabled()
	local battleArenaConfig = BotConfig.BattleArena or {}

	return BotConfig.Enabled == true and battleArenaConfig.Enabled == true
end

local function getConfiguredBotLimit()
	local battleArenaConfig = BotConfig.BattleArena or {}
	local loopBotConfig = BattleArenaLoopConfig.Enabled == true and BattleArenaLoopConfig.Bots or {}
	local safetyConfig = BotConfig.Safety or {}
	local maxBots = math.max(0, math.floor(tonumber(loopBotConfig.MaxBots) or tonumber(battleArenaConfig.MaxBots) or 0))
	local hardLimit = math.max(0, math.floor(tonumber(safetyConfig.MaxBotsHardLimit) or maxBots))

	if hardLimit <= 0 then
		return maxBots
	end

	return math.min(maxBots, hardLimit)
end

local function getDesiredBotCount()
	if not isBattleArenaBotsEnabled() or arenaCombatService == nil then
		return 0
	end

	local battleArenaConfig = BotConfig.BattleArena or {}
	local loopBotConfig = BattleArenaLoopConfig.Enabled == true and BattleArenaLoopConfig.Bots or {}
	local playerCount = arenaCombatService.GetActivePlayerCount ~= nil
		and arenaCombatService.GetActivePlayerCount()
		or 0

	if playerCount <= 0 then
		return 0
	end

	if loopBotConfig.MaintainMinBots == true then
		local minBots = playerCount <= 1
			and math.max(0, math.floor(tonumber(loopBotConfig.MinBotsSolo) or 0))
			or math.max(0, math.floor(tonumber(loopBotConfig.MinBotsWithPlayers) or 0))

		return math.min(minBots, getConfiguredBotLimit())
	end

	local spawnThreshold = math.max(1, math.floor(tonumber(battleArenaConfig.SpawnWhenPlayerCountLessThan) or 2))

	if playerCount >= spawnThreshold then
		return 0
	end

	local minBots = math.max(0, math.floor(tonumber(battleArenaConfig.MinBots) or 0))

	return math.min(minBots, getConfiguredBotLimit())
end

local function getActiveBotRecords()
	local activeRecords = {}

	for _, record in ipairs(botRecords) do
		if record.Active == true then
			table.insert(activeRecords, record)
		end
	end

	return activeRecords
end

local function makeBotTankId()
	local tankId = BOT_ID_PREFIX .. tostring(nextBotIndex)
	nextBotIndex += 1
	return tankId
end

local function getParticipantModel(participant)
	if participant == nil then
		return nil
	end

	if tankParticipantRegistry ~= nil and tankParticipantRegistry.getParticipantPhysicalModel ~= nil then
		return tankParticipantRegistry.getParticipantPhysicalModel(participant)
	end

	return participant.PhysicalModel or participant.Model
end

local function isParticipantDead(participant)
	if participant == nil then
		return true
	end

	if tankParticipantRegistry ~= nil and tankParticipantRegistry.getParticipantIsDead ~= nil then
		return tankParticipantRegistry.getParticipantIsDead(participant)
	end

	return participant.IsDead == true
end

local function registerBotInArena(participant)
	if arenaCombatService ~= nil and arenaCombatService.RegisterBotParticipant ~= nil then
		arenaCombatService.RegisterBotParticipant(participant)
	end
end

local function unregisterBotFromArena(participant)
	if arenaCombatService ~= nil and arenaCombatService.UnregisterBotParticipant ~= nil then
		arenaCombatService.UnregisterBotParticipant(participant)
	end
end

local function makeController(participant)
	return BotController.new({
		Participant = participant,
		TankParticipantRegistry = tankParticipantRegistry,
		TankMovementService = tankMovementService,
		TankSpawnResetService = tankSpawnResetService,
		ProjectileService = projectileService,
		GetArenaParticipants = function()
			if arenaCombatService ~= nil and arenaCombatService.GetActiveParticipants ~= nil then
				return arenaCombatService.GetActiveParticipants()
			end

			return {}
		end,
		GetControlZonePosition = function()
			if arenaCombatService ~= nil and arenaCombatService.GetControlZonePosition ~= nil then
				return arenaCombatService.GetControlZonePosition()
			end

			return nil
		end,
	})
end

local function activateBotRecord(record)
	local participant = record.Participant
	local spawnTransform = spawnPlanner:GetNextSpawnTransform()

	if addMovementIgnoredParticipant ~= nil then
		addMovementIgnoredParticipant(participant)
	end

	registerBotInArena(participant)
	tankParticipantRegistry.setParticipantMatchState(participant, MODE_IN_BATTLE_ARENA, nil, nil)
	tankParticipantRegistry.setParticipantModelVisible(participant, true)
	tankParticipantRegistry.resetParticipantHealth(participant)
	tankSpawnResetService.restoreTankColors(participant.TankId)
	tankSpawnResetService.applySpawnToParticipant(participant, spawnTransform)

	record.Controller = makeController(participant)
	record.Active = true
	record.RespawnAt = nil

	debugLog("spawn:" .. participant.TankId, "[BOT] spawned id=" .. tostring(participant.TankId))
end

local function createBotRecord()
	local tankId = makeBotTankId()
	local spawnTransform = spawnPlanner:GetNextSpawnTransform()
	local result = tankFactory:SpawnTank({
		TankId = tankId,
		Role = TankRole.ArenaBot,
		TeamId = BOT_TEAM_ID,
		OwnerUserId = 0,
		OwnerName = "Bot",
		IsBot = true,
		IsPlayerTank = false,
		IsActive = true,
		StatsProfileId = TankStatsProfile.BotDefault,
		SpawnTransform = spawnTransform,
		SpawnName = "ArenaBotSpawn",
	})
	local participant = result.Participant
	local model = getParticipantModel(participant)

	if model ~= nil then
		tankSpawnResetService.captureTankColors(participant.TankId, model)
	end

	local record = {
		TankId = tankId,
		Participant = participant,
		Controller = nil,
		Active = false,
		RespawnAt = nil,
	}

	table.insert(botRecords, record)
	botRecordsById[tankId] = record
	activateBotRecord(record)

	return record
end

local function deactivateBotRecord(record)
	if record == nil or record.Active ~= true then
		return
	end

	local participant = record.Participant

	if record.Controller ~= nil then
		record.Controller:Destroy()
		record.Controller = nil
	end

	unregisterBotFromArena(participant)

	if participant ~= nil then
		tankParticipantRegistry.setParticipantMatchState(participant, nil, nil, nil)
		tankParticipantRegistry.setParticipantModelVisible(participant, false)
	end

	record.Active = false
	record.RespawnAt = nil

	debugLog("despawn:" .. tostring(record.TankId), "[BOT] despawned id=" .. tostring(record.TankId))
end

local function ensureBotCount(desiredCount)
	local activeRecords = getActiveBotRecords()

	while #activeRecords < desiredCount do
		local inactiveRecord = nil

		for _, record in ipairs(botRecords) do
			if record.Active ~= true then
				inactiveRecord = record
				break
			end
		end

		if inactiveRecord ~= nil then
			activateBotRecord(inactiveRecord)
			table.insert(activeRecords, inactiveRecord)
		else
			table.insert(activeRecords, createBotRecord())
		end
	end

	for index = #activeRecords, desiredCount + 1, -1 do
		deactivateBotRecord(activeRecords[index])
	end
end

local function updateRespawn(record)
	local participant = record.Participant

	if participant == nil or not isParticipantDead(participant) then
		return false
	end

	local battleArenaConfig = BotConfig.BattleArena or {}
	local loopBotConfig = BattleArenaLoopConfig.Enabled == true and BattleArenaLoopConfig.Bots or {}
	local now = os.clock()

	if record.RespawnAt == nil then
		record.RespawnAt = now + math.max(0, tonumber(loopBotConfig.RespawnDelay) or tonumber(battleArenaConfig.RespawnDelay) or 3)
		debugLog("died:" .. tostring(record.TankId), "[BOT] died id=" .. tostring(record.TankId))
		return true
	end

	if now < record.RespawnAt then
		return true
	end

	if record.Controller ~= nil then
		record.Controller:Destroy()
	end

	activateBotRecord(record)
	debugLog("respawn:" .. tostring(record.TankId), "[BOT] respawned id=" .. tostring(record.TankId))

	return true
end

function BotService.init(options)
	options = options or {}

	tankFactory = options.TankFactory
	tankParticipantRegistry = options.TankParticipantRegistry
	tankSpawnResetService = options.TankSpawnResetService
	tankMovementService = options.TankMovementService
	projectileService = options.ProjectileService
	arenaCombatService = options.ArenaCombatService
	addMovementIgnoredParticipant = options.AddMovementIgnoredParticipant
	spawnPlanner = options.SpawnPlanner or BotSpawnPlanner.new(options.Root)
	initialized = true
end

function BotService.update(deltaTime)
	if not initialized then
		return
	end

	local desiredCount = getDesiredBotCount()
	ensureBotCount(desiredCount)

	if desiredCount <= 0 and (BotConfig.Safety or {}).CleanupOnPlayerLeave ~= false then
		return
	end

	for _, record in ipairs(getActiveBotRecords()) do
		if updateRespawn(record) then
			continue
		end

		if record.Controller ~= nil then
			record.Controller:Update(deltaTime)
		end
	end
end

function BotService.cleanupAll()
	for _, record in ipairs(botRecords) do
		deactivateBotRecord(record)
	end
end

return BotService
]]></ProtectedString>
							<string name="ScriptGuid">{962bf31a-d247-4bcd-85d8-6099655dcf6f}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">BotService</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">26a304254af295c10a1efee200008044</UniqueId>
						</Properties>
					</Item>
				</Item>
				<Item class="Folder" referent="RBXd3e5fd8e1b224822b03151fbabc58636">
					<Properties>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">Economy</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">327caba24f9a1d5d0a1a37b3000027e6</UniqueId>
					</Properties>
					<Item class="ModuleScript" referent="RBXffc4ba5c8ba44ab7a4911fbd7c9ade8c">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local DataStoreService = game:GetService("DataStoreService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local shared = ReplicatedStorage:WaitForChild("Shared")
local configs = shared:WaitForChild("Configs")
local CurrencyConfig = require(configs:WaitForChild("CurrencyConfig"))

local PlayerWalletService = {}

local STORE_NAME = "WOBPlayerWalletV1"
local KEY_PREFIX = "Player_"

local walletStore = nil
local loadedBoltsByUserId = {}
local sessionBoltsByUserId = {}
local unsavedBoltsByUserId = {}
local loadedCrystalsByUserId = {}
local sessionCrystalsByUserId = {}
local unsavedCrystalsByUserId = {}

local attributes = CurrencyConfig.Attributes
local crystalAttributes = CurrencyConfig.Crystals.Attributes

local function sanitizeCurrencyValue(value)
	local numberValue = tonumber(value)

	if numberValue == nil then
		return 0
	end

	return math.max(0, math.floor(numberValue))
end

local function sanitizeBolts(value)
	return sanitizeCurrencyValue(value)
end

local function sanitizeCrystals(value)
	return sanitizeCurrencyValue(value)
end

local function sanitizeWalletData(value)
	if typeof(value) ~= "table" then
		return {
			Bolts = 0,
			Crystals = 0,
		}
	end

	return {
		Bolts = sanitizeBolts(value.Bolts),
		Crystals = sanitizeCrystals(value.Crystals),
	}
end

local function getPlayerKey(player)
	return KEY_PREFIX .. tostring(player.UserId)
end

local function getDataStore()
	if walletStore ~= nil then
		return walletStore, nil
	end

	local success, result = pcall(function()
		return DataStoreService:GetDataStore(STORE_NAME)
	end)

	if not success then
		return nil, result
	end

	walletStore = result
	return walletStore, nil
end

local function getLoadedBolts(player)
	return loadedBoltsByUserId[player.UserId] or 0
end

local function getSessionBolts(player)
	return sessionBoltsByUserId[player.UserId] or 0
end

local function getUnsavedBolts(player)
	return unsavedBoltsByUserId[player.UserId] or 0
end

local function getVisibleBolts(player)
	return getLoadedBolts(player) + getUnsavedBolts(player)
end

local function getLoadedCrystals(player)
	return loadedCrystalsByUserId[player.UserId] or 0
end

local function getSessionCrystals(player)
	return sessionCrystalsByUserId[player.UserId] or 0
end

local function getUnsavedCrystals(player)
	return unsavedCrystalsByUserId[player.UserId] or 0
end

local function getVisibleCrystals(player)
	return getLoadedCrystals(player) + getUnsavedCrystals(player)
end

local function setWalletAttributes(player)
	if player == nil then
		return
	end

	player:SetAttribute(attributes.PersistentBalance, getVisibleBolts(player))
	player:SetAttribute(attributes.SessionEarned, getSessionBolts(player))
	player:SetAttribute(attributes.UnsavedBalance, getUnsavedBolts(player))
	player:SetAttribute(crystalAttributes.Balance, getVisibleCrystals(player))
	player:SetAttribute(crystalAttributes.PersistentBalance, getVisibleCrystals(player))
	player:SetAttribute(crystalAttributes.SessionEarned, getSessionCrystals(player))
	player:SetAttribute(crystalAttributes.UnsavedBalance, getUnsavedCrystals(player))
end

local REWARD_SEQUENCE_ATTRIBUTE = "LastBoltsRewardSequence"

local function setFallbackAttributes(player, preservedUnsavedBolts, preservedUnsavedCrystals)
	loadedBoltsByUserId[player.UserId] = 0
	sessionBoltsByUserId[player.UserId] = 0
	unsavedBoltsByUserId[player.UserId] = sanitizeBolts(preservedUnsavedBolts)
	loadedCrystalsByUserId[player.UserId] = 0
	sessionCrystalsByUserId[player.UserId] = 0
	unsavedCrystalsByUserId[player.UserId] = sanitizeCrystals(preservedUnsavedCrystals)

	setWalletAttributes(player)
	player:SetAttribute(attributes.LastRewardAmount, 0)
	player:SetAttribute(attributes.LastRewardReason, "")
	player:SetAttribute(REWARD_SEQUENCE_ATTRIBUTE, player:GetAttribute(REWARD_SEQUENCE_ATTRIBUTE) or 0)
	player:SetAttribute(crystalAttributes.LastRewardAmount, 0)
	player:SetAttribute(crystalAttributes.LastRewardReason, "")
	player:SetAttribute(crystalAttributes.LastRewardSequence, player:GetAttribute(crystalAttributes.LastRewardSequence) or 0)
	player:SetAttribute(crystalAttributes.LastRewardMatchId, "")
	player:SetAttribute("WalletLoaded", false)
	player:SetAttribute("WalletLastSaveSucceeded", false)
end

function PlayerWalletService.loadPlayer(player)
	if player == nil then
		return {
			Bolts = 0,
			Crystals = 0,
		}, false
	end

	local preservedUnsavedBolts = getUnsavedBolts(player)
	local preservedUnsavedCrystals = getUnsavedCrystals(player)

	setFallbackAttributes(player, preservedUnsavedBolts, preservedUnsavedCrystals)

	local store, storeError = getDataStore()

	if store == nil then
		warn("[WALLET] DataStore unavailable for " .. player.Name .. ": " .. tostring(storeError))
		return {
			Bolts = 0,
			Crystals = 0,
		}, false
	end

	local success, result = pcall(function()
		return store:GetAsync(getPlayerKey(player))
	end)

	if not success then
		warn("[WALLET] Failed to load wallet for " .. player.Name .. ": " .. tostring(result))
		return {
			Bolts = 0,
			Crystals = 0,
		}, false
	end

	local walletData = sanitizeWalletData(result)
	local currentSessionBolts = getSessionBolts(player)
	local currentUnsavedBolts = getUnsavedBolts(player)
	local currentSessionCrystals = getSessionCrystals(player)
	local currentUnsavedCrystals = getUnsavedCrystals(player)

	loadedBoltsByUserId[player.UserId] = walletData.Bolts
	sessionBoltsByUserId[player.UserId] = currentSessionBolts
	unsavedBoltsByUserId[player.UserId] = currentUnsavedBolts
	loadedCrystalsByUserId[player.UserId] = walletData.Crystals
	sessionCrystalsByUserId[player.UserId] = currentSessionCrystals
	unsavedCrystalsByUserId[player.UserId] = currentUnsavedCrystals

	setWalletAttributes(player)
	player:SetAttribute("WalletLoaded", true)
	player:SetAttribute("WalletLastSaveSucceeded", currentUnsavedBolts <= 0 and currentUnsavedCrystals <= 0)

	return walletData, true
end

function PlayerWalletService.addBolts(player, amount, reason)
	if player == nil then
		return false, 0
	end

	local rewardAmount = sanitizeBolts(amount)

	if rewardAmount <= 0 then
		return false, PlayerWalletService.getBoltsBalance(player)
	end

	local userId = player.UserId
	sessionBoltsByUserId[userId] = getSessionBolts(player) + rewardAmount
	unsavedBoltsByUserId[userId] = getUnsavedBolts(player) + rewardAmount

	setWalletAttributes(player)
	player:SetAttribute(attributes.LastRewardAmount, rewardAmount)
	player:SetAttribute(attributes.LastRewardReason, tostring(reason or "Reward"))
	player:SetAttribute(REWARD_SEQUENCE_ATTRIBUTE, (tonumber(player:GetAttribute(REWARD_SEQUENCE_ATTRIBUTE)) or 0) + 1)
	player:SetAttribute("WalletLastSaveSucceeded", false)

	print(
		("[WALLET] %s +%d %s reason=%s total=%d"):format(
			player.Name,
			rewardAmount,
			CurrencyConfig.DisplayName,
			tostring(reason or "Reward"),
			PlayerWalletService.getBoltsBalance(player)
		)
	)

	return true, PlayerWalletService.getBoltsBalance(player)
end

function PlayerWalletService.addCrystals(player, amount, reason)
	if player == nil then
		return false, 0
	end

	local rewardAmount = sanitizeCrystals(amount)

	if rewardAmount <= 0 then
		return false, PlayerWalletService.getCrystalsBalance(player)
	end

	local userId = player.UserId
	sessionCrystalsByUserId[userId] = getSessionCrystals(player) + rewardAmount
	unsavedCrystalsByUserId[userId] = getUnsavedCrystals(player) + rewardAmount

	setWalletAttributes(player)
	player:SetAttribute(crystalAttributes.LastRewardAmount, rewardAmount)
	player:SetAttribute(crystalAttributes.LastRewardReason, tostring(reason or "Reward"))
	player:SetAttribute(
		crystalAttributes.LastRewardSequence,
		(tonumber(player:GetAttribute(crystalAttributes.LastRewardSequence)) or 0) + 1
	)
	player:SetAttribute("WalletLastSaveSucceeded", false)

	print(
		("[WALLET] %s +%d %s reason=%s total=%d"):format(
			player.Name,
			rewardAmount,
			CurrencyConfig.Crystals.DisplayName,
			tostring(reason or "Reward"),
			PlayerWalletService.getCrystalsBalance(player)
		)
	)

	return true, PlayerWalletService.getCrystalsBalance(player)
end

function PlayerWalletService.getBoltsBalance(player)
	if player == nil then
		return 0
	end

	return getVisibleBolts(player)
end

function PlayerWalletService.getCrystalsBalance(player)
	if player == nil then
		return 0
	end

	return getVisibleCrystals(player)
end

function PlayerWalletService.savePlayer(player)
	if player == nil then
		return false
	end

	local pendingBoltsDelta = getUnsavedBolts(player)
	local pendingCrystalsDelta = getUnsavedCrystals(player)

	if pendingBoltsDelta <= 0 and pendingCrystalsDelta <= 0 then
		player:SetAttribute("WalletLastSaveSucceeded", true)
		return true
	end

	local store, storeError = getDataStore()

	if store == nil then
		warn("[WALLET] DataStore unavailable while saving " .. player.Name .. ": " .. tostring(storeError))
		player:SetAttribute("WalletLastSaveSucceeded", false)
		return false
	end

	local savedWalletData = nil
	local success, result = pcall(function()
		savedWalletData = store:UpdateAsync(getPlayerKey(player), function(oldValue)
			local walletData = sanitizeWalletData(oldValue)
			walletData.Bolts += pendingBoltsDelta
			walletData.Crystals += pendingCrystalsDelta
			return walletData
		end)
	end)

	if not success then
		warn("[WALLET] Failed to save wallet for " .. player.Name .. ": " .. tostring(result))
		player:SetAttribute("WalletLastSaveSucceeded", false)
		return false
	end

	savedWalletData = sanitizeWalletData(savedWalletData)

	local currentUnsavedBolts = getUnsavedBolts(player)
	local currentUnsavedCrystals = getUnsavedCrystals(player)
	local remainingUnsavedBolts = math.max(0, currentUnsavedBolts - pendingBoltsDelta)
	local remainingUnsavedCrystals = math.max(0, currentUnsavedCrystals - pendingCrystalsDelta)

	loadedBoltsByUserId[player.UserId] = savedWalletData.Bolts
	unsavedBoltsByUserId[player.UserId] = remainingUnsavedBolts
	loadedCrystalsByUserId[player.UserId] = savedWalletData.Crystals
	unsavedCrystalsByUserId[player.UserId] = remainingUnsavedCrystals

	setWalletAttributes(player)
	player:SetAttribute("WalletLoaded", true)
	player:SetAttribute("WalletLastSaveSucceeded", true)

	return true
end

function PlayerWalletService.removePlayer(player)
	if player == nil then
		return
	end

	if getUnsavedBolts(player) > 0 or getUnsavedCrystals(player) > 0 then
		PlayerWalletService.savePlayer(player)
	end

	if getUnsavedBolts(player) > 0 or getUnsavedCrystals(player) > 0 then
		warn("[WALLET] Keeping unsaved wallet delta in memory for " .. player.Name)
		return
	end

	loadedBoltsByUserId[player.UserId] = nil
	sessionBoltsByUserId[player.UserId] = nil
	unsavedBoltsByUserId[player.UserId] = nil
	loadedCrystalsByUserId[player.UserId] = nil
	sessionCrystalsByUserId[player.UserId] = nil
	unsavedCrystalsByUserId[player.UserId] = nil
end

return PlayerWalletService
]]></ProtectedString>
							<string name="ScriptGuid">{a5c83a9a-2728-47b6-b712-56d4e6173f97}</string>
