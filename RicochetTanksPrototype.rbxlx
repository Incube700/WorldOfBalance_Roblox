local rightAimKnobCorner = Instance.new("UICorner")
rightAimKnobCorner.CornerRadius = UDim.new(1, 0)
rightAimKnobCorner.Parent = rightAimKnob

local rightAimLabelText = Instance.new("TextLabel")
