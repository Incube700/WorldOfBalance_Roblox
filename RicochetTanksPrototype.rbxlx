				<Item class="ModuleScript" referent="RBX38d090f627ce4d4aa44f25261a0d33a2">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[-- Read-only snapshot config. Do not wire without a dedicated task.

local WeaponConfig = table.freeze({
	PrimaryWeapon = table.freeze({
