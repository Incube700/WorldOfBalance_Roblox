					</Item>
					<Item class="ModuleScript" referent="RBXed5b3471f63e4d21b587baa06b186eca">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local BattleArenaUpgradeHud = {}
BattleArenaUpgradeHud.__index = BattleArenaUpgradeHud
BattleArenaUpgradeHud._warnedMissingTemplate = false
BattleArenaUpgradeHud._warnedInvalidTemplate = false
BattleArenaUpgradeHud._warnedTemplateVisualChildren = false

local UPGRADE_ICON_SLOT_COUNT = 5

local function warnTemplateIssueOnce(flagName, message)
	if BattleArenaUpgradeHud[flagName] then
		return
	end

	BattleArenaUpgradeHud[flagName] = true
	warn(message)
end

local function addCorner(parent, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = radius
	corner.Parent = parent

	return corner
end

local function addStroke(parent, color, transparency, thickness)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color
	stroke.Transparency = transparency
	stroke.Thickness = thickness
	stroke.Parent = parent

	return stroke
end

local function makeLabel(parent, name, textSize, font, zIndex)
	local label = Instance.new("TextLabel")
	label.Name = name
	label.BackgroundTransparency = 1
	label.BorderSizePixel = 0
	label.Font = font or Enum.Font.GothamBold
	label.Text = ""
	label.TextColor3 = Color3.fromRGB(241, 255, 248)
	label.TextSize = textSize
	label.TextWrapped = false
	label.TextTruncate = Enum.TextTruncate.AtEnd
	label.TextXAlignment = Enum.TextXAlignment.Center
	label.TextYAlignment = Enum.TextYAlignment.Center
	label.ZIndex = zIndex
	label.Parent = parent

	return label
end

local function splitUpgradeIds(upgradeIds)
	local ids = {}

	if typeof(upgradeIds) ~= "string" or upgradeIds == "" then
		return ids
	end

	for id in string.gmatch(upgradeIds, "[^,]+") do
		local trimmed = string.gsub(id, "^%s*(.-)%s*$", "%1")

		if trimmed ~= "" then
			table.insert(ids, trimmed)
		end
	end

	return ids
end

local function getUpgradeIcon(upgradeId)
	if typeof(upgradeId) ~= "string" then
		return "★"
	end

	local lower = string.lower(upgradeId)

	if string.find(lower, "firerate") or string.find(lower, "fire_rate") or string.find(lower, "reload") then
		return "⚡"
	elseif string.find(lower, "damage") or string.find(lower, "heavy") then
		return "💥"
	elseif string.find(lower, "ricochet") or string.find(lower, "bounce") then
		return "🔁"
	elseif string.find(lower, "repair") or string.find(lower, "armor") or string.find(lower, "hp") or string.find(lower, "health") then
		return "🛡"
	elseif string.find(lower, "speed") or string.find(lower, "turbo") or string.find(lower, "move") then
		return "🏎"
	elseif string.find(lower, "shield") then
		return "🔵"
	elseif string.find(lower, "triple") or string.find(lower, "double") or string.find(lower, "explosion") or string.find(lower, "bigboom") then
		return "🔥"
	elseif string.find(lower, "bolt") or string.find(lower, "reward") or string.find(lower, "magnet") then
		return "🧲"
	else
		return "★"
	end
end

local function getShortUpgradeTitle(choice)
	local title = tostring(choice.Title or choice.Id or "UPG")
	title = string.upper(title)

	local replacements = {
		["FIRE RATE"] = "RELOAD",
		["FIRERATE"] = "RELOAD",
		["DAMAGE UP"] = "DAMAGE",
		["PROJECTILE DAMAGE"] = "DAMAGE",
		["RICOCHET"] = "BOUNCE",
		["REPAIR"] = "REPAIR",
		["ARMOR"] = "ARMOR",
		["SPEED"] = "SPEED",
		["TURBO"] = "TURBO",
	}

	for pattern, replacement in pairs(replacements) do
		if string.find(title, pattern) then
			return replacement
		end
	end

	if #title > 8 then
		return string.sub(title, 1, 8)
	end

	return title
end

local function getDescription(choice)
	local description = tostring(choice.Description or "")

	if description == "" then
		return tostring(choice.Id or "Run upgrade")
	end

	return description
end

local function isTextGui(instance)
	return instance ~= nil and (instance:IsA("TextLabel") or instance:IsA("TextButton") or instance:IsA("TextBox"))
end

local function isChoiceRoot(instance)
	return instance ~= nil and (instance:IsA("Frame") or instance:IsA("TextButton"))
end

function BattleArenaUpgradeHud.new(params)
	assert(typeof(params) == "table", "BattleArenaUpgradeHud.new requires params")
	assert(params.Parent ~= nil, "BattleArenaUpgradeHud.new requires params.Parent")

	local self = setmetatable({}, BattleArenaUpgradeHud)

	self._parent = params.Parent
	self._zIndex = tonumber(params.ZIndex) or 30
	self._onChoiceSelected = params.OnChoiceSelected
	self._visible = true
	self._isMobile = false
	self._viewportSize = Vector2.new(1024, 768)
	self._offer = nil
	self._activeUpgradeIds = ""
	self._shieldState = {
		Active = false,
		Charges = 0,
		SpawnShieldUntil = 0,
	}
	self._usesTemplate = false
	self._templateLayoutOwned = false
	self._templateLayouts = nil
	self._activeTemplateLayout = nil
	self._paidReflectSlot = nil

	local templateClone = self:_tryLoadTemplate()
	if templateClone ~= nil and self:_bindTemplate(templateClone) then
		self._usesTemplate = true
		self._templateLayoutOwned = true
	else
		self._usesTemplate = false
		self._templateLayoutOwned = false

		if templateClone == nil then
			warnTemplateIssueOnce(
				"_warnedMissingTemplate",
				"[WOB] BattleArenaUpgradeBeltTemplate not found in ReplicatedStorage — using scripted fallback"
			)
		end
		self:_createRoot()
		self:_createOfferPanel()
		self:_createIconStrip()
	end
	self:SetLayout({
		IsMobile = false,
		ViewportSize = self._viewportSize,
	})
	self:_render()

	return self
end

function BattleArenaUpgradeHud:_createRoot()
	local root = Instance.new("Frame")
	root.Name = "BattleArenaUpgradeHud"
	root.BackgroundTransparency = 1
	root.BorderSizePixel = 0
	root.Position = UDim2.fromScale(0, 0)
	root.Size = UDim2.fromScale(1, 1)
	root.Active = false
	root.ZIndex = self._zIndex
	root.Parent = self._parent

	self._root = root
end

function BattleArenaUpgradeHud:_createOfferPanel()
	local panel = Instance.new("Frame")
	panel.Name = "UpgradeChoiceBelt"
	panel.BackgroundColor3 = Color3.fromRGB(13, 17, 23)
	panel.BackgroundTransparency = 0.08
	panel.BorderSizePixel = 0
	panel.Visible = false
	panel.Active = false
	panel.ZIndex = self._zIndex
	panel.Parent = self._root
	addCorner(panel, UDim.new(0, 8))
	addStroke(panel, Color3.fromRGB(250, 204, 21), 0.3, 1)

	local title = makeLabel(panel, "Title", 14, Enum.Font.GothamBlack, self._zIndex + 1)
	title.Text = "LEVEL UP"
	title.TextColor3 = Color3.fromRGB(250, 204, 21)

	local subtitle = makeLabel(panel, "Subtitle", 11, Enum.Font.GothamMedium, self._zIndex + 1)
	subtitle.Text = ""
	subtitle.TextColor3 = Color3.fromRGB(178, 238, 205)

	self._offerPanel = panel
	self._title = title
	self._subtitle = subtitle
	self._choiceCards = {}

	for index = 1, 3 do
		local card = Instance.new("Frame")
		card.Name = "Choice" .. tostring(index)
		card.BackgroundColor3 = Color3.fromRGB(20, 26, 34)
		card.BackgroundTransparency = 0.06
		card.BorderSizePixel = 0
		card.Visible = false
		card.ZIndex = self._zIndex + 1
		card.Parent = panel
		addCorner(card, UDim.new(0, 7))
		addStroke(card, Color3.fromRGB(249, 115, 22), 0.42, 1)

		local icon = makeLabel(card, "Icon", 24, Enum.Font.GothamBold, self._zIndex + 2)
		icon.Text = "★"

		local name = makeLabel(card, "Name", 10, Enum.Font.GothamBold, self._zIndex + 2)
		name.Text = "UPG"
		name.TextColor3 = Color3.fromRGB(241, 255, 248)

		local effect = makeLabel(card, "Effect", 11, Enum.Font.GothamMedium, self._zIndex + 2)
		effect.Text = ""
		effect.TextColor3 = Color3.fromRGB(178, 238, 205)
		effect.TextXAlignment = Enum.TextXAlignment.Left

		local button = Instance.new("TextButton")
		button.Name = "Button"
		button.BackgroundTransparency = 1
		button.BorderSizePixel = 0
		button.Text = ""
		button.AutoButtonColor = false
		button.Active = true
		button.ZIndex = self._zIndex + 3
		button.Parent = card

		local entry = {
			Card = card,
			Icon = icon,
			Name = name,
			Effect = effect,
			Button = button,
			UpgradeId = nil,
		}

		button.Activated:Connect(function()
			if typeof(entry.UpgradeId) ~= "string" or entry.UpgradeId == "" then
				return
			end

			if self._onChoiceSelected ~= nil then
				self._onChoiceSelected(entry.UpgradeId)
			end
		end)

		table.insert(self._choiceCards, entry)
	end
end

function BattleArenaUpgradeHud:_createIconStrip()
	local strip = Instance.new("Frame")
	strip.Name = "ActiveUpgradeIconStrip"
	strip.BackgroundTransparency = 1
	strip.BorderSizePixel = 0
	strip.Visible = false
	strip.ZIndex = self._zIndex - 1
	strip.Parent = self._root

	self._iconStrip = strip
	self._iconSlots = {}

	for index = 1, UPGRADE_ICON_SLOT_COUNT do
		local slot = makeLabel(strip, "Slot" .. tostring(index), 16, Enum.Font.GothamBold, self._zIndex)
		slot.BackgroundColor3 = Color3.fromRGB(20, 28, 38)
		slot.BackgroundTransparency = 0.22
		slot.Visible = false
		addCorner(slot, UDim.new(0, 6))
		addStroke(slot, Color3.fromRGB(250, 204, 21), 0.58, 1)
		table.insert(self._iconSlots, slot)
	end

	local overflow = makeLabel(strip, "Overflow", 12, Enum.Font.GothamBold, self._zIndex)
	overflow.BackgroundColor3 = Color3.fromRGB(20, 28, 38)
	overflow.BackgroundTransparency = 0.22
	overflow.TextColor3 = Color3.fromRGB(178, 238, 205)
	overflow.Visible = false
	addCorner(overflow, UDim.new(0, 6))

	self._overflow = overflow
end

function BattleArenaUpgradeHud:_tryLoadTemplate()
	local ok, clone = pcall(function()
		local rs = game:GetService("ReplicatedStorage")
		local node = rs:FindFirstChild("Shared")
		if not node then return nil end
		node = node:FindFirstChild("Assets")
		if not node then return nil end
		node = node:FindFirstChild("UI")
		if not node then return nil end
		node = node:FindFirstChild("BattleArena")
		if not node then return nil end
		local template = node:FindFirstChild("BattleArenaUpgradeBeltTemplate")
		if not template then return nil end
		return template:Clone()
	end)
	if not ok then return nil end
	return clone
end

function BattleArenaUpgradeHud:_bindTemplate(clone)
	local visualWarnings = {}

	if clone == nil or not clone:IsA("Frame") then
		warnTemplateIssueOnce(
			"_warnedInvalidTemplate",
			"[WOB] BattleArenaUpgradeBeltTemplate is invalid (BattleArenaUpgradeBeltTemplate must be a Frame) — using scripted fallback"
		)
		return false
	end

	local function bindPaidReflectSlot(choices, layoutName)
		local card = choices:FindFirstChild("PaidReflectChoice") or choices:FindFirstChild("Choice4")

		if card == nil then
			return nil
		end

		if not isChoiceRoot(card) then
			table.insert(visualWarnings, layoutName .. ".PaidReflectChoice is not a Frame or TextButton")
			return nil
		end

		local button = card:FindFirstChild("Button")

		if button ~= nil and not button:IsA("TextButton") then
			table.insert(visualWarnings, layoutName .. ".PaidReflectChoice.Button is not a TextButton")
			button = nil
		elseif button == nil and card:IsA("TextButton") then
			button = card
		end

		local icon = card:FindFirstChild("Icon")
		local title = card:FindFirstChild("Title")
		local costLabel = card:FindFirstChild("CostLabel")

		if icon ~= nil and not isTextGui(icon) then
			table.insert(visualWarnings, layoutName .. ".PaidReflectChoice.Icon is not text")
			icon = nil
		end

		if title ~= nil and not isTextGui(title) then
			table.insert(visualWarnings, layoutName .. ".PaidReflectChoice.Title is not text")
			title = nil
		end

		if costLabel ~= nil and not isTextGui(costLabel) then
			table.insert(visualWarnings, layoutName .. ".PaidReflectChoice.CostLabel is not text")
			costLabel = nil
		end

		if icon ~= nil then
			icon.Text = "🛡"
		end

		if title ~= nil then
			title.Text = "REFLECT"
		end

		if costLabel ~= nil then
			costLabel.Text = "10"
		end

		card.Visible = false
		card:SetAttribute("UpgradeId", nil)

		if button ~= nil then
			button.Active = false
			button:SetAttribute("UpgradeId", nil)
		end

		return {
			Card = card,
			Button = button,
			Icon = icon,
			Title = title,
			CostLabel = costLabel,
		}
	end

	local function bindTemplateLayout(layoutRoot, layoutName)
		local invalidReasons = {}
		local templateChoices = {}
		local iconSlots = {}
		local belt = layoutRoot ~= nil and layoutRoot:FindFirstChild("UpgradeChoiceBelt") or nil

		if layoutRoot == nil or not layoutRoot:IsA("GuiObject") then
			table.insert(invalidReasons, layoutName .. " layout root must be a GuiObject")
		end

		if belt == nil or not belt:IsA("Frame") then
			table.insert(invalidReasons, layoutName .. " missing Frame UpgradeChoiceBelt")
		end

		local choices = belt ~= nil and belt:FindFirstChild("Choices") or nil
		if choices == nil or not choices:IsA("Frame") then
			table.insert(invalidReasons, layoutName .. " missing Frame UpgradeChoiceBelt.Choices")
		end

		local iconStrip = layoutRoot ~= nil and layoutRoot:FindFirstChild("ActiveIcons") or nil
		if iconStrip == nil or not iconStrip:IsA("Frame") then
			table.insert(invalidReasons, layoutName .. " missing Frame ActiveIcons")
		end

		local title = belt ~= nil and belt:FindFirstChild("TitleLabel") or nil
		if not isTextGui(title) then
			table.insert(visualWarnings, layoutName .. ".UpgradeChoiceBelt.TitleLabel is missing or not text")
			title = nil
		end

		local subtitle = belt ~= nil and belt:FindFirstChild("Subtitle") or nil
		if not isTextGui(subtitle) then
			table.insert(visualWarnings, layoutName .. ".UpgradeChoiceBelt.Subtitle is missing or not text")
			subtitle = nil
		end

		if choices ~= nil and choices:IsA("Frame") then
			for index = 1, 3 do
				local choiceName = "Choice" .. tostring(index)
				local card = choices:FindFirstChild(choiceName)

				if not isChoiceRoot(card) then
					table.insert(invalidReasons, layoutName .. " missing Frame or TextButton UpgradeChoiceBelt.Choices." .. choiceName)
				else
					local button = nil
					local templateButton = card:FindFirstChild("Button")

					if templateButton ~= nil then
						if templateButton:IsA("TextButton") then
							button = templateButton
						else
							table.insert(visualWarnings, layoutName .. ".UpgradeChoiceBelt.Choices." .. choiceName .. ".Button is not a TextButton")
						end
					end

					if button == nil and card:IsA("TextButton") then
						button = card
					end

					if button == nil then
						table.insert(invalidReasons, layoutName .. " missing clickable Button for UpgradeChoiceBelt.Choices." .. choiceName)
					end

					local icon = card:FindFirstChild("Icon")
					if not isTextGui(icon) then
						table.insert(visualWarnings, layoutName .. ".UpgradeChoiceBelt.Choices." .. choiceName .. ".Icon is missing or not text")
						icon = nil
					end

					local name = card:FindFirstChild("Title")
					if not isTextGui(name) then
						table.insert(visualWarnings, layoutName .. ".UpgradeChoiceBelt.Choices." .. choiceName .. ".Title is missing or not text")
						name = nil
					end

					local effect = card:FindFirstChild("Effect")
					if effect ~= nil and not isTextGui(effect) then
						table.insert(visualWarnings, layoutName .. ".UpgradeChoiceBelt.Choices." .. choiceName .. ".Effect is not text")
						effect = nil
					end

					table.insert(templateChoices, {
						Card = card,
						Icon = icon,
						Name = name,
						Effect = effect,
						Button = button,
						UpgradeId = nil,
					})
				end
			end
		end

		if iconStrip ~= nil and iconStrip:IsA("Frame") then
			for index = 1, UPGRADE_ICON_SLOT_COUNT do
				local slotName = "Slot" .. tostring(index)
				local slot = iconStrip:FindFirstChild(slotName)

				if isTextGui(slot) then
					table.insert(iconSlots, slot)
				else
					table.insert(visualWarnings, layoutName .. ".ActiveIcons." .. slotName .. " is missing or not text")
				end
			end
		end

		local overflow = iconStrip ~= nil and iconStrip:FindFirstChild("Overflow") or nil
		if not isTextGui(overflow) then
			table.insert(visualWarnings, layoutName .. ".ActiveIcons.Overflow is missing or not text")
			overflow = nil
		end

		if #invalidReasons > 0 then
			return nil, invalidReasons
		end

		return {
			Root = layoutRoot,
			OfferPanel = belt,
			Title = title,
			Subtitle = subtitle,
			ChoiceCards = templateChoices,
			IconStrip = iconStrip,
			IconSlots = iconSlots,
			Overflow = overflow,
			PaidReflectSlot = choices ~= nil and bindPaidReflectSlot(choices, layoutName) or nil,
		}, nil
	end

	local desktopRoot = clone:FindFirstChild("DesktopLayout")
	local mobileRoot = clone:FindFirstChild("MobileLayout")
	local templateLayouts = nil
	local invalidReasons = {}

	if desktopRoot ~= nil or mobileRoot ~= nil then
		local desktopLayout, desktopInvalidReasons = bindTemplateLayout(desktopRoot, "DesktopLayout")
		local mobileLayout, mobileInvalidReasons = bindTemplateLayout(mobileRoot, "MobileLayout")

		if desktopLayout ~= nil and mobileLayout ~= nil then
			templateLayouts = {
				Desktop = desktopLayout,
				Mobile = mobileLayout,
			}
		else
			if desktopInvalidReasons ~= nil then
				for _, reason in ipairs(desktopInvalidReasons) do
					table.insert(invalidReasons, reason)
				end
			end

			if mobileInvalidReasons ~= nil then
				for _, reason in ipairs(mobileInvalidReasons) do
					table.insert(invalidReasons, reason)
				end
			end
		end
	else
		local defaultLayout, defaultInvalidReasons = bindTemplateLayout(clone, "DefaultLayout")

		if defaultLayout ~= nil then
			templateLayouts = {
				Desktop = defaultLayout,
				Mobile = defaultLayout,
			}
		elseif defaultInvalidReasons ~= nil then
			for _, reason in ipairs(defaultInvalidReasons) do
				table.insert(invalidReasons, reason)
			end
		end
	end

	if #invalidReasons > 0 or templateLayouts == nil then
		warnTemplateIssueOnce(
			"_warnedInvalidTemplate",
			"[WOB] BattleArenaUpgradeBeltTemplate is invalid (" .. table.concat(invalidReasons, "; ") .. ") — using scripted fallback"
		)
		clone:Destroy()
		return false
	end

	if #visualWarnings > 0 then
		warnTemplateIssueOnce(
			"_warnedTemplateVisualChildren",
			"[WOB] BattleArenaUpgradeBeltTemplate has missing optional visual children: "
				.. table.concat(visualWarnings, "; ")
		)
	end

	clone.Parent = self._parent
	self._root = clone
	self._templateLayouts = templateLayouts

	local connectedLayouts = {}

	for _, layoutState in pairs(templateLayouts) do
		if connectedLayouts[layoutState] then
			continue
		end

		connectedLayouts[layoutState] = true
		layoutState.Root.Visible = false

		for index = 1, 3 do
			local entry = layoutState.ChoiceCards[index]

			entry.Button.Activated:Connect(function()
				if typeof(entry.UpgradeId) ~= "string" or entry.UpgradeId == "" then
					return
				end
				if self._onChoiceSelected ~= nil then
					self._onChoiceSelected(entry.UpgradeId)
				end
			end)
		end
	end

	self:_selectTemplateLayout(templateLayouts.Desktop)

	return true
end

function BattleArenaUpgradeHud:SetVisible(isVisible)
	self._visible = isVisible == true
	self:_render()
end

function BattleArenaUpgradeHud:SetLayout(layout)
	layout = layout or {}
	self._isMobile = layout.IsMobile == true
	self._viewportSize = layout.ViewportSize or self._viewportSize

	self:_applyLayout()
	self:_render()
end

function BattleArenaUpgradeHud:SetOffer(offer)
	self._offer = offer
	self:_render()
end

function BattleArenaUpgradeHud:SetActiveUpgradeIds(upgradeIds)
	self._activeUpgradeIds = typeof(upgradeIds) == "string" and upgradeIds or ""
	self:_render()
end

function BattleArenaUpgradeHud:SetShieldState(shieldState)
	shieldState = typeof(shieldState) == "table" and shieldState or {}
	self._shieldState = {
		Active = shieldState.Active == true,
		Charges = math.max(0, math.floor(tonumber(shieldState.Charges) or 0)),
		SpawnShieldUntil = math.max(0, tonumber(shieldState.SpawnShieldUntil) or 0),
	}
	self:_render()
end

function BattleArenaUpgradeHud:Destroy()
	if self._root ~= nil then
		self._root:Destroy()
		self._root = nil
	end
end

function BattleArenaUpgradeHud:_applyLayout()
	if self._usesTemplate then
		self:_applyTemplateLayoutState()
		return
	end

	if self._isMobile then
		self:_applyMobileLayout()
	else
		self:_applyDesktopLayout()
	end
end

function BattleArenaUpgradeHud:_selectTemplateLayout(layoutState)
	if layoutState == nil then
		return
	end

	self._activeTemplateLayout = layoutState
	self._offerPanel = layoutState.OfferPanel
	self._title = layoutState.Title
	self._subtitle = layoutState.Subtitle
	self._choiceCards = layoutState.ChoiceCards
	self._iconStrip = layoutState.IconStrip
	self._iconSlots = layoutState.IconSlots
	self._overflow = layoutState.Overflow
	self._paidReflectSlot = layoutState.PaidReflectSlot

	local seenLayouts = {}

	for _, candidateLayout in pairs(self._templateLayouts or {}) do
		if not seenLayouts[candidateLayout] then
			seenLayouts[candidateLayout] = true
			candidateLayout.Root.Visible = candidateLayout == layoutState
		end
	end
end

function BattleArenaUpgradeHud:_applyTemplateLayoutState()
	if self._root ~= nil then
		self._root:SetAttribute("IsMobileLayout", self._isMobile)
	end

	if self._templateLayouts ~= nil then
		local layoutState = self._isMobile and self._templateLayouts.Mobile or self._templateLayouts.Desktop
		self:_selectTemplateLayout(layoutState)
	end
end

function BattleArenaUpgradeHud:_applyMobileLayout()
	local viewportSize = self._viewportSize
	local panelWidth = math.clamp(math.floor(viewportSize.X * 0.56), 196, 248)
	local panelHeight = 90
	local buttonGap = 6
	local buttonSize = math.floor((panelWidth - 24 - buttonGap * 2) / 3)
	buttonSize = math.clamp(buttonSize, 50, 66)
	local rowWidth = buttonSize * 3 + buttonGap * 2
	local rowX = math.floor((panelWidth - rowWidth) * 0.5)

	self._offerPanel.AnchorPoint = Vector2.new(0.5, 1)
	self._offerPanel.Position = UDim2.new(0.5, 0, 1, -104)
	self._offerPanel.Size = UDim2.fromOffset(panelWidth, panelHeight)

	self._title.Position = UDim2.fromOffset(8, 4)
	self._title.Size = UDim2.new(1, -16, 0, 18)
	self._title.TextSize = 13

	self._subtitle.Visible = false

	for index, entry in ipairs(self._choiceCards) do
		local x = rowX + (index - 1) * (buttonSize + buttonGap)
		entry.Card.Position = UDim2.fromOffset(x, 24)
		entry.Card.Size = UDim2.fromOffset(buttonSize, buttonSize)
		entry.Icon.Position = UDim2.fromOffset(0, 4)
		entry.Icon.Size = UDim2.new(1, 0, 0, math.floor(buttonSize * 0.56))
		entry.Icon.TextSize = math.floor(buttonSize * 0.42)

		entry.Name.Position = UDim2.new(0, 3, 1, -20)
		entry.Name.Size = UDim2.new(1, -6, 0, 17)
		entry.Name.TextSize = math.max(8, math.floor(buttonSize * 0.16))
		entry.Name.TextXAlignment = Enum.TextXAlignment.Center

		entry.Effect.Visible = false
		entry.Button.Position = UDim2.fromScale(0, 0)
		entry.Button.Size = UDim2.fromScale(1, 1)
	end

	self:_layoutIconStrip({
		AnchorPoint = Vector2.new(0.5, 1),
		Position = UDim2.new(0.5, 0, 1, -96),
		SlotSize = 32,
		Gap = 4,
	})
end

function BattleArenaUpgradeHud:_applyDesktopLayout()
	local panelWidth = 380
	local panelHeight = 260
	local cardHeight = 58
	local cardGap = 6

	self._offerPanel.AnchorPoint = Vector2.new(0.5, 0)
	self._offerPanel.Position = UDim2.new(0.5, 0, 0, 106)
	self._offerPanel.Size = UDim2.fromOffset(panelWidth, panelHeight)

	self._title.Position = UDim2.fromOffset(14, 10)
	self._title.Size = UDim2.new(1, -28, 0, 26)
	self._title.TextSize = 16

	self._subtitle.Visible = true
	self._subtitle.Position = UDim2.fromOffset(14, 36)
	self._subtitle.Size = UDim2.new(1, -28, 0, 20)
	self._subtitle.TextSize = 12

	for index, entry in ipairs(self._choiceCards) do
		local y = 62 + (index - 1) * (cardHeight + cardGap)
		entry.Card.Position = UDim2.fromOffset(14, y)
		entry.Card.Size = UDim2.fromOffset(panelWidth - 28, cardHeight)

		entry.Icon.Position = UDim2.fromOffset(0, 0)
		entry.Icon.Size = UDim2.fromOffset(50, cardHeight)
		entry.Icon.TextSize = 22

		entry.Name.Position = UDim2.fromOffset(54, 4)
		entry.Name.Size = UDim2.new(1, -58, 0, 26)
		entry.Name.TextSize = 14
		entry.Name.TextXAlignment = Enum.TextXAlignment.Left

		entry.Effect.Visible = true
		entry.Effect.Position = UDim2.fromOffset(54, 30)
		entry.Effect.Size = UDim2.new(1, -58, 0, 22)
		entry.Effect.TextSize = 11

		entry.Button.Position = UDim2.fromScale(0, 0)
		entry.Button.Size = UDim2.fromScale(1, 1)
	end

	self:_layoutIconStrip({
		AnchorPoint = Vector2.new(1, 0),
		Position = UDim2.new(1, -22, 0, 182),
		SlotSize = 30,
		Gap = 4,
	})
end

function BattleArenaUpgradeHud:_layoutIconStrip(config)
	if self._templateLayoutOwned then
		return
	end

	if self._iconStrip == nil or self._overflow == nil then
		return
	end

	local slotSize = config.SlotSize
	local gap = config.Gap
	local stripWidth = UPGRADE_ICON_SLOT_COUNT * slotSize + (UPGRADE_ICON_SLOT_COUNT - 1) * gap
	local overflowWidth = math.floor(slotSize * 1.25)

	self._iconStrip.AnchorPoint = config.AnchorPoint
	self._iconStrip.Position = config.Position
	self._iconStrip.Size = UDim2.fromOffset(stripWidth + gap + overflowWidth, slotSize)

	for index, slot in ipairs(self._iconSlots) do
		slot.Position = UDim2.fromOffset((index - 1) * (slotSize + gap), 0)
		slot.Size = UDim2.fromOffset(slotSize, slotSize)
		slot.TextSize = math.max(12, math.floor(slotSize * 0.52))
	end

	self._overflow.Position = UDim2.fromOffset(UPGRADE_ICON_SLOT_COUNT * (slotSize + gap), 0)
	self._overflow.Size = UDim2.fromOffset(overflowWidth, slotSize)
	self._overflow.TextSize = math.max(10, math.floor(slotSize * 0.38))
end

function BattleArenaUpgradeHud:_hasOffer()
	local offer = self._offer
	local choices = offer ~= nil and offer.Choices or {}

	return offer ~= nil and #choices > 0
end

function BattleArenaUpgradeHud:_render()
	if self._root == nil then
		return
	end

	local hasOffer = self._visible and self:_hasOffer()

	self._root.Visible = self._visible
	self._offerPanel.Visible = hasOffer
	self._offerPanel.Active = hasOffer
	self:_renderPaidReflectSlot()

	if hasOffer then
		self:_renderOffer()
		self._iconStrip.Visible = false
	else
		self:_renderIconStrip()
	end
end

function BattleArenaUpgradeHud:_renderPaidReflectSlot()
	local slot = self._paidReflectSlot

	if slot == nil then
		return
	end

	slot.Card.Visible = false
	slot.Card:SetAttribute("UpgradeId", nil)

	if slot.Button ~= nil then
		slot.Button.Active = false
		slot.Button:SetAttribute("UpgradeId", nil)
	end

	if slot.Icon ~= nil then
		slot.Icon.Text = "🛡"
	end

	if slot.Title ~= nil then
		slot.Title.Text = "REFLECT"
	end

	if slot.CostLabel ~= nil then
		slot.CostLabel.Text = "10"
	end
end

function BattleArenaUpgradeHud:_renderOffer()
	local offer = self._offer
	local choices = offer.Choices or {}
	local source = tostring(offer.Source or "LevelUp")
	local arenaLevel = tonumber(offer.ArenaLevel) or 1

	if self._title ~= nil then
		self._title.Text = source == "SupplyCrate" and "SUPPLY" or "LEVEL UP"
	end

	if self._subtitle ~= nil then
		self._subtitle.Text = "Arena Level " .. tostring(math.floor(arenaLevel)) .. " upgrade"
	end

	for index, entry in ipairs(self._choiceCards) do
		local choice = choices[index]

		if choice ~= nil then
			local choiceId = tostring(choice.Id or "")
			entry.UpgradeId = choiceId
			entry.Card.Visible = true
			entry.Card:SetAttribute("UpgradeId", choiceId)
			entry.Button.Active = true
			entry.Button:SetAttribute("UpgradeId", choiceId)

			if entry.Icon ~= nil then
				entry.Icon.Text = getUpgradeIcon(choiceId)
			end

			if entry.Name ~= nil then
				entry.Name.Text = self._isMobile and getShortUpgradeTitle(choice) or tostring(choice.Title or choice.Id or "Upgrade")
			end

			if entry.Effect ~= nil then
				entry.Effect.Text = getDescription(choice)
			end
		else
			entry.UpgradeId = nil
			entry.Card.Visible = false
			entry.Card:SetAttribute("UpgradeId", nil)
			entry.Button.Active = false
			entry.Button:SetAttribute("UpgradeId", nil)

			if entry.Name ~= nil then
				entry.Name.Text = ""
			end

			if entry.Effect ~= nil then
				entry.Effect.Text = ""
			end
		end
	end
end

function BattleArenaUpgradeHud:_renderIconStrip()
	local ids = splitUpgradeIds(self._activeUpgradeIds)
	local displayIds = {}
	local hasShieldIcon = false

	for _, upgradeId in ipairs(ids) do
		if upgradeId == "ReflectShield" then
			hasShieldIcon = true
		else
			table.insert(displayIds, upgradeId)
		end
	end

	if self._shieldState.Active == true then
		if hasShieldIcon then
			table.insert(displayIds, "ReflectShield")
		else
			table.insert(displayIds, 1, "ReflectShield")
		end
	end

	local visible = self._visible and #displayIds > 0

	self._iconStrip.Visible = visible

	if not visible then
		for _, slot in ipairs(self._iconSlots) do
			slot.Visible = false
		end

		if self._overflow ~= nil then
			self._overflow.Visible = false
		end

		return
	end

	local displayCount = math.min(#displayIds, UPGRADE_ICON_SLOT_COUNT)
	local overflow = #displayIds - displayCount

	for index, slot in ipairs(self._iconSlots) do
		if index <= displayCount then
			slot.Text = getUpgradeIcon(displayIds[index])
			slot.Visible = true
		else
			slot.Visible = false
		end
	end

	if overflow > 0 then
		if self._overflow ~= nil then
			self._overflow.Text = "+" .. tostring(overflow)
			self._overflow.Visible = true
		end
	elseif self._overflow ~= nil then
		self._overflow.Visible = false
	end
end

return BattleArenaUpgradeHud
]]></ProtectedString>
							<string name="ScriptGuid">{579407a9-8850-483f-bd9f-f92f0a0c6908}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">BattleArenaUpgradeHud</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">2580cdd9915f79820a23b1a20000325e</UniqueId>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBXfaaef5e5f2864ef2a043b6d43b20476a">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[-- HudWidgetFactory
--
-- Reusable, display-only HUD UI primitives (corner, stroke, panel, label, bar,
-- button). These were previously duplicated as local helpers inside the overlay
-- scripts (WOBBattleArenaOverlay, WOBDuelHudOverlay, ...). This module owns the
-- construction of Instances only.
--
-- Rules:
-- - It must NOT own gameplay decisions, attribute reads, remotes, or visibility
--   logic. Those stay in the presenter/overlay and in HudVisibilityRules.
-- - Defaults reproduce the exact values the BattleArena overlay used so callers
--   can migrate without any visual change. Callers may override any value.
--
-- API:
--   addCorner(parent, radius)                       -> UICorner
--   addStroke(parent, color, transparency, thickness) -> UIStroke
--   createPanel(options)                            -> Frame
--   createLabel(options)                            -> TextLabel
--   createBar(options)                              -> fill: Frame, back: Frame
--   styleButton(button, text)                       -> button (styles in place)
--   createButton(options)                           -> TextButton

local HudWidgetFactory = {}

local DEFAULT_PANEL_COLOR = Color3.fromRGB(13, 17, 23)
local DEFAULT_PANEL_TRANSPARENCY = 0.1
local DEFAULT_PANEL_CORNER = UDim.new(0, 8)
local DEFAULT_STROKE_COLOR = Color3.fromRGB(31, 41, 55)
local DEFAULT_STROKE_TRANSPARENCY = 0.25
local DEFAULT_STROKE_THICKNESS = 1

local DEFAULT_LABEL_COLOR = Color3.fromRGB(241, 255, 248)
local DEFAULT_LABEL_FONT = Enum.Font.GothamBold

local DEFAULT_BAR_BACK_COLOR = Color3.fromRGB(35, 42, 45)
local DEFAULT_BAR_CORNER = UDim.new(0, 4)

local DEFAULT_BUTTON_COLOR = Color3.fromRGB(250, 204, 21)
local DEFAULT_BUTTON_TEXT_COLOR = Color3.fromRGB(13, 17, 23)
local DEFAULT_BUTTON_STROKE_COLOR = Color3.fromRGB(249, 115, 22)
local DEFAULT_BUTTON_TEXT = "Return to Lobby"

-- Computes the ZIndex a child should receive: one above its parent when the
-- parent is a GuiObject, otherwise the supplied fallback. Mirrors the original
-- inline logic in the overlay scripts.
local function resolveChildZIndex(parent, fallbackZIndex)
	if typeof(parent) == "Instance" and parent:IsA("GuiObject") then
		return parent.ZIndex + 1
	end

	return fallbackZIndex or 1
end

function HudWidgetFactory.addCorner(parent, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = radius
	corner.Parent = parent

	return corner
end

function HudWidgetFactory.addStroke(parent, color, transparency, thickness)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color
	stroke.Transparency = transparency
	stroke.Thickness = thickness
	stroke.Parent = parent

	return stroke
end

-- options:
--   Name, Parent, Position, Size            (positioning)
--   ZIndex                                  (defaults 10)
--   BackgroundColor3, BackgroundTransparency
--   CornerRadius                            (UDim; nil disables corner)
--   StrokeColor, StrokeTransparency, StrokeThickness (nil StrokeColor disables stroke)
function HudWidgetFactory.createPanel(options)
	options = options or {}

	local panel = Instance.new("Frame")
	panel.Name = options.Name or "Panel"

	if options.Position ~= nil then
		panel.Position = options.Position
	end

	if options.Size ~= nil then
		panel.Size = options.Size
	end

	if options.AnchorPoint ~= nil then
		panel.AnchorPoint = options.AnchorPoint
	end

	panel.BackgroundColor3 = options.BackgroundColor3 or DEFAULT_PANEL_COLOR
	panel.BackgroundTransparency = options.BackgroundTransparency ~= nil
		and options.BackgroundTransparency
		or DEFAULT_PANEL_TRANSPARENCY
	panel.BorderSizePixel = 0
	panel.ZIndex = options.ZIndex or 10

	local cornerRadius = options.CornerRadius
	if cornerRadius == nil then
		cornerRadius = DEFAULT_PANEL_CORNER
	end
	if cornerRadius ~= false then
		HudWidgetFactory.addCorner(panel, cornerRadius)
	end

	local strokeColor = options.StrokeColor
	if strokeColor == nil then
		strokeColor = DEFAULT_STROKE_COLOR
	end
	if strokeColor ~= false then
		HudWidgetFactory.addStroke(
			panel,
			strokeColor,
			options.StrokeTransparency ~= nil and options.StrokeTransparency or DEFAULT_STROKE_TRANSPARENCY,
			options.StrokeThickness or DEFAULT_STROKE_THICKNESS
		)
	end

	if options.Parent ~= nil then
		panel.Parent = options.Parent
	end

	return panel
end

-- options:
--   Parent, Name, Position, Size, TextSize
--   Font                (defaults GothamBold)
--   TextColor3          (defaults 241,255,248)
--   Text                (defaults "")
--   TextWrapped         (defaults true)
--   TextTruncate        (defaults AtEnd)
--   TextXAlignment      (defaults Left)
--   TextYAlignment      (defaults Center)
--   FallbackZIndex      (used when Parent is not a GuiObject)
function HudWidgetFactory.createLabel(options)
	options = options or {}

	local label = Instance.new("TextLabel")
	label.Name = options.Name or "Label"

	if options.Position ~= nil then
		label.Position = options.Position
	end

	if options.Size ~= nil then
		label.Size = options.Size
	end

	label.BackgroundTransparency = 1
	label.BorderSizePixel = 0
	label.Font = options.Font or DEFAULT_LABEL_FONT
	label.Text = options.Text or ""
	label.TextColor3 = options.TextColor3 or DEFAULT_LABEL_COLOR
	label.TextSize = options.TextSize
	if options.TextWrapped ~= nil then
		label.TextWrapped = options.TextWrapped
	else
		label.TextWrapped = true
	end
	label.TextTruncate = options.TextTruncate or Enum.TextTruncate.AtEnd
	label.TextXAlignment = options.TextXAlignment or Enum.TextXAlignment.Left
	label.TextYAlignment = options.TextYAlignment or Enum.TextYAlignment.Center
	label.ZIndex = resolveChildZIndex(options.Parent, options.FallbackZIndex or 11)

	if options.Parent ~= nil then
		label.Parent = options.Parent
	end

	return label
end

-- options:
--   Parent, Name, Position, Size, FillColor
--   BackColor           (defaults 35,42,45)
--   CornerRadius        (UDim; defaults UDim.new(0, 4))
--   FallbackZIndex      (used when Parent is not a GuiObject)
-- Returns: fill, back
function HudWidgetFactory.createBar(options)
	options = options or {}

	local name = options.Name or "Bar"
	local cornerRadius = options.CornerRadius
	if cornerRadius == nil then
		cornerRadius = DEFAULT_BAR_CORNER
	end

	local back = Instance.new("Frame")
	back.Name = name .. "Back"

	if options.Position ~= nil then
		back.Position = options.Position
	end

	if options.Size ~= nil then
		back.Size = options.Size
	end

	back.BackgroundColor3 = options.BackColor or DEFAULT_BAR_BACK_COLOR
	back.BorderSizePixel = 0
	back.ZIndex = resolveChildZIndex(options.Parent, options.FallbackZIndex or 11)

	if cornerRadius ~= false then
		HudWidgetFactory.addCorner(back, cornerRadius)
	end

	if options.Parent ~= nil then
		back.Parent = options.Parent
	end

	local fill = Instance.new("Frame")
	fill.Name = name .. "Fill"
	fill.Size = UDim2.new(1, 0, 1, 0)
	fill.BackgroundColor3 = options.FillColor or DEFAULT_LABEL_COLOR
	fill.BorderSizePixel = 0
	fill.ZIndex = back.ZIndex + 1
	fill.Parent = back

	if cornerRadius ~= false then
		HudWidgetFactory.addCorner(fill, cornerRadius)
	end

	return fill, back
end

-- Styles an existing TextButton in place. Matches the original styleButton.
function HudWidgetFactory.styleButton(button, text)
	button.BackgroundColor3 = DEFAULT_BUTTON_COLOR
	button.BackgroundTransparency = 0
	button.BorderSizePixel = 0
	button.Font = Enum.Font.GothamBold
	button.Text = text or DEFAULT_BUTTON_TEXT
	button.TextColor3 = DEFAULT_BUTTON_TEXT_COLOR
	button.TextSize = 16
	button.TextWrapped = true
	button.AutoButtonColor = true
	button.Active = true
	HudWidgetFactory.addCorner(button, UDim.new(0, 8))
	HudWidgetFactory.addStroke(button, DEFAULT_BUTTON_STROKE_COLOR, 0.3, 1)

	return button
end

-- options:
--   Parent, Name, Position, Size, AnchorPoint, ZIndex, Visible, Text
-- Creates a TextButton and applies the default button style.
function HudWidgetFactory.createButton(options)
	options = options or {}

	local button = Instance.new("TextButton")
	button.Name = options.Name or "Button"

	if options.AnchorPoint ~= nil then
		button.AnchorPoint = options.AnchorPoint
	end

	if options.Position ~= nil then
		button.Position = options.Position
	end

	if options.Size ~= nil then
		button.Size = options.Size
	end

	if options.ZIndex ~= nil then
		button.ZIndex = options.ZIndex
	end

	if options.Visible ~= nil then
		button.Visible = options.Visible
	end

	HudWidgetFactory.styleButton(button, options.Text)

	if options.Parent ~= nil then
		button.Parent = options.Parent
	end

	return button
end

return HudWidgetFactory
]]></ProtectedString>
							<string name="ScriptGuid">{3d8c6e32-9fce-4a2f-8ca3-fc20cf84f2f9}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">HudWidgetFactory</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">147ca5d86d202c460a23cb2a00003646</UniqueId>
						</Properties>
					</Item>
				</Item>
				<Item class="LocalScript" referent="RBX34d17b22576040b1b9fd157c44788fc2">
					<Properties>
						<ProtectedString name="Source"><![CDATA[-- Scripted, animated duel HUD that replaces the legacy on-screen duel panels.
-- Built entirely in Lua (no Studio HUD template dependency) and wired to real
-- gameplay data: tank Health/MaxHealth, server reload attributes, series score,
-- and the player's Bolts wallet. Visual language follows the "Ricochet Tanks"
-- UI concept (dark sci-fi panels, blue/red sides, yellow accents).

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService = game:GetService("TweenService")
local GuiService = game:GetService("GuiService")

local shared = ReplicatedStorage:WaitForChild("Shared")
local configs = shared:WaitForChild("Configs")
local utils = shared:WaitForChild("Utils")
local WeaponConfig = require(configs:WaitForChild("WeaponConfig"))
local HudConfig = require(configs:WaitForChild("HudConfig"))
local TankModelResolver = require(utils:WaitForChild("TankModelResolver"))

local clientFolder = script.Parent
local HudDeviceUtils = require(clientFolder:WaitForChild("Hud"):WaitForChild("HudDeviceUtils"))

local remotes = ReplicatedStorage:WaitForChild("Remotes")
local combatFeedbackEvent = remotes:WaitForChild("CombatFeedbackEvent")
local returnToMenuRequestEvent = remotes:WaitForChild("ReturnToMenuRequestEvent")

local localPlayer = Players.LocalPlayer
local playerGui = localPlayer:WaitForChild("PlayerGui")
local root = Workspace:WaitForChild("WOB_Generated")

------------------------------------------------------------------------
-- Palette (from the UI concept)
------------------------------------------------------------------------
local COLORS = {
	Panel = Color3.fromRGB(13, 17, 23),
	Border = Color3.fromRGB(31, 41, 55),
	BarTrack = Color3.fromRGB(31, 41, 55),
	Blue = Color3.fromRGB(59, 130, 246),
	BlueLight = Color3.fromRGB(96, 165, 250),
	BlueDark = Color3.fromRGB(29, 78, 216),
	Red = Color3.fromRGB(239, 68, 68),
	RedLight = Color3.fromRGB(248, 113, 113),
	RedDark = Color3.fromRGB(185, 28, 28),
	Yellow = Color3.fromRGB(250, 204, 21),
	Green = Color3.fromRGB(34, 197, 94),
	GreenLight = Color3.fromRGB(74, 222, 128),
	GreenDark = Color3.fromRGB(22, 163, 74),
	Orange = Color3.fromRGB(249, 115, 22),
	Text = Color3.fromRGB(226, 232, 240),
	Muted = Color3.fromRGB(100, 116, 139),
}

local PANEL_TRANSPARENCY = 0.1
local TITLE_FONT = Enum.Font.GothamBlack
local LABEL_FONT = Enum.Font.GothamBold
local MONO_FONT = Enum.Font.Code

local RELOAD_FALLBACK_DURATION = math.max(0.05, (WeaponConfig.PrimaryWeapon or {}).ShootCooldown or 0.45)
local SCRIPTED_DUEL_HUD_ENABLED = ((HudConfig.CombatHud or {}).UseScriptedDuelHud == true)
local SCRIPTED_TRAINING_HUD_ENABLED = ((HudConfig.CombatHud or {}).UseScriptedTrainingHud == true)
local TRAINING_COMPACT_HUD = ((HudConfig.CombatHud or {}).TrainingCompactHud == true)
local MAX_FEEDBACK = 4

------------------------------------------------------------------------
-- Small UI builders
------------------------------------------------------------------------
local function lock(guiObject)
	guiObject.Active = false
	pcall(function()
		guiObject.Selectable = false
	end)
end

local function addCorner(parent, radius)
	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, radius)
	corner.Parent = parent
	return corner
end

local function addStroke(parent, color, transparency, thickness)
	local stroke = Instance.new("UIStroke")
	stroke.Color = color
	stroke.Transparency = transparency or 0
	stroke.Thickness = thickness or 1
	stroke.Parent = parent
	return stroke
end

local function makePanel(name, parent)
	local panel = Instance.new("Frame")
	panel.Name = name
	panel.BackgroundColor3 = COLORS.Panel
	panel.BackgroundTransparency = PANEL_TRANSPARENCY
	panel.BorderSizePixel = 0
	panel.Parent = parent
	addCorner(panel, 8)
	addStroke(panel, COLORS.Border, 0.25, 1)
	lock(panel)
	return panel
end

local function makeAccent(parent, color, side)
	local accent = Instance.new("Frame")
	accent.Name = "Accent"
	accent.BorderSizePixel = 0
	accent.BackgroundColor3 = color
	accent.Size = UDim2.new(0, 2, 1, -10)
	accent.Position = UDim2.new(0, 0, 0, 5)
	accent.AnchorPoint = Vector2.new(0, 0)

	if side == "right" then
		accent.AnchorPoint = Vector2.new(1, 0)
		accent.Position = UDim2.new(1, 0, 0, 5)
	end

	addCorner(accent, 2)
	accent.Parent = parent
	lock(accent)
	return accent
end

local function makeLabel(name, parent, font, size, color, xAlign)
	local label = Instance.new("TextLabel")
	label.Name = name
	label.BackgroundTransparency = 1
	label.Font = font
	label.TextSize = size
	label.TextColor3 = color
	label.TextXAlignment = xAlign or Enum.TextXAlignment.Left
	label.TextYAlignment = Enum.TextYAlignment.Center
	label.Text = ""
	label.Parent = parent
	lock(label)
	return label
end

-- A track + fill bar. Returns the fill frame.
local function makeBar(parent, position, size, fillColor)
	local track = Instance.new("Frame")
	track.Name = "Track"
	track.BackgroundColor3 = COLORS.BarTrack
	track.BorderSizePixel = 0
	track.Position = position
	track.Size = size
	track.Parent = parent
	addCorner(track, 99)
	lock(track)

	local fill = Instance.new("Frame")
	fill.Name = "Fill"
	fill.BackgroundColor3 = fillColor
	fill.BorderSizePixel = 0
	fill.Size = UDim2.fromScale(1, 1)
	fill.Parent = track
	addCorner(fill, 99)
	lock(fill)

	return fill, track
end

local function setZIndexTree(instance, zIndex)
	if instance:IsA("GuiObject") then
		instance.ZIndex = zIndex
	end

	for _, descendant in ipairs(instance:GetDescendants()) do
		if descendant:IsA("GuiObject") then
			descendant.ZIndex = zIndex
		end
	end
end

local function tweenButtonVisual(button, scale, pressed, normalColor)
	local targetColor = pressed and COLORS.Orange or normalColor
	local targetScale = pressed and 0.96 or 1

	TweenService:Create(button, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		BackgroundColor3 = targetColor,
	}):Play()
	TweenService:Create(scale, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
		Scale = targetScale,
	}):Play()
end

local function makeButton(name, parent, text, accentColor)
	local normalColor = accentColor or COLORS.Yellow
	local button = Instance.new("TextButton")
	button.Name = name
	button.BackgroundColor3 = normalColor
	button.BackgroundTransparency = 0
	button.BorderSizePixel = 0
	button.Font = TITLE_FONT
	button.Text = text
	button.TextColor3 = COLORS.Panel
	button.TextSize = 13
	button.TextWrapped = true
	button.AutoButtonColor = false
	button.Active = true
	button.Parent = parent
	addCorner(button, 8)
	addStroke(button, COLORS.Orange, 0.35, 1)

	local scale = Instance.new("UIScale")
	scale.Parent = button

	button.MouseEnter:Connect(function()
		tweenButtonVisual(button, scale, false, normalColor)
	end)
	button.MouseButton1Down:Connect(function()
		tweenButtonVisual(button, scale, true, normalColor)
	end)
	button.MouseButton1Up:Connect(function()
		tweenButtonVisual(button, scale, false, normalColor)
	end)
	button.MouseLeave:Connect(function()
		tweenButtonVisual(button, scale, false, normalColor)
	end)

	return button, scale
end

------------------------------------------------------------------------
-- Build the HUD tree
------------------------------------------------------------------------
local gui = Instance.new("ScreenGui")
gui.Name = "WOBDuelHud"
gui.ResetOnSpawn = false
gui.IgnoreGuiInset = true
gui.DisplayOrder = 60
gui.Enabled = false
gui.Parent = playerGui

local rootFrame = Instance.new("Frame")
rootFrame.Name = "Root"
rootFrame.Size = UDim2.fromScale(1, 1)
rootFrame.BackgroundTransparency = 1
rootFrame.Parent = gui
lock(rootFrame)

local function makeGradientShade(name, position, size, rotation)
	local shade = Instance.new("Frame")
	shade.Name = name
	shade.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	shade.BackgroundTransparency = 0
	shade.BorderSizePixel = 0
	shade.Position = position
	shade.Size = size
	shade.ZIndex = 0
	shade.Parent = rootFrame
	lock(shade)

	local gradient = Instance.new("UIGradient")
	gradient.Rotation = rotation
	gradient.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.15),
		NumberSequenceKeypoint.new(1, 1),
	})
	gradient.Parent = shade

	return shade
end

local topShade = makeGradientShade("TopShade", UDim2.fromScale(0, 0), UDim2.new(1, 0, 0, 110), 90)
local bottomShade = makeGradientShade("BottomShade", UDim2.new(0, 0, 1, -96), UDim2.new(1, 0, 0, 96), -90)

-- ---- Top bar -------------------------------------------------------
local topBar = Instance.new("Frame")
topBar.Name = "TopBar"
topBar.Size = UDim2.new(1, 0, 0, 72)
topBar.Position = UDim2.new(0, 0, 0, 0)
topBar.BackgroundTransparency = 1
topBar.Parent = rootFrame
lock(topBar)

-- Player panel (top-left)
local playerPanel = makePanel("PlayerPanel", topBar)
playerPanel.AnchorPoint = Vector2.new(0, 0)
playerPanel.Position = UDim2.new(0, 16, 0, 12)
playerPanel.Size = UDim2.fromOffset(208, 56)
makeAccent(playerPanel, COLORS.Blue, "left")
local playerStroke = playerPanel:FindFirstChildOfClass("UIStroke")

local playerName = makeLabel("Name", playerPanel, MONO_FONT, 11, COLORS.BlueLight, Enum.TextXAlignment.Left)
playerName.Position = UDim2.new(0, 12, 0, 5)
playerName.Size = UDim2.new(1, -24, 0, 12)
playerName.Text = "YOU"

local playerHpFill = makeBar(
	playerPanel,
	UDim2.new(0, 12, 0, 22),
	UDim2.new(1, -64, 0, 8),
	COLORS.GreenLight
)
local playerHpValue = makeLabel("HpValue", playerPanel, MONO_FONT, 12, COLORS.GreenLight, Enum.TextXAlignment.Right)
playerHpValue.Position = UDim2.new(1, -50, 0, 20)
playerHpValue.Size = UDim2.fromOffset(40, 12)
playerHpValue.Text = "--"

local playerReloadFill, playerReloadTrack = makeBar(
	playerPanel,
	UDim2.new(0, 12, 0, 38),
	UDim2.new(1, -64, 0, 5),
	COLORS.BlueLight
)
local playerReloadLabel = makeLabel("ReloadTag", playerPanel, LABEL_FONT, 9, COLORS.Muted, Enum.TextXAlignment.Right)
playerReloadLabel.Position = UDim2.new(1, -50, 0, 35)
playerReloadLabel.Size = UDim2.fromOffset(40, 11)
playerReloadLabel.Text = "RELOAD"

-- Enemy panel (top-right)
local enemyPanel = makePanel("EnemyPanel", topBar)
enemyPanel.AnchorPoint = Vector2.new(1, 0)
enemyPanel.Position = UDim2.new(1, -16, 0, 12)
enemyPanel.Size = UDim2.fromOffset(208, 56)
makeAccent(enemyPanel, COLORS.Red, "right")

local enemyName = makeLabel("Name", enemyPanel, MONO_FONT, 11, COLORS.RedLight, Enum.TextXAlignment.Right)
enemyName.Position = UDim2.new(0, 12, 0, 5)
enemyName.Size = UDim2.new(1, -24, 0, 12)
enemyName.Text = "ENEMY"

local enemyHpValue = makeLabel("HpValue", enemyPanel, MONO_FONT, 12, COLORS.RedLight, Enum.TextXAlignment.Left)
enemyHpValue.Position = UDim2.new(0, 12, 0, 24)
enemyHpValue.Size = UDim2.fromOffset(40, 12)
enemyHpValue.Text = "--"

local enemyHpFill = makeBar(
	enemyPanel,
	UDim2.new(0, 56, 0, 26),
	UDim2.new(1, -68, 0, 8),
	COLORS.RedLight
)

-- Score box (top-center)
local scoreBox = makePanel("ScoreBox", topBar)
scoreBox.AnchorPoint = Vector2.new(0.5, 0)
scoreBox.Position = UDim2.new(0.5, 0, 0, 10)
scoreBox.Size = UDim2.fromOffset(168, 50)

local scoreBoxScale = Instance.new("UIScale")
scoreBoxScale.Parent = scoreBox

local youNum = makeLabel("You", scoreBox, TITLE_FONT, 24, COLORS.Blue, Enum.TextXAlignment.Center)
youNum.Position = UDim2.new(0, 12, 0, 4)
youNum.Size = UDim2.fromOffset(50, 28)
youNum.Text = "0"
local youNumScale = Instance.new("UIScale")
youNumScale.Parent = youNum

local youSub = makeLabel("YouSub", scoreBox, LABEL_FONT, 9, COLORS.Muted, Enum.TextXAlignment.Center)
youSub.Position = UDim2.new(0, 12, 0, 33)
youSub.Size = UDim2.fromOffset(50, 12)
youSub.Text = "YOU"

local divider = makeLabel("Divider", scoreBox, TITLE_FONT, 16, COLORS.Border, Enum.TextXAlignment.Center)
divider.Position = UDim2.new(0.5, -10, 0, 8)
divider.Size = UDim2.fromOffset(20, 24)
divider.Text = "—"

local oppNum = makeLabel("Opp", scoreBox, TITLE_FONT, 24, COLORS.Red, Enum.TextXAlignment.Center)
oppNum.Position = UDim2.new(1, -62, 0, 4)
oppNum.Size = UDim2.fromOffset(50, 28)
oppNum.Text = "0"
local oppNumScale = Instance.new("UIScale")
oppNumScale.Parent = oppNum

local oppSub = makeLabel("OppSub", scoreBox, LABEL_FONT, 9, COLORS.Muted, Enum.TextXAlignment.Center)
oppSub.Position = UDim2.new(1, -62, 0, 33)
oppSub.Size = UDim2.fromOffset(50, 12)
oppSub.Text = "ENEMY"

local trainingTitle = makeLabel("TrainingTitle", scoreBox, TITLE_FONT, 16, COLORS.Yellow, Enum.TextXAlignment.Center)
trainingTitle.Position = UDim2.new(0, 12, 0, 6)
trainingTitle.Size = UDim2.new(1, -24, 0, 20)
trainingTitle.Text = "TRAINING"
trainingTitle.Visible = false

local trainingHint = makeLabel("TrainingHint", scoreBox, LABEL_FONT, 10, COLORS.Muted, Enum.TextXAlignment.Center)
trainingHint.Position = UDim2.new(0, 10, 0, 28)
trainingHint.Size = UDim2.new(1, -20, 0, 16)
trainingHint.Text = "DESTROY TARGETS - PRACTICE RICOCHETS"
trainingHint.TextTruncate = Enum.TextTruncate.AtEnd
trainingHint.Visible = false

-- ---- Bottom bar ----------------------------------------------------
local bottomBar = Instance.new("Frame")
bottomBar.Name = "BottomBar"
bottomBar.AnchorPoint = Vector2.new(0, 1)
bottomBar.Size = UDim2.new(1, 0, 0, 60)
bottomBar.Position = UDim2.new(0, 0, 1, 0)
bottomBar.BackgroundTransparency = 1
bottomBar.Parent = rootFrame
lock(bottomBar)

local reloadPanel = makePanel("ReloadPanel", bottomBar)
reloadPanel.AnchorPoint = Vector2.new(0, 1)
reloadPanel.Position = UDim2.new(0, 16, 1, -12)
reloadPanel.Size = UDim2.fromOffset(210, 44)

local reloadIcon = makeLabel("Icon", reloadPanel, LABEL_FONT, 16, COLORS.BlueLight, Enum.TextXAlignment.Center)
reloadIcon.Position = UDim2.new(0, 8, 0, 0)
reloadIcon.Size = UDim2.new(0, 22, 1, 0)
reloadIcon.Text = "⟳"

local reloadTitle = makeLabel("Title", reloadPanel, LABEL_FONT, 9, COLORS.Muted, Enum.TextXAlignment.Left)
reloadTitle.Position = UDim2.new(0, 36, 0, 7)
reloadTitle.Size = UDim2.new(1, -46, 0, 12)
reloadTitle.Text = "RELOAD"

local reloadBarFill = makeBar(
	reloadPanel,
	UDim2.new(0, 36, 0, 24),
	UDim2.new(1, -48, 0, 6),
	COLORS.BlueLight
)

local boltsPanel = makePanel("BoltsPanel", bottomBar)
boltsPanel.AnchorPoint = Vector2.new(0, 1)
boltsPanel.Position = UDim2.new(0, 236, 1, -12)
boltsPanel.Size = UDim2.fromOffset(104, 44)

local boltIcon = Instance.new("Frame")
boltIcon.Name = "BoltIcon"
boltIcon.BackgroundColor3 = COLORS.Orange
boltIcon.Size = UDim2.fromOffset(18, 18)
boltIcon.Position = UDim2.new(0, 10, 0.5, -9)
boltIcon.BorderSizePixel = 0
boltIcon.Parent = boltsPanel
addCorner(boltIcon, 99)
lock(boltIcon)
local boltGlyph = makeLabel("B", boltIcon, TITLE_FONT, 10, COLORS.Panel, Enum.TextXAlignment.Center)
boltGlyph.Size = UDim2.fromScale(1, 1)
boltGlyph.Text = "B"

local boltsValue = makeLabel("Value", boltsPanel, MONO_FONT, 14, COLORS.Orange, Enum.TextXAlignment.Left)
boltsValue.Position = UDim2.new(0, 34, 0, 0)
boltsValue.Size = UDim2.new(1, -40, 1, 0)
boltsValue.Text = "0"

local boltsReward = makeLabel("Reward", boltsPanel, LABEL_FONT, 11, COLORS.Green, Enum.TextXAlignment.Center)
boltsReward.AnchorPoint = Vector2.new(0.5, 1)
boltsReward.Position = UDim2.new(0.5, 0, 0, 0)
boltsReward.Size = UDim2.fromOffset(96, 16)
boltsReward.TextTransparency = 1
boltsReward.Text = ""

-- ---- Feedback layer (RICOCHET / NO PEN / HIT) ----------------------
local feedbackLayer = Instance.new("Frame")
feedbackLayer.Name = "FeedbackLayer"
feedbackLayer.Size = UDim2.fromScale(1, 1)
feedbackLayer.BackgroundTransparency = 1
feedbackLayer.Parent = rootFrame
lock(feedbackLayer)

local feedbackPool = {}

for index = 1, MAX_FEEDBACK do
	local label = Instance.new("TextLabel")
	label.Name = "FeedbackLabel" .. tostring(index)
	label.BackgroundTransparency = 1
	label.Font = TITLE_FONT
	label.TextSize = 22
	label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	label.TextStrokeTransparency = 1
	label.TextTransparency = 1
	label.AnchorPoint = Vector2.new(0.5, 0.5)
	label.Size = UDim2.fromOffset(260, 40)
	label.Visible = false
	label.Parent = feedbackLayer
	lock(label)

	local scale = Instance.new("UIScale")
	scale.Scale = 0.7
	scale.Parent = label

	feedbackPool[index] = {
		Label = label,
		Scale = scale,
		InUse = false,
		Token = 0,
	}
end

-- ---- Round/match result overlay -----------------------------------
local resultOverlay = Instance.new("Frame")
resultOverlay.Name = "ResultOverlay"
resultOverlay.Size = UDim2.fromScale(1, 1)
resultOverlay.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
resultOverlay.BackgroundTransparency = 1
resultOverlay.Visible = false
resultOverlay.Parent = rootFrame
lock(resultOverlay)

local resultContent = Instance.new("Frame")
resultContent.Name = "ResultContent"
resultContent.AnchorPoint = Vector2.new(0.5, 0.5)
resultContent.Position = UDim2.fromScale(0.5, 0.5)
resultContent.Size = UDim2.fromOffset(420, 170)
resultContent.BackgroundTransparency = 1
resultContent.Parent = resultOverlay
lock(resultContent)

local resultTitle = makeLabel("Title", resultContent, TITLE_FONT, 34, COLORS.Yellow, Enum.TextXAlignment.Center)
resultTitle.Position = UDim2.new(0, 0, 0, 0)
resultTitle.Size = UDim2.new(1, 0, 0, 52)
resultTitle.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
resultTitle.TextStrokeTransparency = 0.28

local resultTitleScale = Instance.new("UIScale")
resultTitleScale.Scale = 0.78
resultTitleScale.Parent = resultTitle

local resultSubtitle = makeLabel("Subtitle", resultContent, LABEL_FONT, 13, COLORS.Muted, Enum.TextXAlignment.Center)
resultSubtitle.Position = UDim2.new(0, 0, 0, 58)
resultSubtitle.Size = UDim2.new(1, 0, 0, 24)

