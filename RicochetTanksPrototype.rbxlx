	WallRicochet = "WallRicochet",
	TankPenetration = "TankPenetration",
	TankNoPen = "TankNoPen",
	TankRicochet = "TankRicochet",
	ShieldReflect = "ShieldReflect",
	Expired = "Expired",
	NoHit = "NoHit",
})

return ProjectileHitResult
]]></ProtectedString>
