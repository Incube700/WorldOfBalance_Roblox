							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">PersistentPlayerStatsService</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">6b430d99b548492f0a0e63fe00001618</UniqueId>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBX26960f5e9ab14972ab99b521396e2f11">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")

local PersistentPlayerStatsService = require(script.Parent:WaitForChild("PersistentPlayerStatsService"))

local MatchStatsService = {}

local DEBUG_STATS = false
local STATS_LOG_INTERVAL = 5

local matchStatDefaults = {
	{ Name = "StatsShotsFired", Value = 0 },
	{ Name = "StatsHits", Value = 0 },
	{ Name = "StatsRicochets", Value = 0 },
	{ Name = "StatsRicochetHits", Value = 0 },
	{ Name = "StatsSelfHits", Value = 0 },
	{ Name = "StatsDamageDealt", Value = 0 },
	{ Name = "StatsDamageTaken", Value = 0 },
	{ Name = "StatsRoundsWon", Value = 0 },
	{ Name = "StatsRoundsLost", Value = 0 },
	{ Name = "StatsMatchResult", Value = "" },
}

local numericMatchStatNames = {
	"StatsShotsFired",
	"StatsHits",
	"StatsRicochets",
	"StatsRicochetHits",
	"StatsSelfHits",
	"StatsDamageDealt",
	"StatsDamageTaken",
	"StatsRoundsWon",
	"StatsRoundsLost",
}

local matchStatsByParticipant = {}
local root = nil
local lastDebugLogByKey = {}

local function copyDefaultStats()
	local stats = {}

	for _, stat in ipairs(matchStatDefaults) do
		stats[stat.Name] = stat.Value
	end

	return stats
end

local function setStatsAttributes(instance, stats)
	if instance == nil then
		return
	end

	for _, stat in ipairs(matchStatDefaults) do
		instance:SetAttribute(stat.Name, stats[stat.Name])
	end
end

local function getParticipantStats(participant)
	if participant == nil then
		return nil
	end

	local stats = matchStatsByParticipant[participant]

	if stats == nil then
		stats = copyDefaultStats()
		matchStatsByParticipant[participant] = stats
	end

	return stats
end

local function participantHasPlayerOwner(participant)
	return participant ~= nil and participant.OwnerPlayer ~= nil and participant.IsPlayerTank == true
end

local function shouldMirrorRootStats(participant)
	if root == nil or participant == nil then
		return false
	end

	local playerSideTankId = root:GetAttribute("PlayerSideTankId")

	if typeof(playerSideTankId) == "string" and playerSideTankId ~= "" then
		return participant.TankId == playerSideTankId
	end

	return participantHasPlayerOwner(participant)
end

local function mirrorParticipantStats(participant)
	local stats = getParticipantStats(participant)

	if stats == nil then
		return
	end

	if participant.OwnerPlayer ~= nil then
		setStatsAttributes(participant.OwnerPlayer, stats)
	end

	if shouldMirrorRootStats(participant) then
		setStatsAttributes(root, stats)
	end
end

local function resetPlayerRuntimeAttributes(player)
	setStatsAttributes(player, copyDefaultStats())
end

local function maybeDebugStats(participant, message)
	if not DEBUG_STATS then
		return
	end

	local tankId = participant ~= nil and participant.TankId or "nil"
	local key = tankId .. ":" .. message
	local now = os.clock()

	if now - (lastDebugLogByKey[key] or 0) < STATS_LOG_INTERVAL then
		return
	end

	lastDebugLogByKey[key] = now
	local userId = participant ~= nil and participant.OwnerUserId or nil
	print("[STATS] runtime recorded tankId=" .. tostring(tankId) .. " userId=" .. tostring(userId) .. " " .. message)
end

local function incrementParticipantStat(participant, statName, amount)
	if not participantHasPlayerOwner(participant) then
		return
	end

	local stats = getParticipantStats(participant)
	stats[statName] = (tonumber(stats[statName]) or 0) + (amount or 1)
	mirrorParticipantStats(participant)
	maybeDebugStats(participant, statName .. "+=" .. tostring(amount or 1))
end

local function setParticipantStat(participant, statName, value)
	if not participantHasPlayerOwner(participant) then
		return
	end

	local stats = getParticipantStats(participant)
	stats[statName] = value
	mirrorParticipantStats(participant)
end

function MatchStatsService.init(targetRoot)
	root = targetRoot
	MatchStatsService.resetRuntimeMatchStats()
end

function MatchStatsService.setMatchStat(name, value)
	if root then
		root:SetAttribute(name, value)
	end
end

function MatchStatsService.incrementMatchStat(name, amount)
	local current = root ~= nil and root:GetAttribute(name) or 0
	MatchStatsService.setMatchStat(name, (tonumber(current) or 0) + (amount or 1))
end

function MatchStatsService.resetRuntimeMatchStats(participants)
	table.clear(matchStatsByParticipant)
	table.clear(lastDebugLogByKey)

	if participants ~= nil then
		for _, participant in ipairs(participants) do
			if participantHasPlayerOwner(participant) then
				matchStatsByParticipant[participant] = copyDefaultStats()
				mirrorParticipantStats(participant)
			end
		end

		return
	end

	if root ~= nil then
		setStatsAttributes(root, copyDefaultStats())
	end

	for _, player in ipairs(Players:GetPlayers()) do
		resetPlayerRuntimeAttributes(player)
	end
end

function MatchStatsService.recordShotFired(participant)
	incrementParticipantStat(participant, "StatsShotsFired", 1)
end

function MatchStatsService.recordProjectileRicochet(projectile)
	if projectile == nil then
		return
	end

	incrementParticipantStat(projectile.OwnerParticipant, "StatsRicochets", 1)
end

function MatchStatsService.recordProjectileTankHitStats(projectile)
	if projectile == nil then
		return
	end

	incrementParticipantStat(projectile.OwnerParticipant, "StatsHits", 1)

	if projectile.BounceCount > 0 then
		incrementParticipantStat(projectile.OwnerParticipant, "StatsRicochetHits", 1)
	end
end

function MatchStatsService.recordProjectileDamageStats(projectile, targetParticipant, damage)
	if projectile == nil then
		return
	end

	local ownerParticipant = projectile.OwnerParticipant
	local resolvedDamage = tonumber(damage) or 0

	if ownerParticipant == targetParticipant then
		incrementParticipantStat(ownerParticipant, "StatsSelfHits", 1)
		incrementParticipantStat(ownerParticipant, "StatsDamageTaken", resolvedDamage)
		return
	end

	incrementParticipantStat(ownerParticipant, "StatsDamageDealt", resolvedDamage)
	incrementParticipantStat(targetParticipant, "StatsDamageTaken", resolvedDamage)
end

function MatchStatsService.recordRoundStats(winnerTankId, loserTankId, participants)
	for _, participant in ipairs(participants or {}) do
		if participant.TankId == winnerTankId then
			incrementParticipantStat(participant, "StatsRoundsWon", 1)
		elseif participant.TankId == loserTankId then
			incrementParticipantStat(participant, "StatsRoundsLost", 1)
		end
	end
end

function MatchStatsService.setParticipantMatchResult(participant, result)
	setParticipantStat(participant, "StatsMatchResult", result)

	if participantHasPlayerOwner(participant) then
		print("[STATS] match result userId=" .. tostring(participant.OwnerUserId) .. " result=" .. tostring(result))
	end
end

function MatchStatsService.getRuntimeMatchStatsSnapshot(participant, currentMatchResult)
	local stats = getParticipantStats(participant) or copyDefaultStats()
	local matchResult = stats.StatsMatchResult

	if matchResult == nil or matchResult == "" then
		matchResult = currentMatchResult
	end

	local snapshot = {
		MatchResult = matchResult or "",
	}

	for _, statName in ipairs(numericMatchStatNames) do
		snapshot[statName] = tonumber(stats[statName]) or 0
	end

	return snapshot
end

function MatchStatsService.persistFinalMatchStats(playerParticipant, currentMatchResult)
	local ownerPlayer = playerParticipant.OwnerPlayer

	if ownerPlayer == nil then
		return
	end

	local statsSnapshot = MatchStatsService.getRuntimeMatchStatsSnapshot(playerParticipant, currentMatchResult)
	print("[STATS] persistent save queued player=" .. ownerPlayer.Name)

	task.spawn(function()
		PersistentPlayerStatsService.saveMatchResult(ownerPlayer, statsSnapshot)
	end)
end

return MatchStatsService
]]></ProtectedString>
							<string name="ScriptGuid">{d797b195-7a19-4988-814f-bd1116e22771}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">MatchStatsService</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">5db59d0e34656d700a0f46d8000009bd</UniqueId>
						</Properties>
					</Item>
				</Item>
				<Item class="ModuleScript" referent="RBXa22e90c6ba5346c985998e58795a7696">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local PlayerTankSpawner = {}

local REQUIRED_PART_NAMES = {
	"Body",
	"Turret",
	"Barrel",
	"ShootPoint",
}

local ARMOR_HITBOX_NAMES = {
	"FrontArmor",
	"RearArmor",
	"LeftArmor",
	"RightArmor",
}

local PART_SPECS = {
	Body = {
		Size = Vector3.new(8, 3, 11),
		Offset = CFrame.new(0, 2, 0),
		Color = Color3.fromRGB(55, 185, 255),
	},
	Turret = {
		Size = Vector3.new(5.5, 2.2, 5.5),
		Offset = CFrame.new(0, 4.6, 0),
		Color = Color3.fromRGB(80, 220, 160),
	},
	Barrel = {
		Size = Vector3.new(1.2, 1.2, 6),
		Offset = CFrame.new(0, 4.6, -5.8),
		Color = Color3.fromRGB(35, 40, 42),
	},
	ShootPoint = {
		Size = Vector3.new(0.6, 0.6, 0.6),
		Offset = CFrame.new(0, 4.6, -10),
		Color = Color3.fromRGB(255, 230, 80),
	},
}

local HITBOX_SPECS = {
	FrontArmor = {
		Size = Vector3.new(8.7, 5.4, 0.25),
		Offset = CFrame.new(0, 3.4, -5.7),
		Color = Color3.fromRGB(70, 235, 190),
		Transparency = 0.35,
	},
	RearArmor = {
		Size = Vector3.new(8.7, 5.4, 0.25),
		Offset = CFrame.new(0, 3.4, 5.7),
		Color = Color3.fromRGB(255, 85, 85),
		Transparency = 0.45,
	},
	LeftArmor = {
		Size = Vector3.new(0.25, 5.4, 11.7),
		Offset = CFrame.new(-4.2, 3.4, 0),
		Color = Color3.fromRGB(255, 205, 70),
		Transparency = 0.45,
	},
	RightArmor = {
		Size = Vector3.new(0.25, 5.4, 11.7),
		Offset = CFrame.new(4.2, 3.4, 0),
		Color = Color3.fromRGB(255, 205, 70),
		Transparency = 0.45,
	},
}

local function getModelPivot(model)
	local success, pivot = pcall(function()
		return model:GetPivot()
	end)

	if success and typeof(pivot) == "CFrame" then
		return pivot
	end

	return CFrame.new()
end

local function findBasePart(model, partName)
	local directChild = model:FindFirstChild(partName)

	if directChild ~= nil and directChild:IsA("BasePart") then
		return directChild
	end

	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant.Name == partName and descendant:IsA("BasePart") then
			return descendant
		end
	end

	return nil
end

local function findFirstBasePart(model)
	local body = findBasePart(model, "Body")

	if body ~= nil then
		return body
	end

	local hull = findBasePart(model, "Hull")

	if hull ~= nil then
		return hull
	end

	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant:IsA("BasePart") then
			return descendant
		end
	end

	if model.PrimaryPart ~= nil then
		return model.PrimaryPart
	end

	return nil
end

local function countBaseParts(model)
	local count = 0

	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant:IsA("BasePart") then
			count += 1
		end
	end

	return count
end

local function configureVisualPart(part, spec, pivot)
	part.Size = spec.Size
	part.CFrame = pivot * spec.Offset
	part.Anchored = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = false
	part.CastShadow = false
	part.Material = Enum.Material.SmoothPlastic
	part.Color = spec.Color
	part.Transparency = 0
end

local function configureHitboxPart(part, spec, pivot)
	part.Size = spec.Size
	part.CFrame = pivot * spec.Offset
	part.Anchored = false
	part.Massless = true
	part.CanCollide = false
	part.CanTouch = false
	part.CanQuery = true
	part.CastShadow = false
	part.Material = Enum.Material.SmoothPlastic
	part.Color = spec.Color
	part.Transparency = spec.Transparency or 0.45
end

local function ensurePart(model, partName)
	local existing = findBasePart(model, partName)

	if existing ~= nil then
		return existing, false
	end

	local part = Instance.new("Part")
	part.Name = partName
	part.Parent = model

	configureVisualPart(part, PART_SPECS[partName], getModelPivot(model))

	warn("[TANK] created missing " .. model:GetFullName() .. "." .. partName)

	return part, true
end

-- Returns the hitbox folder for the model.
-- Prefers "ArmorZones" (BaseTankTemplate contract) over "Hitboxes" (legacy).
-- Deep-searches in case the folder is nested inside a sub-model.
local function findHitboxFolder(model)
	if model == nil then
		return nil
	end

	local armorZones = model:FindFirstChild("ArmorZones")
	if armorZones ~= nil and armorZones:IsA("Folder") then
		return armorZones
	end

	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant.Name == "ArmorZones" and descendant:IsA("Folder") then
			return descendant
		end
	end

	local hitboxes = model:FindFirstChild("Hitboxes")
	if hitboxes ~= nil and hitboxes:IsA("Folder") then
		return hitboxes
	end

	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant.Name == "Hitboxes" and descendant:IsA("Folder") then
			return descendant
		end
	end

	return nil
end

local function ensureHitboxes(model)
	-- Find existing hitbox folder (ArmorZones preferred). Create "Hitboxes" only
	-- when neither folder exists at all.
	local hitboxFolder = findHitboxFolder(model)

	if hitboxFolder == nil then
		hitboxFolder = Instance.new("Folder")
		hitboxFolder.Name = "Hitboxes"
		hitboxFolder.Parent = model
		warn("[TANK] created missing " .. model:GetFullName() .. ".Hitboxes")
	end

	-- When ArmorZones is the active folder, destroy any coexisting legacy Hitboxes
	-- folders to prevent duplicate floating armor rectangles near tanks.
	if hitboxFolder.Name == "ArmorZones" then
		local legacyToDestroy = {}
		for _, descendant in ipairs(model:GetDescendants()) do
			if descendant.Name == "Hitboxes" and descendant:IsA("Folder") then
				table.insert(legacyToDestroy, descendant)
			end
		end
		for _, folder in ipairs(legacyToDestroy) do
			folder:Destroy()
		end
	end

	-- Always ensure the 4 named armor parts exist inside whichever folder we found
	-- or created. TankArmorPartsService.Configure positions and welds them to Body
	-- after this function returns, so missing parts created here will be correctly
	-- placed before the first frame of physics simulation.
	local pivot = getModelPivot(model)

	for _, hitboxName in ipairs(ARMOR_HITBOX_NAMES) do
		local hitbox = hitboxFolder:FindFirstChild(hitboxName)

		if hitbox ~= nil and not hitbox:IsA("BasePart") then
			warn("[TANK] " .. hitbox:GetFullName() .. " is " .. hitbox.ClassName .. ", expected BasePart")
			hitbox = nil
		end

		if hitbox == nil then
			hitbox = Instance.new("Part")
			hitbox.Name = hitboxName
			hitbox.Parent = hitboxFolder
			configureHitboxPart(hitbox, HITBOX_SPECS[hitboxName], pivot)
			warn("[TANK] created missing " .. model:GetFullName() .. "." .. hitboxFolder.Name .. "." .. hitboxName)
		end
	end

	return hitboxFolder
end

function PlayerTankSpawner.ensurePrimaryPart(model)
	local primaryPart = findFirstBasePart(model)

	if primaryPart ~= nil then
		model.PrimaryPart = primaryPart
	end

	return primaryPart
end

function PlayerTankSpawner.getTankParts(model)
	-- findHitboxFolder prefers "ArmorZones" (BaseTankTemplate) over legacy "Hitboxes".
	local parts = {
		Model = model,
		Body = findBasePart(model, "Body"),
		Hull = findBasePart(model, "Hull"),
		Turret = findBasePart(model, "Turret"),
		Barrel = findBasePart(model, "Barrel"),
		ShootPoint = findBasePart(model, "ShootPoint"),
		Hitboxes = findHitboxFolder(model),
		BasePartCount = countBaseParts(model),
		PrimaryPart = PlayerTankSpawner.ensurePrimaryPart(model),
	}

	return parts
end

function PlayerTankSpawner.ensurePhysicalTankModel(model)
	if model == nil or not model:IsA("Model") then
		return model
	end

	for _, partName in ipairs(REQUIRED_PART_NAMES) do
		ensurePart(model, partName)
	end

	ensureHitboxes(model)
	PlayerTankSpawner.ensurePrimaryPart(model)

	return model
end

local function waitForTankParts(model)
	PlayerTankSpawner.ensurePhysicalTankModel(model)

	return PlayerTankSpawner.getTankParts(model)
end

function PlayerTankSpawner.getOrCreateRuntimePlayerTank(sourceModel, parent, tankName)
	PlayerTankSpawner.ensurePhysicalTankModel(sourceModel)

	local existing = parent:FindFirstChild(tankName)

	if existing ~= nil and existing:IsA("Model") then
		return waitForTankParts(existing), false
	end

	local clone = sourceModel:Clone()
	clone.Name = tankName
	clone.Parent = parent

	return waitForTankParts(clone), true
end

function PlayerTankSpawner.getDynamicPlayerTankName(player)
	return "PlayerTank_" .. tostring(player.UserId)
end

function PlayerTankSpawner.getOrCreatePlayerTankForPlayer(sourceModel, parent, player)
	return PlayerTankSpawner.getOrCreateRuntimePlayerTank(
		sourceModel,
		parent,
		PlayerTankSpawner.getDynamicPlayerTankName(player)
	)
end

return PlayerTankSpawner
]]></ProtectedString>
