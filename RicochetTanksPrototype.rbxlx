							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">HealthBarAnchorService</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">26a304254af295c10a1efee200000ab1</UniqueId>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBX53b0282e1f434068ad19f0a2e81fa9d8">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local HealthBarBillboardFactory = {}
HealthBarBillboardFactory.__index = HealthBarBillboardFactory

local function resolveUiAssets()
	local shared = ReplicatedStorage:WaitForChild("Shared")
	local assets = shared:WaitForChild("Assets")
	return assets:FindFirstChild("UI")
end

function HealthBarBillboardFactory.new(config)
	return setmetatable({
		Config = config,
		UiAssets = resolveUiAssets(),
		WarnedMissingTemplate = false,
	}, HealthBarBillboardFactory)
end

function HealthBarBillboardFactory:FindDescendant(root, name, className)
	local object = root:FindFirstChild(name, true)

	if object ~= nil and (className == nil or object:IsA(className)) then
		return object
	end

	return nil
end

function HealthBarBillboardFactory:GetOrCreateFrame(parent, name)
	local existing = parent:FindFirstChild(name)

	if existing ~= nil then
		if existing:IsA("Frame") then
			return existing
		end

		warn(("[WOB] %s.%s is %s, expected Frame. World health bar layout may be incomplete."):format(
			parent:GetFullName(),
			name,
			existing.ClassName
		))
		return nil
	end

	local frame = Instance.new("Frame")
	frame.Name = name
	frame.BorderSizePixel = 0
	frame.Parent = parent

	return frame
end

function HealthBarBillboardFactory:FindTemplate()
	if self.UiAssets == nil then
		return nil
	end

	local template = self.UiAssets:FindFirstChild(self.Config.TEMPLATE_NAME)

	if template ~= nil and template:IsA("BillboardGui") then
		return template
	end

	if not self.WarnedMissingTemplate then
		warn("[WOB] TankHealthBillboard template missing. Using local fallback.")
		self.WarnedMissingTemplate = true
	end

	return nil
end

function HealthBarBillboardFactory:CreateFallbackBillboard()
	local config = self.Config
	local billboard = Instance.new("BillboardGui")
	billboard.Name = config.TEMPLATE_NAME
	billboard.AlwaysOnTop = true
	billboard.LightInfluence = 0
	billboard.MaxDistance = config.MAX_DISTANCE
	billboard.Size = config.BILLBOARD_SIZE
	billboard.StudsOffset = Vector3.zero

	local root = Instance.new("Frame")
	root.Name = "Root"
	root.BackgroundTransparency = 1
	root.BorderSizePixel = 0
	root.Size = UDim2.fromScale(1, 1)
	root.Parent = billboard

	local barsRoot = Instance.new("Frame")
	barsRoot.Name = "BarsRoot"
	barsRoot.BackgroundTransparency = 1
	barsRoot.BorderSizePixel = 0
	barsRoot.Size = UDim2.fromScale(1, 1)
	barsRoot.Parent = root

	local barBack = Instance.new("Frame")
	barBack.Name = "BarBack"
	barBack.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
	barBack.BackgroundTransparency = 0.15
	barBack.BorderSizePixel = 0
	barBack.ClipsDescendants = true
	barBack.Size = config.SHOW_RELOAD_BAR and UDim2.new(1, 0, 0, 8) or UDim2.fromScale(1, 1)
	barBack.Parent = barsRoot

	local redBar = Instance.new("Frame")
	redBar.Name = "RedBar"
	redBar.AnchorPoint = Vector2.new(0, 0.5)
	redBar.Position = UDim2.fromScale(0, 0.5)
	redBar.Size = UDim2.fromScale(1, 1)
	redBar.BackgroundColor3 = Color3.fromRGB(185, 45, 45)
	redBar.BorderSizePixel = 0
	redBar.ZIndex = 1
	redBar.Parent = barBack

	local greenBar = Instance.new("Frame")
	greenBar.Name = "GreenBar"
	greenBar.AnchorPoint = Vector2.new(0, 0.5)
	greenBar.Position = UDim2.fromScale(0, 0.5)
	greenBar.Size = UDim2.fromScale(1, 1)
	greenBar.BackgroundColor3 = Color3.fromRGB(90, 225, 115)
	greenBar.BorderSizePixel = 0
	greenBar.ZIndex = 2
	greenBar.Parent = barBack

	if config.SHOW_RELOAD_BAR then
		local reloadBack = Instance.new("Frame")
		reloadBack.Name = "ReloadBack"
		reloadBack.BackgroundColor3 = Color3.fromRGB(8, 16, 28)
		reloadBack.BackgroundTransparency = 0.12
		reloadBack.BorderSizePixel = 0
		reloadBack.ClipsDescendants = true
		reloadBack.Position = UDim2.new(0, 0, 0, 10)
		reloadBack.Size = UDim2.new(1, 0, 0, 4)
		reloadBack.Parent = barsRoot

		local reloadBar = Instance.new("Frame")
		reloadBar.Name = "ReloadBar"
		reloadBar.AnchorPoint = Vector2.new(0, 0.5)
		reloadBar.Position = UDim2.fromScale(0, 0.5)
		reloadBar.Size = UDim2.fromScale(1, 1)
		reloadBar.BackgroundColor3 = Color3.fromRGB(80, 190, 255)
		reloadBar.BorderSizePixel = 0
		reloadBar.ZIndex = 2
		reloadBar.Parent = reloadBack
	end

	return billboard
end

function HealthBarBillboardFactory:ConfigureBillboard(billboard)
	billboard.Size = self.Config.BILLBOARD_SIZE
	billboard.StudsOffset = Vector3.zero
	-- Reset world-space offset to zero so callers can override it safely.
	-- TankHealthBarRecord sets StudsOffsetWorldSpace per anchor type after this call.
	billboard.StudsOffsetWorldSpace = Vector3.zero
	billboard.AlwaysOnTop = true
	billboard.LightInfluence = 0
	billboard.MaxDistance = self.Config.MAX_DISTANCE
	billboard.Enabled = true
end

function HealthBarBillboardFactory:ConfigureBillboardLayout(billboard)
	local config = self.Config
	local root = self:FindDescendant(billboard, "Root", "Frame")

	if root == nil then
		root = Instance.new("Frame")
		root.Name = "Root"
		root.Parent = billboard
	end

	root.BackgroundTransparency = 1
	root.BorderSizePixel = 0
	root.Size = UDim2.fromScale(1, 1)

	local barsRoot = root:FindFirstChild("BarsRoot")

	if barsRoot == nil then
		barsRoot = Instance.new("Frame")
		barsRoot.Name = "BarsRoot"
		barsRoot.Parent = root
	elseif not barsRoot:IsA("Frame") then
		warn("[WOB] TankHealthBillboard BarsRoot is " .. barsRoot.ClassName .. ", expected Frame.")
		return
	end

	barsRoot.BackgroundTransparency = 1
	barsRoot.BorderSizePixel = 0
	barsRoot.Size = UDim2.fromScale(1, 1)

	local barBack = self:FindDescendant(billboard, "BarBack", "Frame") or self:GetOrCreateFrame(barsRoot, "BarBack")

	if barBack ~= nil then
		barBack.Parent = barsRoot
		barBack.AnchorPoint = Vector2.new(0, 0)
		barBack.Position = UDim2.fromOffset(0, 0)
		barBack.Size = config.SHOW_RELOAD_BAR and UDim2.new(1, 0, 0, 8) or UDim2.fromScale(1, 1)
		barBack.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
		barBack.BackgroundTransparency = 0.15
		barBack.BorderSizePixel = 0
		barBack.ClipsDescendants = true

		local redBar = self:FindDescendant(barBack, "RedBar", "Frame") or self:GetOrCreateFrame(barBack, "RedBar")
		local greenBar = self:FindDescendant(barBack, "GreenBar", "Frame") or self:GetOrCreateFrame(barBack, "GreenBar")

		if redBar ~= nil then
			redBar.AnchorPoint = Vector2.new(0, 0.5)
			redBar.Position = UDim2.fromScale(0, 0.5)
			redBar.Size = UDim2.fromScale(1, 1)
			redBar.BackgroundColor3 = Color3.fromRGB(185, 45, 45)
			redBar.BorderSizePixel = 0
			redBar.ZIndex = 1
		end

		if greenBar ~= nil then
			greenBar.AnchorPoint = Vector2.new(0, 0.5)
			greenBar.Position = UDim2.fromScale(0, 0.5)
			greenBar.BackgroundColor3 = Color3.fromRGB(90, 225, 115)
			greenBar.BorderSizePixel = 0
			greenBar.ZIndex = 2
		end
	end

	local reloadBack = self:FindDescendant(billboard, "ReloadBack", "Frame")

	if config.SHOW_RELOAD_BAR then
		reloadBack = reloadBack or self:GetOrCreateFrame(barsRoot, "ReloadBack")

		if reloadBack ~= nil then
			reloadBack.Parent = barsRoot
			reloadBack.AnchorPoint = Vector2.new(0, 0)
			reloadBack.Position = UDim2.new(0, 0, 0, 10)
			reloadBack.Size = UDim2.new(1, 0, 0, 4)
			reloadBack.BackgroundColor3 = Color3.fromRGB(8, 16, 28)
			reloadBack.BackgroundTransparency = 0.30
			reloadBack.BorderSizePixel = 0
			reloadBack.ClipsDescendants = true
			reloadBack.Visible = true

			local reloadBar = self:FindDescendant(reloadBack, "ReloadBar", "Frame")
				or self:GetOrCreateFrame(reloadBack, "ReloadBar")

			if reloadBar ~= nil then
				reloadBar.AnchorPoint = Vector2.new(0, 0.5)
				reloadBar.Position = UDim2.fromScale(0, 0.5)
				reloadBar.Size = UDim2.fromScale(1, 1)
				reloadBar.BackgroundColor3 = Color3.fromRGB(80, 190, 255)
				reloadBar.BorderSizePixel = 0
				reloadBar.ZIndex = 2
				reloadBar.Visible = true
			end
		end
	elseif reloadBack ~= nil then
		reloadBack.Visible = false
	end
end

function HealthBarBillboardFactory:CreateBillboard()
	local template = self:FindTemplate()
	local billboard = template ~= nil and template:Clone() or self:CreateFallbackBillboard()

	self:ConfigureBillboard(billboard)
	self:ConfigureBillboardLayout(billboard)

	local playerName = self:FindDescendant(billboard, "PlayerName", "TextLabel")
	local hpText = self:FindDescendant(billboard, "HpText", "TextLabel")

	if playerName ~= nil then
		playerName.Visible = false
	end

	if hpText ~= nil then
		hpText.Visible = false
	end

	return billboard
end

return HealthBarBillboardFactory
]]></ProtectedString>
							<string name="ScriptGuid">{4ba1c232-84f6-45f6-bf24-9b62a02391cb}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">HealthBarBillboardFactory</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">26a304254af295c10a1efee200000ab2</UniqueId>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBXd375a2fd1d124b85868fe0f0db8e7225">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local Workspace = game:GetService("Workspace")

local TankHealthBarRecord = {}
TankHealthBarRecord.__index = TankHealthBarRecord

local function getNumberAttribute(instance, names)
	for _, name in ipairs(names) do
		local value = instance:GetAttribute(name)

		if typeof(value) == "number" then
			return value
		end
	end

	return nil
end

local function getServerTimeNow()
	local success, serverTime = pcall(function()
		return Workspace:GetServerTimeNow()
	end)

	if success and typeof(serverTime) == "number" then
		return serverTime
	end

	return os.clock()
end

local function getHealth(model, config)
	local maxHealth = getNumberAttribute(model, { "MaxHealth" }) or 100
	local currentHealth = getNumberAttribute(model, config.HEALTH_ATTRIBUTES) or maxHealth

	return math.max(0, currentHealth), math.max(1, maxHealth)
end

local function getReloadRatio(model, config)
	if not config.SHOW_RELOAD_BAR then
		return 1
	end

	if model:GetAttribute("ReloadReady") == true then
		return 1
	end

	local lastShotAtServerTime = model:GetAttribute("LastShotAtServerTime")
	local reloadDuration = model:GetAttribute("ReloadDuration")

	if typeof(lastShotAtServerTime) == "number" and typeof(reloadDuration) == "number" and reloadDuration > 0 then
		return math.clamp((getServerTimeNow() - lastShotAtServerTime) / reloadDuration, 0, 1)
	end

	local reloadProgress = model:GetAttribute("ReloadProgress")

	if typeof(reloadProgress) == "number" then
		return math.clamp(reloadProgress, 0, 1)
	end

	return 1
end

function TankHealthBarRecord.new(model, context)
	local billboard = context.Factory:CreateBillboard()
	billboard.Name = "TankHealthBillboard_" .. model.Name
	billboard.Parent = context.GuiFolder

	local record = setmetatable({
		Model = model,
		Config = context.Config,
		Scanner = context.Scanner,
		Factory = context.Factory,
		AnchorService = context.AnchorService,
		OnInvalid = context.OnInvalid,
		Billboard = billboard,
		AnchorPart = context.AnchorService:CreateAnchor(model),
		RedBar = context.Factory:FindDescendant(billboard, "RedBar", "Frame"),
		GreenBar = context.Factory:FindDescendant(billboard, "GreenBar", "Frame"),
		ReloadBack = context.Factory:FindDescendant(billboard, "ReloadBack", "Frame"),
		ReloadBar = context.Factory:FindDescendant(billboard, "ReloadBar", "Frame"),
		Connections = {},
	}, TankHealthBarRecord)

	record:Connect()
	record:Update()

	return record
end

function TankHealthBarRecord:Connect()
	for _, attributeName in ipairs(self.Config.TRACKED_ATTRIBUTES) do
		table.insert(self.Connections, self.Model:GetAttributeChangedSignal(attributeName):Connect(function()
			if not self:Update() and self.OnInvalid ~= nil then
				self.OnInvalid(self.Model)
			end
		end))
	end

	table.insert(self.Connections, self.Model.AncestryChanged:Connect(function(_, parent)
		if parent == nil and self.OnInvalid ~= nil then
			self.OnInvalid(self.Model)
		end
	end))
end

function TankHealthBarRecord:UpdateAnchor()
	self.AnchorService:UpdateAnchor(self.Model, self.AnchorPart)
end

function TankHealthBarRecord:UpdateReloadBar()
	if not self.Config.SHOW_RELOAD_BAR then
		if self.ReloadBack ~= nil then
			self.ReloadBack.Visible = false
		end

		return
	end

	if self.ReloadBack ~= nil then
		self.ReloadBack.Visible = true
	end

	if self.ReloadBar == nil then
		return
	end

	local reloadRatio = getReloadRatio(self.Model, self.Config)
	self.ReloadBar.AnchorPoint = Vector2.new(0, 0.5)
	self.ReloadBar.Position = UDim2.fromScale(0, 0.5)
	self.ReloadBar.Size = UDim2.new(reloadRatio, 0, 1, 0)
	self.ReloadBar.Visible = true
end

function TankHealthBarRecord:Update()
	if not self.Scanner.IsTankModel(self.Model, self.Config) then
		return false
	end

	local currentHealth, maxHealth = getHealth(self.Model, self.Config)
	local ratio = math.clamp(currentHealth / maxHealth, 0, 1)
	local isDead = self.Model:GetAttribute("IsDead") == true
		or self.Model:GetAttribute("IsAlive") == false
		or currentHealth <= 0

	self:UpdateAnchor()

	self.Billboard.Adornee = self.AnchorPart
	self.Billboard.Enabled = not isDead
	self.Factory:ConfigureBillboard(self.Billboard)

	-- WORLD_OFFSET.Z is a world-space Z shift that appears sideways in a top-down
	-- camera. For Attachment anchors we remap it to StudsOffset.Y (camera-space up),
	-- so the bar is pushed toward the top of the screen regardless of world orientation.
	-- StudsOffsetWorldSpace stays zero — no rotation artifacts.
	-- The fallback Part anchor bakes WORLD_OFFSET into its world position already,
	-- so its billboard uses zero here to avoid doubling the offset.
	self.Billboard.StudsOffsetWorldSpace = Vector3.zero
	if self.AnchorPart ~= nil and self.AnchorPart:IsA("Attachment") then
		self.Billboard.StudsOffset = Vector3.new(0, math.abs(self.Config.WORLD_OFFSET.Z), 0)
	else
		self.Billboard.StudsOffset = Vector3.zero
	end

	if self.RedBar ~= nil then
		self.RedBar.AnchorPoint = Vector2.new(0, 0.5)
		self.RedBar.Position = UDim2.fromScale(0, 0.5)
		self.RedBar.Size = UDim2.fromScale(1, 1)
		self.RedBar.Visible = true
	end

	if self.GreenBar ~= nil then
		self.GreenBar.AnchorPoint = Vector2.new(0, 0.5)
		self.GreenBar.Position = UDim2.fromScale(0, 0.5)
		self.GreenBar.Size = UDim2.new(ratio, 0, 1, 0)
		self.GreenBar.Visible = ratio > 0
	end

	self:UpdateReloadBar()

	return true
end

function TankHealthBarRecord:Step()
	if self.Model.Parent == nil or self.AnchorPart == nil then
		return false
	end

	if self.Billboard.Enabled == false then
		return true
	end

	self:UpdateAnchor()
	self:UpdateReloadBar()

	return true
end

function TankHealthBarRecord:Destroy()
	for _, connection in ipairs(self.Connections) do
		connection:Disconnect()
	end

	self.Connections = {}

	if self.Billboard ~= nil then
		self.Billboard:Destroy()
	end

	self.AnchorService:CleanupAnchor(self.AnchorPart)
	self.AnchorPart = nil
end

return TankHealthBarRecord
]]></ProtectedString>
