resultButtonLike.BackgroundTransparency = 0
resultButtonLike.BorderSizePixel = 0
resultButtonLike.Text = ""
addCorner(resultButtonLike, 6)
addStroke(resultButtonLike, COLORS.Orange, 0.35, 1)

