			<Item class="Folder" referent="RBXb31586357fd4495882cbba1bc1686ed6">
				<Properties>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
					<string name="Name">Utils</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
					<UniqueId name="UniqueId">5cb6da0208de41c70a0dc989000053cb</UniqueId>
				</Properties>
				<Item class="ModuleScript" referent="RBXb2dd6cf304024e54a244ce3c93e81385">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local RicochetMath = {}

local EPSILON = 0.00001

local function flatten(vector)
	return Vector3.new(vector.X, 0, vector.Z)
end

local function safeUnit(vector, fallback)
	local flat = flatten(vector)

	if flat.Magnitude > EPSILON then
		return flat.Unit
	end

	if fallback ~= nil then
		local flatFallback = flatten(fallback)

		if flatFallback.Magnitude > EPSILON then
			return flatFallback.Unit
		end
	end

	return Vector3.new(0, 0, -1)
end

function RicochetMath.Reflect(direction, normal)
	local incoming = safeUnit(direction)
	local surfaceNormal = safeUnit(normal, -incoming)
	local reflected = incoming - 2 * incoming:Dot(surfaceNormal) * surfaceNormal
	local flatReflected = flatten(reflected)

	if flatReflected.Magnitude <= EPSILON then
		return safeUnit(-incoming)
	end

	return flatReflected.Unit
end

function RicochetMath.GetHitAngleDegrees(incomingDirection, hitNormal)
	local incoming = safeUnit(incomingDirection)
	local surfaceNormal = safeUnit(hitNormal, -incoming)
	local dot = math.clamp((-incoming):Dot(surfaceNormal), -1, 1)

	return math.deg(math.acos(dot))
end

function RicochetMath.CalculateEffectiveArmor(baseArmor, incomingDirection, hitNormal, safeMinCos)
	local incoming = safeUnit(incomingDirection)
	local surfaceNormal = safeUnit(hitNormal, -incoming)
	local minCos = safeMinCos or 0.15
	local dot = math.clamp((-incoming):Dot(surfaceNormal), -1, 1)
	local cos = math.max(dot, minCos)

	return baseArmor / cos
end

function RicochetMath.ClassifyArmorZone(tankBodyCFrame, hitNormal)
	local worldNormal = safeUnit(hitNormal)
	local localNormal = tankBodyCFrame:VectorToObjectSpace(worldNormal)
	local absX = math.abs(localNormal.X)
	local absZ = math.abs(localNormal.Z)

	-- Raycast gives the outward surface normal. By design, +Z local armor is Front,
	-- -Z local armor is Rear, and +/-X local armor is Side.
	if absZ >= absX then
		if localNormal.Z >= 0 then
			return "Front"
		end

		return "Rear"
	end

	return "Side"
end

function RicochetMath.GetBaseArmorForZone(zone, armorConfig)
	if zone == "Front" then
		return armorConfig.FrontArmor
	elseif zone == "Rear" then
		return armorConfig.RearArmor
	end

	return armorConfig.SideArmor
end

function RicochetMath.ResolveArmorHit(params)
	local armorConfig = params.armorConfig
	local safeMinCos = params.safeMinCos or armorConfig.SafeMinCos or 0.15
	local autoRicochetAngleDegrees = params.autoRicochetAngleDegrees
		or armorConfig.AutoRicochetAngleDegrees
		or 72
	local hitAngleDegrees = RicochetMath.GetHitAngleDegrees(params.incomingDirection, params.hitNormal)
	local zone = params.armorZone or RicochetMath.ClassifyArmorZone(params.tankBodyCFrame, params.hitNormal)
	local baseArmor = RicochetMath.GetBaseArmorForZone(zone, armorConfig)
	local effectiveArmor = RicochetMath.CalculateEffectiveArmor(
		baseArmor,
		params.incomingDirection,
		params.hitNormal,
		safeMinCos
	)

	if hitAngleDegrees >= autoRicochetAngleDegrees then
		return {
			Result = "Ricochet",
			Damage = 0,
			Zone = zone,
			HitAngleDegrees = hitAngleDegrees,
			EffectiveArmor = effectiveArmor,
		}
	end

	if params.projectilePenetration < effectiveArmor then
		return {
			Result = "NoPenetration",
			Damage = 0,
			Zone = zone,
			HitAngleDegrees = hitAngleDegrees,
			EffectiveArmor = effectiveArmor,
		}
	end

	return {
		Result = "Penetrated",
		Damage = params.currentDamage,
		Zone = zone,
		HitAngleDegrees = hitAngleDegrees,
		EffectiveArmor = effectiveArmor,
	}
end

return RicochetMath
]]></ProtectedString>
						<string name="ScriptGuid">{add2c250-3d6e-4cbf-aee3-86f5dac0bd8b}</string>
						<BinaryString name="AttributesSerialize">AQAAABYAAABXT0JEaXNhYmxlZEFzc2V0U2NyaXB0AwE=</BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">RicochetMath</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">5cb6da0208de41c70a0dc989000053cc</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="RBX9a2cb94574e54cbdbadffe2d1509f5c0">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local TankModelResolver = {}

local DEFAULT_FOCUS_PART_NAMES = {
	"Body",
	"Hull",
	"Root",
}

local HITBOX_FOLDER_NAME = "Hitboxes"

local function getSearchRoots(root)
	local searchRoots = {}
	local testObjects = root:FindFirstChild("TestObjects")
	local runtime = root:FindFirstChild("Runtime")

	if testObjects ~= nil then
		table.insert(searchRoots, testObjects)
	end

	if runtime ~= nil then
		table.insert(searchRoots, runtime)
	end

	table.insert(searchRoots, root)

	return searchRoots
end

local function getInstanceFromFullName(fullName)
	if typeof(fullName) ~= "string" or fullName == "" then
		return nil
	end

	local current = game
	local isFirstSegment = true

	for segment in string.gmatch(fullName, "[^%.]+") do
		if isFirstSegment then
			isFirstSegment = false

			if segment == "game" then
				current = game
			else
				local success, service = pcall(function()
					return game:GetService(segment)
				end)

				if success and service ~= nil then
					current = service
				else
					current = game:FindFirstChild(segment)
				end
			end
		else
			current = current ~= nil and current:FindFirstChild(segment) or nil
		end

		if current == nil then
			return nil
		end
	end

	return current
end

local function findNamedBasePart(model, partName)
	local directChild = model:FindFirstChild(partName)

	if directChild ~= nil and directChild:IsA("BasePart") then
		return directChild
	end

	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant.Name == partName and descendant:IsA("BasePart") then
			return descendant
		end
	end

	return nil
end

local function isInsideHitboxes(instance)
	local current = instance.Parent

	while current ~= nil do
		if current.Name == HITBOX_FOLDER_NAME then
			return true
		end

		if current:IsA("Model") then
			return false
		end

		current = current.Parent
	end

	return false
end

local function findFirstPhysicalBasePart(model)
	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant:IsA("BasePart") and not isInsideHitboxes(descendant) then
			return descendant
		end
	end

	return nil
end

function TankModelResolver.countBaseParts(model)
	if model == nil then
		return 0
	end

	local count = 0

	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant:IsA("BasePart") then
			count += 1
		end
	end

	return count
end

function TankModelResolver.findFocusPart(model)
	if model == nil then
		return nil
	end

	if model:IsA("BasePart") then
		return model
	end

	if not model:IsA("Model") then
		return nil
	end

	if model.PrimaryPart ~= nil and not isInsideHitboxes(model.PrimaryPart) then
		return model.PrimaryPart
	end

	for _, partName in ipairs(DEFAULT_FOCUS_PART_NAMES) do
		local part = findNamedBasePart(model, partName)

		if part ~= nil then
			return part
		end
	end

	return findFirstPhysicalBasePart(model)
end

function TankModelResolver.hasBasePart(model)
	return TankModelResolver.findFocusPart(model) ~= nil
end

local function findPhysicalModelByTankId(root, tankId)
	if tankId == nil or tankId == "" then
		return nil
	end

	for _, searchRoot in ipairs(getSearchRoots(root)) do
		local named = searchRoot:FindFirstChild(tankId, true)

		if named ~= nil and named:IsA("Model") and TankModelResolver.hasBasePart(named) then
			return named
		end

		for _, descendant in ipairs(searchRoot:GetDescendants()) do
			if descendant:IsA("Model")
				and descendant:GetAttribute("TankId") == tankId
				and TankModelResolver.hasBasePart(descendant)
			then
				return descendant
			end
		end
	end

	return nil
end

function TankModelResolver.resolvePhysicalModel(root, model)
	if model == nil or not model:IsA("Model") then
		return nil
	end

	if TankModelResolver.hasBasePart(model) then
		return model
	end

	local physicalModelPath = model:GetAttribute("PhysicalModelPath")
	local physicalModel = getInstanceFromFullName(physicalModelPath)

	if physicalModel ~= nil and physicalModel:IsA("Model") and TankModelResolver.hasBasePart(physicalModel) then
		return physicalModel
	end

	return findPhysicalModelByTankId(root, model:GetAttribute("TankId") or model.Name)
end

function TankModelResolver.findOwnedTank(root, userId, requirePhysical)
	local fallback = nil

	for _, searchRoot in ipairs(getSearchRoots(root)) do
		for _, descendant in ipairs(searchRoot:GetDescendants()) do
			if descendant:IsA("Model")
				and descendant:GetAttribute("IsPlayerTank") == true
				and descendant:GetAttribute("OwnerUserId") == userId
			then
				local physicalModel = TankModelResolver.resolvePhysicalModel(root, descendant)

				if physicalModel ~= nil then
					return physicalModel
				end

				fallback = fallback or descendant
			end
		end
	end

	if requirePhysical == true then
		return nil
	end

	return fallback
end

function TankModelResolver.findTankByTankId(root, tankId, requirePhysical)
	local fallback = nil

	for _, searchRoot in ipairs(getSearchRoots(root)) do
		for _, descendant in ipairs(searchRoot:GetDescendants()) do
			if descendant:IsA("Model")
				and (descendant:GetAttribute("TankId") == tankId or descendant.Name == tankId)
			then
				local physicalModel = TankModelResolver.resolvePhysicalModel(root, descendant)

				if physicalModel ~= nil then
					return physicalModel
				end

				fallback = fallback or descendant
			end
		end
	end

	if requirePhysical == true then
		return nil
	end

	return fallback
end

function TankModelResolver.findTankByRole(root, role, requirePhysical)
	local fallback = nil

	for _, searchRoot in ipairs(getSearchRoots(root)) do
		for _, descendant in ipairs(searchRoot:GetDescendants()) do
			if descendant:IsA("Model")
				and descendant:GetAttribute("TankRole") == role
				and descendant:GetAttribute("IsActive") ~= false
			then
				local physicalModel = TankModelResolver.resolvePhysicalModel(root, descendant)

				if physicalModel ~= nil then
					return physicalModel
				end

				fallback = fallback or descendant
			end
		end
	end

	if requirePhysical == true then
		return nil
	end

	return fallback
end

function TankModelResolver.findEnemyTank(root, userId)
	local ownedTank = TankModelResolver.findOwnedTank(root, userId, true)
	local opponentTankId = ownedTank ~= nil and ownedTank:GetAttribute("OpponentTankId") or nil

	if opponentTankId ~= nil and opponentTankId ~= "" then
		local opponentTank = TankModelResolver.findTankByTankId(root, opponentTankId, true)

		if opponentTank ~= nil then
			return opponentTank
		end
	end

	local matchMode = root:GetAttribute("MatchMode")

	if matchMode == "PvP" then
		for _, searchRoot in ipairs(getSearchRoots(root)) do
			for _, descendant in ipairs(searchRoot:GetDescendants()) do
				if descendant:IsA("Model")
					and descendant:GetAttribute("IsPlayerTank") == true
					and descendant:GetAttribute("IsActive") ~= false
					and descendant:GetAttribute("OwnerUserId") ~= nil
					and descendant:GetAttribute("OwnerUserId") ~= userId
				then
					local physicalModel = TankModelResolver.resolvePhysicalModel(root, descendant)

					if physicalModel ~= nil then
						return physicalModel
					end
				end
			end
		end
	end

	return TankModelResolver.findTankByRole(root, "Dummy", true)
end

return TankModelResolver
]]></ProtectedString>
