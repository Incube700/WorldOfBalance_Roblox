				<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
				<string name="Name">TankTemplates</string>
				<int64 name="SourceAssetId">-1</int64>
				<BinaryString name="Tags"></BinaryString>
				<UniqueId name="UniqueId">0f7e8050d957ea560a231c09000008f9</UniqueId>
			</Properties>
			<Item class="Model" referent="RBXbc6da1489c324d5586e311af34554c1b">
				<Properties>
					<token name="LevelOfDetail">0</token>
					<CoordinateFrame name="ModelMeshCFrame">
						<X>-48.4805183</X>
						<Y>0.829746962</Y>
						<Z>66.7579956</Z>
						<R00>0.707176745</R00>
						<R01>0</R01>
						<R02>-0.707176745</R02>
						<R10>0</R10>
						<R11>1</R11>
						<R12>0</R12>
						<R20>0.707069814</R20>
						<R21>0</R21>
						<R22>0.707069814</R22>
					</CoordinateFrame>
					<SharedString name="ModelMeshData">yuZpQdnvvUBOTYh1jqZ2cA==</SharedString>
					<Vector3 name="ModelMeshSize">
						<X>0</X>
						<Y>0</Y>
						<Z>0</Z>
					</Vector3>
