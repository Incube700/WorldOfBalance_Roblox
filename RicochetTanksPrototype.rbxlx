							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">TankTemplateProvider</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">26a304254af295c10a1efee200007630</UniqueId>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBX497fd8528ce94fc29ebc1b0711cf1a92">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local configs = ReplicatedStorage:WaitForChild("Shared"):WaitForChild("Configs")
local TankFactoryConfig = require(configs:WaitForChild("TankFactoryConfig"))

local TankStatsProfile = require(script.Parent:WaitForChild("TankStatsProfile"))

local TankStatsProvider = {}
TankStatsProvider.__index = TankStatsProvider

local DEFAULT_STATS_BY_PROFILE = table.freeze({
	[TankStatsProfile.DuelNormalized] = table.freeze({}),
	[TankStatsProfile.ArenaDefault] = table.freeze({}),
	[TankStatsProfile.TrainingPlayer] = table.freeze({}),
	[TankStatsProfile.TrainingDummy] = table.freeze({}),
	[TankStatsProfile.BotDefault] = table.freeze({}),
})

local function getNumberAttribute(model, attributeName)
	if model == nil then
		return nil
	end

	local value = model:GetAttribute(attributeName)

	return typeof(value) == "number" and value or nil
end

function TankStatsProvider.new()
	return setmetatable({}, TankStatsProvider)
end

function TankStatsProvider:GetStats(statsProfileId, request, model)
	request = request or {}

	local profileDefaults = DEFAULT_STATS_BY_PROFILE[statsProfileId] or DEFAULT_STATS_BY_PROFILE[TankStatsProfile.DuelNormalized]
	local maxHealth = tonumber(request.MaxHealth)
		or getNumberAttribute(model, "MaxHealth")
		or profileDefaults.MaxHealth
		or TankFactoryConfig.DefaultStats.MaxHealth
	local health = tonumber(request.Health)
		or tonumber(request.CurrentHealth)
		or getNumberAttribute(model, "CurrentHealth")
		or getNumberAttribute(model, "HP")
		or getNumberAttribute(model, "Health")
		or profileDefaults.Health
		or maxHealth

	maxHealth = math.max(1, maxHealth)
	health = math.clamp(health, 0, maxHealth)

	return {
		MaxHealth = maxHealth,
		Health = health,
		WeaponId = request.WeaponId
			or (request.Loadout ~= nil and request.Loadout.WeaponId)
			or TankFactoryConfig.DefaultLoadout.WeaponId,
	}
end

return TankStatsProvider
]]></ProtectedString>
							<string name="ScriptGuid">{eee6bc11-9616-4635-86bc-cbae88a8bcc4}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">TankStatsProvider</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">26a304254af295c10a1efee200007632</UniqueId>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBX7beb17e004174a18ae13f6bbbb4c3aea">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local shared = ReplicatedStorage:WaitForChild("Shared")
local configs = shared:WaitForChild("Configs")
local TankArmorConfig = require(configs:WaitForChild("TankArmorConfig"))
local TankConfig = require(configs:WaitForChild("TankConfig"))

local TankArmorPartsService = {}

local ARMOR_PART_NAMES = table.freeze({
	"FrontArmor",
	"RearArmor",
	"LeftArmor",
	"RightArmor",
})

local ARMOR_ZONE_BY_PART = table.freeze({
	FrontArmor = "Front",
	RearArmor = "Rear",
	LeftArmor = "Side",
	RightArmor = "Side",
})

local TANK_ARMOR = TankConfig.Armor or {}
local ARMOR_VISUALS = TankArmorConfig.Visuals or {}
local ARMOR_HITBOX_PADDING = TANK_ARMOR.ArmorHitboxPadding or 0.75
local ARMOR_HITBOX_THICKNESS = TANK_ARMOR.ArmorHitboxThickness or 1.2
local ARMOR_HITBOX_HEIGHT = TANK_ARMOR.ArmorHitboxHeight or 5.4
local ARMOR_HITBOX_Y_OFFSET = TANK_ARMOR.ArmorHitboxYOffset or 1.4
local ARMOR_HITBOX_MATERIAL = ARMOR_VISUALS.Material or TANK_ARMOR.ArmorHitboxMaterial or Enum.Material.SmoothPlastic
local FRONT_ARMOR_COLOR = ARMOR_VISUALS.FrontColor or TANK_ARMOR.FrontArmorColor or Color3.fromRGB(70, 235, 190)
local REAR_ARMOR_COLOR = ARMOR_VISUALS.RearColor or TANK_ARMOR.RearArmorColor or Color3.fromRGB(255, 85, 85)
local SIDE_ARMOR_COLOR = ARMOR_VISUALS.SideColor or TANK_ARMOR.SideArmorColor or Color3.fromRGB(255, 205, 70)

local resolvedArmorHitboxMaterial = nil

local function findBasePart(model, partName)
	if model == nil then
		return nil
	end

	local directChild = model:FindFirstChild(partName)

	if directChild ~= nil and directChild:IsA("BasePart") then
		return directChild
	end

	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant.Name == partName and descendant:IsA("BasePart") then
			return descendant
		end
	end

	return nil
end

local function findStableBodyPart(model)
	return findBasePart(model, "Body")
		or findBasePart(model, "Hull")
		or (model ~= nil and model.PrimaryPart or nil)
end

-- Finds the folder that contains armor zone parts.
-- Supports both:
--   "ArmorZones" — BaseTankTemplate / new workflow (preferred)
--   "Hitboxes"   — legacy PlayerTankPrototype / Player2TankPrototype / DummyTank
-- "ArmorZones" takes priority when both exist.
local function findArmorZonesFolder(model)
	if model == nil then
		return nil
	end

	-- Priority 1: ArmorZones (BaseTankTemplate contract)
	local directArmorZones = model:FindFirstChild("ArmorZones")

	if directArmorZones ~= nil and directArmorZones:IsA("Folder") then
		return directArmorZones
	end

	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant.Name == "ArmorZones" and descendant:IsA("Folder") then
			return descendant
		end
	end

	-- Priority 2: Hitboxes (legacy prototype contract)
	local directHitboxes = model:FindFirstChild("Hitboxes")

	if directHitboxes ~= nil and directHitboxes:IsA("Folder") then
		return directHitboxes
	end

	for _, descendant in ipairs(model:GetDescendants()) do
		if descendant.Name == "Hitboxes" and descendant:IsA("Folder") then
			return descendant
		end
	end

	return nil
end

local function getArmorHitboxMaterial()
	if resolvedArmorHitboxMaterial ~= nil then
		return resolvedArmorHitboxMaterial
	end

	if typeof(ARMOR_HITBOX_MATERIAL) == "EnumItem"
		and ARMOR_HITBOX_MATERIAL.EnumType == Enum.Material
	then
		resolvedArmorHitboxMaterial = ARMOR_HITBOX_MATERIAL
		return resolvedArmorHitboxMaterial
	end

	if typeof(ARMOR_HITBOX_MATERIAL) == "string" then
		local success, material = pcall(function()
			return Enum.Material[ARMOR_HITBOX_MATERIAL]
		end)

		if success and material ~= nil then
			resolvedArmorHitboxMaterial = material
			return resolvedArmorHitboxMaterial
		end
	end

	resolvedArmorHitboxMaterial = Enum.Material.SmoothPlastic
	return resolvedArmorHitboxMaterial
end

local function shouldShowArmorZones()
	return ARMOR_VISUALS.ArmorZonesVisible ~= false
end

local function getArmorTransparency(armorPartName)
	if not shouldShowArmorZones() then
		return 1
	end

	if armorPartName == "FrontArmor" then
		return ARMOR_VISUALS.FrontTransparency or 0.35
	elseif armorPartName == "RearArmor" then
		return ARMOR_VISUALS.RearTransparency or 0.45
	elseif armorPartName == "LeftArmor" or armorPartName == "RightArmor" then
		return ARMOR_VISUALS.SideTransparency or 0.45
	end

	return ARMOR_VISUALS.CornerTransparency or 0.45
end

local function getArmorSpec(body, armorPartName)
	local frontRearSize = Vector3.new(
		body.Size.X + ARMOR_HITBOX_PADDING * 2,
		ARMOR_HITBOX_HEIGHT,
		ARMOR_HITBOX_THICKNESS
	)
	local sideSize = Vector3.new(
		ARMOR_HITBOX_THICKNESS,
		ARMOR_HITBOX_HEIGHT,
		body.Size.Z + ARMOR_HITBOX_PADDING * 2
	)
	local frontZ = -(body.Size.Z * 0.5 + ARMOR_HITBOX_THICKNESS * 0.5)
	local rearZ = body.Size.Z * 0.5 + ARMOR_HITBOX_THICKNESS * 0.5
	local leftX = -(body.Size.X * 0.5 + ARMOR_HITBOX_THICKNESS * 0.5)
	local rightX = body.Size.X * 0.5 + ARMOR_HITBOX_THICKNESS * 0.5

	if armorPartName == "FrontArmor" then
		return frontRearSize, CFrame.new(0, ARMOR_HITBOX_Y_OFFSET, frontZ), FRONT_ARMOR_COLOR
	elseif armorPartName == "RearArmor" then
		return frontRearSize, CFrame.new(0, ARMOR_HITBOX_Y_OFFSET, rearZ), REAR_ARMOR_COLOR
	elseif armorPartName == "LeftArmor" then
		return sideSize, CFrame.new(leftX, ARMOR_HITBOX_Y_OFFSET, 0), SIDE_ARMOR_COLOR
	elseif armorPartName == "RightArmor" then
		return sideSize, CFrame.new(rightX, ARMOR_HITBOX_Y_OFFSET, 0), SIDE_ARMOR_COLOR
	end

	return nil, nil, nil
end

local function getOrCreateBodyWeld(body, armorPart)
	local weld = armorPart:FindFirstChild("WOBArmorBodyWeld")

	if weld ~= nil and not weld:IsA("WeldConstraint") then
		weld:Destroy()
		weld = nil
	end

	if weld ~= nil and (weld.Part0 ~= body or weld.Part1 ~= armorPart) then
		weld:Destroy()
		weld = nil
	end

	if weld == nil then
		weld = Instance.new("WeldConstraint")
		weld.Name = "WOBArmorBodyWeld"
		weld.Part0 = body
		weld.Part1 = armorPart
		weld.Parent = armorPart
	end

	return weld
end

local function configureArmorPart(body, armorPart)
	if armorPart == nil or not armorPart:IsA("BasePart") then
		return false
	end

	local size, localOffset, color = getArmorSpec(body, armorPart.Name)

	if size == nil then
		return false
	end

	local weld = armorPart:FindFirstChild("WOBArmorBodyWeld")
	local needsPoseRefresh = weld == nil
		or armorPart:GetAttribute("WOBArmorConfigured") ~= true
		or armorPart:GetAttribute("WOBArmorBodyName") ~= body.Name

	armorPart.Size = size

	if needsPoseRefresh then
		armorPart.CFrame = body.CFrame * localOffset
	end

	armorPart.Anchored = false
	armorPart.Massless = true
	armorPart.CanCollide = false
	armorPart.CanTouch = false
	armorPart.CanQuery = true
	armorPart.CastShadow = false
	armorPart.Material = getArmorHitboxMaterial()
	armorPart.Color = color
	armorPart.Transparency = getArmorTransparency(armorPart.Name)
	armorPart:SetAttribute("WOBArmorHitbox", true)
	armorPart:SetAttribute("ArmorZone", ARMOR_ZONE_BY_PART[armorPart.Name])
	armorPart:SetAttribute("WOBArmorGameplayVisible", shouldShowArmorZones())
	armorPart:SetAttribute("WOBArmorConfigured", true)
	armorPart:SetAttribute("WOBArmorBodyName", body.Name)

	getOrCreateBodyWeld(body, armorPart)

	return true
end

function TankArmorPartsService.Configure(tankModel)
	local body = findStableBodyPart(tankModel)
	local hitboxes = findArmorZonesFolder(tankModel)

	if body == nil or hitboxes == nil then
		return false
	end

	local configuredCount = 0

	for _, armorPartName in ipairs(ARMOR_PART_NAMES) do
		local armorPart = hitboxes:FindFirstChild(armorPartName)

		if configureArmorPart(body, armorPart) then
			configuredCount += 1
		end
	end

	return configuredCount > 0
end

return TankArmorPartsService
]]></ProtectedString>
							<string name="ScriptGuid">{7911ba70-cf1a-4c6e-b5f4-cdd09dace7df}</string>
							<BinaryString name="AttributesSerialize"></BinaryString>
							<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
							<bool name="DefinesCapabilities">false</bool>
							<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
							<string name="Name">TankArmorPartsService</string>
							<int64 name="SourceAssetId">-1</int64>
							<BinaryString name="Tags"></BinaryString>
							<UniqueId name="UniqueId">26a304254af295c10a1efee200008de1</UniqueId>
						</Properties>
					</Item>
					<Item class="ModuleScript" referent="RBX4e9018ba6ab44c189a038e30e3aa5556">
						<Properties>
							<Content name="LinkedSource"><null></null></Content>
							<ProtectedString name="Source"><![CDATA[-- TankSkinApplier
-- Applies a visual skin to a tank model after clone/reuse.
-- Responsibilities:
--   - Configure parts inside the Visuals folder (CanQuery=false, CanCollide=false, etc.)
--   - Apply base color/material to visual parts for the requested SkinId.
--   - Does NOT touch armor stats, armor zone sizes, collision on Body, or gameplay logic.
--
-- Called by TankFactory after clone:
--   TankSkinApplier.Apply(tankModel, loadout)
--
-- Future skins: add new SkinId entries to SKIN_CONFIGS below.

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local shared = ReplicatedStorage:WaitForChild("Shared")
local configs = shared:WaitForChild("Configs")
local TankFactoryConfig = require(configs:WaitForChild("TankFactoryConfig"))
local SkinCatalog = require(configs:WaitForChild("SkinCatalog"))

local TankSkinApplier = {}

-- Part name → which skin color key to use.
local VISUAL_PART_COLOR_MAP = {
	BodyVisual    = "BodyColor",
	HullVisual    = "BodyColor",
	TrackLeft     = "BodyColor",
	TrackRight    = "BodyColor",
	Tracks        = "BodyColor",
	TurretVisual  = "TurretColor",
	TurretMesh    = "TurretColor",
	BarrelVisual  = "BarrelColor",
	BarrelMesh    = "BarrelColor",
}

local function applyVisualsProperties(part)
	if part == nil or not part:IsA("BasePart") then
		return
	end

	-- Visual parts must never block projectile raycasts or physical collision.
	part.CanCollide  = false
	part.CanTouch    = false
	part.CanQuery    = false
	part.Massless    = true
	part.Anchored    = false
	part.CastShadow  = false
end

local function applyColor(part, skinConfig)
	if part == nil or not part:IsA("BasePart") then
		return
	end

	local colorKey = VISUAL_PART_COLOR_MAP[part.Name]

	if colorKey ~= nil and skinConfig[colorKey] ~= nil then
		part.Color = skinConfig[colorKey]
	end

	if skinConfig.Material ~= nil then
		pcall(function()
			part.Material = skinConfig.Material
		end)
	end
end

local function processVisualsFolder(visualsFolder, skinConfig)
	if visualsFolder == nil then
		return
	end

	for _, child in ipairs(visualsFolder:GetDescendants()) do
		if child:IsA("BasePart") then
			applyVisualsProperties(child)
			applyColor(child, skinConfig)
		end
	end
end

local function findVisualsFolder(tankModel)
	if tankModel == nil then
		return nil
	end

	local direct = tankModel:FindFirstChild("Visuals")

	if direct ~= nil and direct:IsA("Folder") then
		return direct
	end

	for _, descendant in ipairs(tankModel:GetDescendants()) do
		if descendant.Name == "Visuals" and descendant:IsA("Folder") then
			return descendant
		end
	end

	return nil
end

local function getSkinConfig(skinId)
	local skins = SkinCatalog.Skins or {}
	local defaultSkinId = SkinCatalog.DefaultSkinId or TankFactoryConfig.DefaultLoadout.SkinId or "Default"
	local requestedSkin = skins[skinId]

	if requestedSkin ~= nil and typeof(requestedSkin.AliasOf) == "string" and skins[requestedSkin.AliasOf] ~= nil then
		return skins[requestedSkin.AliasOf], requestedSkin.AliasOf
	end

	if requestedSkin ~= nil then
		return requestedSkin, skinId
	end

	return skins[defaultSkinId] or skins.Default, defaultSkinId
end

-- Apply skin to the tank model.
-- loadout: table with optional SkinId field.
-- Falls back to "Default" if SkinId is nil or unknown.
function TankSkinApplier.Apply(tankModel, loadout)
	if tankModel == nil then
		return
	end

	local skinId = "Default"

	if loadout ~= nil and loadout.SkinId ~= nil then
		skinId = loadout.SkinId
	end

	local skinConfig, resolvedSkinId = getSkinConfig(skinId)

	if skinConfig == nil then
		warn("[TANK SKIN APPLIER] No skin config found for SkinId=" .. tostring(skinId) .. "; skipping.")
		return
	end

	tankModel:SetAttribute("SkinId", resolvedSkinId)

	local visualsFolder = findVisualsFolder(tankModel)

	if visualsFolder ~= nil then
		processVisualsFolder(visualsFolder, skinConfig)
	end
	-- Note: if the tank has no Visuals folder (legacy prototypes), this is a no-op.
	-- TankCustomizationService.applySkin handles legacy visual parts separately.
end

return TankSkinApplier
]]></ProtectedString>
