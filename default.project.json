{
  "name": "WorldOfBalanceRoblox",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/ReplicatedStorage/Shared",
        "Assets": {
          "$className": "Folder",
          "VFX": {
            "$className": "Folder",
            "$ignoreUnknownInstances": true
          }
        }
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/ServerScriptService/Server"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/StarterPlayer/StarterPlayerScripts/Client"
        }
      }
    }
  }
}
